---
import { landingCopy, type LandingLang } from '../data/landing';

interface Props {
  lang?: LandingLang;
}

const { lang = 'en' } = Astro.props;
const t = landingCopy(lang);
const faqs = t.faq.items;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.a,
    },
  })),
};
---

<section id={t.ids.faq} class="faq-section">

  <div class="faq-header fade-up" data-delay="0">
    <h2 class="faq-display">{t.faq.displayLine1}<br/>{t.faq.displayLine2}</h2>
  </div>

  <div class="faq-list">
    {faqs.map((f, i) => (
      <details class="faq-card fade-up" data-delay={String(80 + i * 60)}>
        <summary class="faq-summary">
          <span class="faq-q-text">{f.q}</span>
          <span class="faq-icon" aria-hidden="true">+</span>
        </summary>
        <div class="faq-a">
          <p>{f.a}</p>
          {'moreHref' in f && f.moreHref && (
            <p class="faq-more">
              <a href={f.moreHref}>{f.moreLabel}</a>
            </p>
          )}
        </div>
      </details>
    ))}
  </div>

</section>

<script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />

<style>
  .faq-section {
    background: var(--white, oklch(99% 0 0));
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3.5rem);
  }

  .faq-header {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .faq-display {
    font-family: var(--font-display, inherit);
    font-size: clamp(2rem, 5vw, 4.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink, #2C303C);
    text-transform: uppercase;
    text-wrap: balance;
    margin: 0;
  }

  /* ── Cards ── */
  .faq-list {
    display: flex;
    flex-direction: column;
    max-width: 860px;
  }

  .faq-card {
    overflow: hidden;
  }

  .faq-card + .faq-card {
    border-top: 1px dotted var(--rule, oklch(87% 0.005 260));
  }

  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.85rem 1rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary::marker { display: none; content: ''; }

  .faq-q-text {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--ink, #2C303C);
    margin: 0;
    display: inline;
  }

  .faq-icon {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 300;
    color: var(--ghost, oklch(50% 0.006 260));
    line-height: 1;
    transition: transform 0.2s;
  }

  .faq-card[open] .faq-icon {
    transform: rotate(45deg);
  }

  .faq-a {
    margin: 0;
    padding: 0 1rem 0.9rem;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.75;
    color: var(--dim, oklch(28% 0.010 258));
  }

  .faq-a p {
    margin: 0;
  }

  .faq-more {
    margin-top: 0.65rem;
  }

  .faq-more a {
    color: var(--cobalt, #bbdd00);
    text-decoration: none;
    font-weight: 600;
  }

  .faq-more a:hover {
    text-decoration: underline;
  }
</style>
