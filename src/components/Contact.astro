---
const EMAILJS_PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;
const EMAILJS_SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
const EMAILJS_TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;

const socials = [
  { label: 'GitHub',    href: 'https://github.com/Vllrich' },
  { label: 'Instagram', href: 'https://www.instagram.com/vllrich/' },
  { label: 'LinkedIn',  href: 'https://www.linkedin.com/in/lars-ullrich-47338a27/' },
];
---

<section id="contact" class="contact-section">

  <div class="contact-inner">
    <div class="contact-left">
      <h2 class="contact-display fade-up" data-delay="0">
        Let's<br/>Talk.
      </h2>

      <p class="contact-intro fade-up" data-delay="120">
        Tell me what you're building and where it's stuck. If I'm the right person to help, I'll say so. If I'm not, I'll tell you that too.
      </p>

      <p class="contact-note fade-in" data-delay="240">
        Best starting point for most teams:
        <a href="/services/readiness-audit/">Readiness &amp; Production Audit</a>
        (fixed scope, 1-2 weeks).
      </p>

      <p class="contact-note fade-in" data-delay="320">
        Currently open to AI readiness audits, corporate LLM builds, agent and production builds, reliability retainers, and fractional CTO/CAIO engagements.
      </p>
    </div>

    <div class="contact-right fade-up" data-delay="200">
      <form id="contact-form" class="contact-form" novalidate
        data-ejs-key={EMAILJS_PUBLIC_KEY ?? ''}
        data-ejs-service={EMAILJS_SERVICE_ID ?? ''}
        data-ejs-template={EMAILJS_TEMPLATE_ID ?? ''}
      >
        <input type="text" name="_hp" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden" />
        <div class="form-row">
          <div class="form-group">
            <label for="cf-name">Name</label>
            <input type="text" id="cf-name" name="name" placeholder="Your full name" required autocomplete="name" />
            <span class="form-error" id="err-name"></span>
          </div>
          <div class="form-group">
            <label for="cf-email">Email</label>
            <input type="email" id="cf-email" name="email" placeholder="your@email.com" required autocomplete="email" />
            <span class="form-error" id="err-email"></span>
          </div>
        </div>
        <div class="form-group">
          <label for="cf-subject">Subject</label>
          <input type="text" id="cf-subject" name="subject" placeholder="What is this about?" required />
          <span class="form-error" id="err-subject"></span>
        </div>
        <div class="form-group">
          <label for="cf-message">Message</label>
          <textarea id="cf-message" name="message" rows="5" placeholder="What are you building, and where is it stuck?" required></textarea>
          <span class="form-error" id="err-message"></span>
        </div>
        <button type="submit" id="cf-submit" class="cf-btn">
          <span class="btn-label">Send Message</span>
          <svg class="btn-spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" opacity="0.25"/>
            <path fill="currentColor" opacity="0.75" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
          </svg>
        </button>
        <p class="cf-feedback" id="cf-error" role="alert" aria-live="assertive" style="display:none">
          Something went wrong. Please try again in a moment.
        </p>
        <p class="visually-hidden" id="cf-success-msg" aria-live="polite" aria-atomic="true"></p>
      </form>
    </div>
  </div>

  <footer class="site-footer">
    <div class="footer-brand">
      <span class="footer-logo">LARS ULLRICH</span>
      <p class="footer-desc">Production AI and agents. Built to ship, and to keep running.</p>
    </div>

    <nav class="footer-links" aria-label="Footer navigation">
      {socials.map(s => (
        <a href={s.href} target="_blank" rel="noopener noreferrer">{s.label}</a>
      ))}
      <a href="/de/" hreflang="de">Deutsch</a>
      <a href="/work/patterns/">Patterns</a>
      <a href="/impressum/">Impressum</a>
    </nav>

    <span class="footer-copy">&copy; 2026 Lars Ullrich. All rights reserved.</span>
  </footer>

</section>

<style>
  .contact-section {
    background: #2C303C;
    position: relative;
    overflow: hidden;
  }

  /* Diagonal soft-light gradient overlay */
  .contact-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(35, 31, 32, 0.35) 0%,
      rgba(255, 255, 255, 0.10) 100%
    );
    mix-blend-mode: soft-light;
    pointer-events: none;
    z-index: 0;
  }

  .contact-section > * { position: relative; z-index: 1; }

  /* ── Main layout ── */
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3.5rem);
    border-bottom: 1px dotted rgba(255,255,255,0.15);
    align-items: start;
  }

  /* ── Left column ── */
  .contact-display {
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.0;
    color: #ffffff;
    text-transform: uppercase;
    margin-bottom: 1.75rem;
    text-wrap: balance;
  }

  .contact-intro {
    font-size: var(--text-body-size, 1rem);
    font-weight: 400;
    line-height: var(--text-body-lh, 1.875);
    color: rgba(255,255,255,0.7);
    max-width: 44ch;
    margin-bottom: 2rem;
  }

  .contact-note {
    font-size: var(--text-note-size, 0.875rem);
    font-weight: 400;
    line-height: var(--text-note-lh, 1.8);
    color: rgba(255,255,255,0.5);
    max-width: 42ch;
  }

  .contact-note a {
    color: var(--cobalt, #bbdd00);
    text-decoration: none;
  }

  .contact-note a:hover {
    text-decoration: underline;
  }

  /* ── Form ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .form-group label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
  }

  .form-group input,
  .form-group textarea {
    font-size: 0.9rem;
    font-weight: 400;
    color: #ffffff;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.18);
    padding: 0.7rem 0.9rem;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    resize: none;
    font-family: inherit;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(255,255,255,0.3);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: #bbdd00;
    background: rgba(255,255,255,0.12);
  }

  .form-group input.is-invalid,
  .form-group textarea.is-invalid { border-color: oklch(55% 0.2 25); }

  .form-error {
    font-size: 0.62rem;
    color: oklch(50% 0.2 25);
    min-height: 1em;
  }

  /* ── Submit button ── */
  .cf-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: inherit;
    font-weight: 700;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink, #2C303C);
    background: var(--cobalt, #bbdd00);
    border: 1px solid var(--cobalt, #bbdd00);
    padding: 0.9rem 2rem;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    align-self: flex-start;
  }
  .cf-btn:hover:not(:disabled) {
    background: var(--cobalt-dim, #8aaa00);
    border-color: var(--cobalt-dim, #8aaa00);
  }
  .cf-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .cf-btn.is-success { background: oklch(55% 0.15 145); border-color: oklch(55% 0.15 145); }
  .cf-btn.is-error   { background: oklch(55% 0.2 25); border-color: oklch(55% 0.2 25); }

  .btn-spinner {
    display: none;
    width: 1rem;
    height: 1rem;
    animation: spin 0.8s linear infinite;
  }
  .cf-btn.is-loading .btn-spinner { display: block; }
  .cf-btn.is-loading .btn-label { opacity: 0.6; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .cf-feedback {
    font-size: 0.75rem;
    color: oklch(50% 0.2 25);
  }
  .cf-feedback a { color: inherit; }

  /* ── Footer — green ── */
  .site-footer {
    padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 4vw, 3.5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    background: #bbdd00;
    border-top: none;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .footer-logo {
    font-weight: 800;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    color: var(--ink, #2C303C);
  }

  .footer-desc {
    font-size: 0.68rem;
    font-weight: 400;
    color: oklch(28% 0.010 258);
    line-height: 1.6;
  }

  .footer-links {
    display: flex;
    gap: 1.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer-links a {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: oklch(22% 0.01 258);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--ink, #2C303C); }

  .footer-copy {
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: oklch(30% 0.008 258);
    white-space: nowrap;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .contact-inner { grid-template-columns: 1fr; }
    .site-footer { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
  }
  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
    .cf-btn { align-self: stretch; }
    .footer-links { gap: 1.25rem; }
  }
</style>

<script>
  import emailjs from '@emailjs/browser';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const { ejsKey, ejsService, ejsTemplate } = (form as any).dataset;
  emailjs.init(ejsKey);

  const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement;
  const btnLabel = submitBtn.querySelector('.btn-label') as HTMLElement;
  const errorBox = document.getElementById('cf-error') as HTMLElement;

  function setError(fieldId: string, errId: string, msg: string) {
    const el  = document.getElementById(fieldId) as HTMLElement;
    const err = document.getElementById(errId)   as HTMLElement;
    if (msg) { el.classList.add('is-invalid'); err.textContent = msg; }
    else      { el.classList.remove('is-invalid'); err.textContent = ''; }
  }

  function validate(data: Record<string,string>) {
    let ok = true;
    if (!data.name.trim())    { setError('cf-name','err-name','Name is required'); ok=false; }
    else setError('cf-name','err-name','');
    if (!data.email.trim())   { setError('cf-email','err-email','Email is required'); ok=false; }
    else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) { setError('cf-email','err-email','Please enter a valid email'); ok=false; }
    else setError('cf-email','err-email','');
    if (!data.subject.trim()) { setError('cf-subject','err-subject','Subject is required'); ok=false; }
    else setError('cf-subject','err-subject','');
    if (!data.message.trim()) { setError('cf-message','err-message','Message is required'); ok=false; }
    else if (data.message.length < 10) { setError('cf-message','err-message','At least 10 characters'); ok=false; }
    else setError('cf-message','err-message','');
    return ok;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    // Honeypot check — bots fill hidden fields, humans don't
    const hp = (form.querySelector('[name="_hp"]') as HTMLInputElement)?.value;
    if (hp) return;
    const data = {
      name:    (document.getElementById('cf-name')    as HTMLInputElement).value,
      email:   (document.getElementById('cf-email')   as HTMLInputElement).value,
      subject: (document.getElementById('cf-subject') as HTMLInputElement).value,
      message: (document.getElementById('cf-message') as HTMLTextAreaElement).value,
    };
    if (!validate(data)) return;

    submitBtn.disabled = true;
    submitBtn.classList.add('is-loading');
    btnLabel.textContent = 'Sending...';
    errorBox.style.display = 'none';

    try {
      const res = await emailjs.send(ejsService, ejsTemplate, {
        to_name:    'Lars Ullrich',
        from_name:  data.name,
        from_email: data.email,
        message:    `Subject: ${data.subject}\n\n${data.message}`,
        to_email:   'contact@larsullrich.de',
      });
      if (res.status === 200) {
        submitBtn.classList.remove('is-loading');
        submitBtn.classList.add('is-success');
        btnLabel.textContent = 'Message Sent';
        form.reset();
        (document.getElementById('cf-success-msg') as HTMLElement).textContent = 'Your message was sent successfully.';
        setTimeout(() => {
          submitBtn.classList.remove('is-success');
          btnLabel.textContent = 'Send Message';
          submitBtn.disabled = false;
        }, 3000);
      } else { throw new Error(); }
    } catch {
      submitBtn.classList.remove('is-loading');
      submitBtn.classList.add('is-error');
      btnLabel.textContent = 'Try Again';
      errorBox.style.display = 'block';
      submitBtn.disabled = false;
      setTimeout(() => {
        submitBtn.classList.remove('is-error');
        btnLabel.textContent = 'Send Message';
      }, 5000);
    }
  });
</script>
