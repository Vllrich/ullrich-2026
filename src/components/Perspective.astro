---
const scorecard = [
  { dim: 'Problem framing',      weight: '35%', score: 7.4 },
  { dim: 'Stack & architecture', weight: '30%', score: 5.8 },
  { dim: 'Production readiness', weight: '25%', score: 4.2 },
  { dim: 'Governance',           weight: '10%', score: 3.1 },
];

const items = [
  {
    code: 'Tune in',
    body: 'Understand the real problem, the data, and the constraints before touching a model. Most AI failures are framing failures.',
  },
  {
    code: 'Compose the architecture',
    body: "Choose the right tools — often RAG and agents over custom models — and design for reliability, cost, and the team that inherits it.",
  },
  {
    code: 'Ship and harden',
    body: "Get it live, then make it dependable: monitoring, guardrails, human-in-the-loop, and clear ownership.",
  },
  {
    code: 'Adopt responsibly',
    body: "Governance that fits your size — data protection, EU AI Act readiness, and transparent decisions, without slowing you down.",
  },
];
---

<section id="perspective" class="method-section">

  <div class="method-header fade-up" data-delay="0">
    <p class="method-lead">
      Signal to system -<br/>
      a calm path from idea<br/>
      to production.
    </p>
    <div class="method-meta">
      <p class="method-sub">The same discipline I learned where there was no second take.</p>
    </div>
  </div>

  <ol class="method-list">
    {items.map((item, i) => (
      <li class="method-item fade-up" data-delay={String(80 + i * 60)}>
        <span class="method-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
        <div class="method-content">
          <h3 class="method-code">{item.code}</h3>
          <p class="method-body">{item.body}</p>
        </div>
      </li>
    ))}
  </ol>

  <div class="sc-wrap fade-up" data-delay="300">
    <p class="sc-context">Where clients typically score on first engagement — four dimensions that account for nearly every production AI failure.</p>
    <div class="sc-row">
      {scorecard.map((s, i) => (
        <div class="sc-col" style={`flex: ${parseInt(s.weight)}`}>
          <span class="sc-dim">{s.dim}</span>
          <span class="sc-weight">{s.weight}</span>
          <div class="sc-bar-wrap">
            <div class="sc-bar-fill" style={`--fill: ${(s.score / 10 * 100).toFixed(1)}%`}></div>
          </div>
          <span class="sc-score">{s.score.toFixed(2)}<span class="sc-denom"> / 10</span></span>
        </div>
      ))}
    </div>
  </div>

  <div class="method-statement fade-up" data-delay="440">
    <p>The stages got smaller.<br/>
    <strong>The systems got larger.<br/>The instinct stayed the same.</strong></p>
  </div>

</section>

<style>
  .method-section {
    background: var(--surface, oklch(96.5% 0.003 260));
    color: var(--ink, oklch(10% 0.012 258));
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3.5rem);
    border-bottom: 1px solid var(--rule, oklch(87% 0.005 260));
  }

  /* ── Header ── */
  .method-header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem 4rem;
    align-items: end;
    margin-bottom: clamp(3rem, 6vw, 5rem);
    border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
    padding-bottom: clamp(2.5rem, 4vw, 3.5rem);
  }

  .method-lead {
    font-size: clamp(2.4rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: var(--ink, oklch(10% 0.012 258));
    text-transform: uppercase;
    text-wrap: balance;
  }

  .method-meta {
    text-align: right;
    max-width: 28ch;
    align-self: flex-end;
  }

  .method-sub {
    font-size: var(--text-note-size, 0.875rem);
    font-weight: 400;
    line-height: var(--text-note-lh, 1.8);
    color: var(--dim, oklch(28% 0.010 258));
  }

  /* ── Numbered list ── */
  .method-list {
    list-style: none;
    border-top: 1px dotted var(--rule, oklch(87% 0.005 260));
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .method-item {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 0 2rem;
    padding: clamp(1.75rem, 3vw, 2.5rem) 0;
    border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
    align-items: baseline;
  }

  .method-num {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--cobalt, oklch(52% 0.22 265));
    font-variant-numeric: tabular-nums;
    padding-top: 0.3rem;
  }

  .method-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 3rem;
    align-items: baseline;
  }

  .method-code {
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--ink, oklch(10% 0.012 258));
  }

  .method-body {
    font-size: var(--text-body-size, 1rem);
    font-weight: 400;
    line-height: var(--text-body-lh, 1.875);
    color: var(--dim, oklch(28% 0.010 258));
  }

  /* ── Closing statement ── */
  .method-statement {
    border-top: 1px dotted var(--rule, oklch(87% 0.005 260));
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .method-statement p {
    font-size: clamp(1.4rem, 3.5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--ghost, oklch(50% 0.006 260));
    text-transform: uppercase;
  }

  .method-statement strong {
    color: var(--ink, oklch(10% 0.012 258));
    font-weight: 800;
  }

  /* ── Scorecard ── */
  .sc-wrap {
    border-top: 1px dotted var(--rule, oklch(87% 0.005 260));
    padding-top: clamp(2rem, 4vw, 3rem);
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .sc-context {
    font-size: 0.78rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--ghost, oklch(50% 0.006 260));
    max-width: 62ch;
    margin-bottom: 1.75rem;
  }

  /* ── Scorecard columns ── */
  .sc-row {
    display: flex;
  }

  .sc-col {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.9rem 0 0.75rem 0;
    border-left: 1px dotted oklch(45% 0.006 260 / 35%);
    border-right: 1px dotted oklch(45% 0.006 260 / 35%);
    min-width: 0;
  }
  /* Collapse adjacent right+left borders into one */
  .sc-col:not(:first-child) { border-left: none; }

  .sc-dim,
  .sc-weight,
  .sc-score {
    padding-left: 1rem;
    padding-right: 1rem;
  }
  .sc-col:first-child .sc-dim,
  .sc-col:first-child .sc-weight,
  .sc-col:first-child .sc-score { padding-left: 0.75rem; }
  .sc-col:last-child .sc-dim,
  .sc-col:last-child .sc-weight,
  .sc-col:last-child .sc-score  { padding-right: 0.75rem; }

  .sc-dim {
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--dim, oklch(28% 0.010 258));
    line-height: 1.3;
  }

  .sc-weight {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--ink, oklch(10% 0.012 258));
    margin-bottom: 0.15rem;
  }

  /* Bar spans full column width — no horizontal padding */
  .sc-bar-wrap {
    height: 44px;
    background: oklch(10% 0.012 258 / 4%);
    overflow: hidden;
  }

  .sc-bar-fill {
    height: 100%;
    width: var(--fill, 50%);
    background: oklch(10% 0.012 258 / 12%);
    transition: width 1.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  html.js-ready .sc-bar-fill { width: 0; }
  html.js-ready .sc-wrap.in .sc-bar-fill { width: var(--fill); }

  .sc-col:nth-child(1) .sc-bar-fill { transition-delay:   0ms; }
  .sc-col:nth-child(2) .sc-bar-fill { transition-delay: 110ms; }
  .sc-col:nth-child(3) .sc-bar-fill { transition-delay: 220ms; }
  .sc-col:nth-child(4) .sc-bar-fill { transition-delay: 330ms; }

  @media (prefers-reduced-motion: reduce) {
    .sc-bar-fill { transition: none; }
    html.js-ready .sc-bar-fill { width: var(--fill); }
  }

  .sc-score {
    font-size: clamp(0.9rem, 1.6vw, 1.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink, oklch(10% 0.012 258));
    font-variant-numeric: tabular-nums;
    line-height: 1;
    font-family: var(--font-display);
  }

  .sc-denom {
    font-size: 0.8em;
    font-weight: 400;
    color: var(--ghost, oklch(50% 0.006 260));
    letter-spacing: 0;
  }

  @media (max-width: 900px) {
    .method-content { grid-template-columns: 1fr; gap: 0.75rem; }
    .sc-row { flex-wrap: wrap; }
    .sc-col { flex: 1 1 40% !important; }
    .sc-col:nth-child(2) { border-right: none; }
    .sc-col:nth-child(3) { padding-left: 0; }
  }

  @media (max-width: 760px) {
    .method-header { grid-template-columns: 1fr; }
    .method-meta { text-align: left; }
    .method-item { grid-template-columns: 2.5rem 1fr; gap: 0 1rem; }
    .sc-row { flex-wrap: wrap; }
    .sc-col { flex: 1 1 40% !important; }
  }

  @media (max-width: 480px) {
    .sc-row { flex-direction: column; }
    .sc-col { border-right: none; border-bottom: 1px dotted oklch(45% 0.006 260); padding: 0.75rem 0; }
    .sc-col:last-child { border-bottom: none; }
    .sc-col:not(:first-child) { padding-left: 0; }
  }
</style>
