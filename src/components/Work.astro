---
const projects = [
  { title: 'MIRAI / Micropsi Industries', desc: 'ML backbone for industrial robots - GPU-optimized pipelines and real-time control where downtime is not an option.', cat: 'Robotics AI · Systems Eng.', year: '2023' },
  { title: 'CORPUS',                      desc: 'AI platform for real-time, context-aware music with transparent artist attribution. Architecture, infrastructure, delivery.', cat: 'AI Platform · CTO', year: '2021–22' },
  { title: 'The Sound of Porsche',         desc: 'Real-time audio systems for global brand installations - built to run unattended, night after night.', cat: 'Brand Audio · Lead Tech', year: '2019' },
  { title: 'ECM / Flow',                  desc: 'Audiovisual installation for ECM Records - 20 works rendered and animated live from the catalogue.', cat: 'Installation · Architect', year: '2018' },
  { title: 'Einstein on the Beach',        desc: 'Real-time video and interaction design for the Glass / Wilson opera at Oper Dortmund.', cat: 'Opera · Creative Dev', year: '2017' },
  { title: 'Hemispheres',                 desc: 'Generative audiovisual installation exploring synchronization - art as a stress test for real-time systems.', cat: 'Installation · Visual Dev', year: '2016' },
];
---

<section id="work" class="work-section">
  <div class="work-header">
    <h2 class="work-display fade-up" data-delay="0">Selected Work</h2>
    <p class="work-intro fade-up" data-delay="60">
      A few systems that had to work in the real world - on stage, on the factory floor, and in production.
    </p>
  </div>

  <ol class="tracklist">
    {projects.map((p, i) => (
      <li>
        <div class="track fade-up" data-delay={String(100 + i * 55)}>
          <span class="track-title">{p.title}</span>
          <div class="track-right">
            <span class="track-desc">{p.desc}</span>
            <span class="track-cat">{p.cat}</span>
            <span class="track-year">{p.year}</span>
          </div>
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  .work-section {
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3.5rem);
    background: var(--color-bg, oklch(97.5% 0 0));
    border-top: 1px solid var(--color-rule, oklch(84% 0.005 255));
  }

  .work-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0 4rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    align-items: baseline;
  }

  .work-display {
    font-size: clamp(1.8rem, 4vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-ink, oklch(11% 0.015 255));
    text-transform: uppercase;
    white-space: nowrap;
  }

  .work-intro {
    font-size: 0.88rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-dim, oklch(42% 0.012 255));
    max-width: 54ch;
    padding-top: 0.3rem;
  }

  /* ── Track list ── */
  .tracklist {
    list-style: none;
    border-top: 2px solid var(--color-ink, oklch(11% 0.015 255));
  }

  .track {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--color-rule, oklch(84% 0.005 255));
    gap: 2rem;
    transition: border-bottom-color 0.3s;
  }
  .track:hover { border-bottom-color: var(--color-dim, oklch(42% 0.012 255)); }
  .track:hover .track-title { color: var(--color-dim, oklch(42% 0.012 255)); }

  .track-title {
    font-size: clamp(1rem, 2.2vw, 1.75rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-ink, oklch(11% 0.015 255));
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.3s;
  }

  .track-right {
    display: flex;
    align-items: baseline;
    gap: 2rem;
    flex-shrink: 1;
    min-width: 0;
  }

  .track-desc {
    font-size: 0.72rem;
    font-weight: 300;
    color: var(--color-dim, oklch(42% 0.012 255));
    line-height: 1.6;
    flex: 1;
    min-width: 0;
  }

  .track-cat {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ghost, oklch(60% 0.007 255));
    white-space: nowrap;
    flex-shrink: 0;
  }

  .track-year {
    font-size: 0.65rem;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--color-ghost, oklch(60% 0.007 255));
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 3rem;
    text-align: right;
  }

  @media (max-width: 900px) {
    .work-header { grid-template-columns: 1fr; gap: 1rem; }
    .track-cat, .track-year { display: none; }
    .track-title { white-space: normal; }
  }
  @media (max-width: 640px) {
    .track-right { display: none; }
    .track-title { font-size: clamp(1rem, 5vw, 1.5rem); }
  }
</style>
