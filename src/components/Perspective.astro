---
const scorecard = [
  { dim: 'Problem framing',      status: 'Usually solid',          note: 'the team knows the problem' },
  { dim: 'Stack & architecture', status: 'Mixed',                  note: 'works in the demo, untested under load' },
  { dim: 'Production readiness', status: 'Usually the weak point', note: 'no evals, no monitoring, no guardrails' },
  { dim: 'Governance',           status: 'Rarely addressed yet',   note: '' },
];

const items = [
  {
    code: 'Tune in',
    body: 'Understand the real problem, the data, and the constraints before touching a model. Most AI failures are framing failures.',
  },
  {
    code: 'Compose the architecture',
    body: 'Choose the right tools, often agents and RAG over a custom model. Design for reliability, cost, and the team that inherits it.',
  },
  {
    code: 'Ship and harden',
    body: 'Get it live, then make it dependable: evals, monitoring, guardrails, and clear ownership.',
  },
  {
    code: 'Adopt responsibly',
    body: 'Governance sized to your company: data protection, EU AI Act readiness, decisions you can explain.',
  },
];
---

<section id="method" class="method-section">

  <div class="method-header fade-up" data-delay="0">
    <h2 class="method-lead">
      From signal<br/>
      to system.
    </h2>
    <div class="method-meta">
      <p class="method-sub">From a demo that works to an agent you can leave running.</p>
    </div>
  </div>

  <ol class="method-list">
    {items.map((item, i) => (
      <li class="method-item fade-up" data-delay={String(80 + i * 60)}>
        <span class="method-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
        <div class="method-content">
          <h3 class="method-code">{item.code}</h3>
          <p class="method-body">{item.body}</p>
        </div>
      </li>
    ))}
  </ol>

  <div class="sc-wrap fade-up" data-delay="300">
    <h3 class="sc-title">Where teams usually start</h3>
    <p class="sc-context">The four dimensions where production AI breaks, and where teams usually stand at the first engagement. Strong on framing, thin on what it takes to run.</p>
    <div class="sc-row">
      {scorecard.map((s) => (
        <div class="sc-col">
          <span class="sc-dim">{s.dim}</span>
          <span class="sc-status">{s.status}</span>
          {s.note && <span class="sc-note">{s.note}</span>}
        </div>
      ))}
    </div>
  </div>

  <div class="method-statement fade-up" data-delay="440">
    <p>The stages got smaller.<br/>
    <strong>The systems got larger.<br/>The discipline carried over.</strong></p>
  </div>

</section>

<style>
  .method-section {
    background: var(--surface, oklch(96.5% 0.003 260));
    color: var(--ink, oklch(10% 0.012 258));
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3.5rem);
    border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
  }

  /* ── Header ── */
  .method-header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem 4rem;
    align-items: end;
    margin-bottom: clamp(3rem, 6vw, 5rem);
    border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
    padding-bottom: clamp(2.5rem, 4vw, 3.5rem);
  }

  .method-lead {
    font-size: clamp(2.4rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: var(--ink, oklch(10% 0.012 258));
    text-transform: uppercase;
    text-wrap: balance;
    margin: 0;
  }

  .method-meta {
    text-align: right;
    max-width: 28ch;
    align-self: flex-end;
  }

  .method-sub {
    font-size: var(--text-note-size, 0.875rem);
    font-weight: 400;
    line-height: var(--text-note-lh, 1.8);
    color: var(--dim, oklch(28% 0.010 258));
  }

  /* ── Numbered list ── */
  .method-list {
    list-style: none;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .method-item {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 0 2rem;
    padding: clamp(1.75rem, 3vw, 2.5rem) 0;
    border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
    align-items: baseline;
  }

  .method-item:last-child {
    border-bottom: none;
  }

  .method-num {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--cobalt, oklch(52% 0.22 265));
    font-variant-numeric: tabular-nums;
    padding-top: 0.3rem;
  }

  .method-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 3rem;
    align-items: baseline;
  }

  .method-code {
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--ink, oklch(10% 0.012 258));
  }

  .method-body {
    font-size: var(--text-body-size, 1rem);
    font-weight: 400;
    line-height: var(--text-body-lh, 1.875);
    color: var(--dim, oklch(28% 0.010 258));
  }

  /* ── Closing statement ── */
  .method-statement {
    border-top: 1px dotted var(--rule, oklch(87% 0.005 260));
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .method-statement p {
    font-size: clamp(1.4rem, 3.5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--ghost, oklch(50% 0.006 260));
    text-transform: uppercase;
  }

  .method-statement strong {
    color: var(--ink, oklch(10% 0.012 258));
    font-weight: 800;
  }

  /* ── Scorecard ── */
  .sc-wrap {
    padding-top: clamp(2rem, 4vw, 3rem);
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .sc-title {
    font-size: 0.58rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ghost, oklch(50% 0.006 260));
    margin-bottom: 0.75rem;
  }

  .sc-context {
    font-size: 0.78rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--ghost, oklch(50% 0.006 260));
    max-width: 62ch;
    margin-bottom: 1.75rem;
  }

  /* ── Scorecard columns ── */
  .sc-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px dotted var(--rule, oklch(87% 0.005 260));
  }

  .sc-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.25rem 1.25rem 0;
    border-right: 1px dotted var(--rule, oklch(87% 0.005 260));
    min-width: 0;
  }
  .sc-col:last-child { border-right: none; }

  .sc-dim {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ghost, oklch(50% 0.006 260));
    line-height: 1.3;
  }

  .sc-status {
    font-size: clamp(0.85rem, 1.4vw, 1.05rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--ink, oklch(10% 0.012 258));
    line-height: 1.2;
  }

  .sc-note {
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--dim, oklch(28% 0.010 258));
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .method-content { grid-template-columns: 1fr; gap: 0.75rem; }
    .sc-row { grid-template-columns: 1fr 1fr; }
    .sc-col:nth-child(2) { border-right: none; padding-right: 0; }
    .sc-col:nth-child(3) { border-top: 1px dotted var(--rule, oklch(87% 0.005 260)); }
    .sc-col:nth-child(4) { border-right: none; border-top: 1px dotted var(--rule, oklch(87% 0.005 260)); padding-right: 0; }
  }

  @media (max-width: 760px) {
    .method-header { grid-template-columns: 1fr; }
    .method-meta { text-align: left; }
    .method-item { grid-template-columns: 2.5rem 1fr; gap: 0 1rem; }
  }

  @media (max-width: 480px) {
    .sc-row { grid-template-columns: 1fr; }
    .sc-col { border-right: none; border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260)); padding: 1rem 0; }
    .sc-col:last-child { border-bottom: none; }
    .sc-col:nth-child(2),
    .sc-col:nth-child(3),
    .sc-col:nth-child(4) { border-top: none; }
  }
</style>
