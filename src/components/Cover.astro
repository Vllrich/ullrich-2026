---
---

<div class="site-wrap">

  <header class="site-nav">
    <a href="#" class="nav-logo">
      LARS ULLRICH
      <span class="nav-descriptor">Agent reliability &middot; Full-Stack Engineer &amp; Fractional CTO</span>
    </a>
    <nav class="nav-links" id="nav-links" aria-label="Main navigation">
      <a href="#what-i-do">What I Do</a>
      <a href="#method">Method</a>
      <a href="#services">Services</a>
      <a href="#about">About</a>
      <a href="#contact">Contact</a>
    </nav>
    <button
      class="nav-toggle"
      id="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-links"
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </header>

  <section class="hero" aria-label="Hero">
    <!-- WebGL canvases — hidden, preserved for re-enable -->
    <canvas id="fluid-canvas" aria-hidden="true"></canvas>
    <canvas id="ascii-canvas" aria-hidden="true"></canvas>

    <!-- Left: text content -->
    <div class="hero-text">
      <h1 class="hero-heading">
        Anyone can build a demo<br/>
        <span class="hero-heading-alt">Running it is the job</span>
      </h1>
      <p class="hero-body">
        I help startups and growing companies ship software that holds up in production, and keep it running. AI included, when it earns its place
      </p>
      <div class="hero-ctas">
        <a href="#contact" class="hero-cta-primary">Start a conversation</a>
        <a href="#method" class="hero-cta-secondary">See how I work</a>
      </div>
    </div>

    <!-- Right: grid animation + shader controls -->
    <div class="hero-graphic" aria-hidden="true">
      <canvas id="bauhaus-canvas"></canvas>
      <!-- Word labels — positioned by JS each frame -->
      <div id="grid-labels" class="grid-labels"></div>
    </div>
  </section>

</div>

<style>
  .site-wrap { background: #ffffff; }

  /* ── Navigation ── */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 3.5rem;
    background: #bbdd00;
    border-bottom: 1px solid transparent;
    transition: background 0.28s ease, border-color 0.28s ease;
  }

  .site-nav.is-scrolled {
    background: oklch(99% 0 0 / 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--rule, oklch(87% 0.005 260));
  }

  .nav-logo {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink, #2C303C);
    font-family: var(--font-sans, "Darker Grotesque", system-ui, sans-serif);
    line-height: 1.1;
  }

  .nav-descriptor {
    font-weight: 400;
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: oklch(30% 0.008 258);
    font-family: var(--font-sans, "Darker Grotesque", system-ui, sans-serif);
    display: block;
    line-height: 1;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-sans, "Darker Grotesque", system-ui, sans-serif);
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dim, oklch(28% 0.010 258));
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--ink, #2C303C); }

  /* ── Hero: white, 1280×960, split left/right ── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 960px;
    background: #bbdd00;
    overflow: hidden;
    margin-top: -2rem; /* nav bar is same lime color — shift up so content sits at optical midpoint of nav+hero combined */
  }

  #fluid-canvas,
  #ascii-canvas { display: none; }

  /* Left: text column — vertically centered */
  .hero-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    padding: clamp(3rem, 5vw, 5rem) clamp(2.5rem, 5vw, 4.5rem);
  }

  .hero-heading {
    font-family: var(--font-display, "Darker Grotesque", system-ui, sans-serif);
    font-size: clamp(2.8rem, 5vw, 5.5rem);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--ink, #2C303C);
    text-transform: uppercase;
    text-wrap: balance;
  }

  .hero-body {
    font-size: var(--text-body-size, 1rem);
    font-weight: 400;
    line-height: var(--text-body-lh, 1.875);
    color: var(--dim, oklch(28% 0.010 258));
    max-width: 42ch;
  }

  .hero-heading-alt {
    color: var(--white, #fafafa);
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero-cta-primary {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--white, #fafafa);
    background: var(--ink, #2C303C);
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .hero-cta-primary:hover { background: oklch(22% 0.01 258); }

  .hero-cta-secondary {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink, #2C303C);
    background: transparent;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--ink, #2C303C);
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .hero-cta-secondary:hover { opacity: 0.55; }

  /* Services list below CTA */
  .hero-services {
    list-style: none;
    padding: 0;
    margin-top: 0.25rem;
  }

  .hero-services li {
    font-family: var(--font-sans, "Darker Grotesque", system-ui, sans-serif);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ghost, oklch(50% 0.006 260));
    padding: 0.55rem 0;
    border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
    line-height: 1;
  }
  .hero-services li:first-child { border-top: 1px dotted var(--rule, oklch(87% 0.005 260)); }

  /* Right: grid animation panel */
  .hero-graphic {
    display: flex;
    align-items: stretch;
    justify-content: flex-end;
    overflow: hidden;
    padding: 80px 0;
    background: #bbdd00;
    position: relative; /* anchor for the param panel */
    align-self: stretch; /* fill the full hero row height */
  }

  /* ── Word label overlay ─────────────────────────────────────── */
  .grid-labels {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 5; /* above the canvas (z-index:1), below the param panel (20) */
  }
  /* :global — these spans are created in JS via createElement, so they
     don't carry Astro's scoped data-attribute. Without :global the scoped
     selector wouldn't match them and position:absolute would be dropped. */
  :global(.grid-label) {
    position: absolute;
    color: #2C303C; /* site ink — readable against the lime bloom */
    font-family: var(--font-sans, "Hanken Grotesk", system-ui, sans-serif);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
    white-space: nowrap;
    transform: translate(-50%, -50%);
    user-select: none;
    pointer-events: none;
  }

  #bauhaus-canvas {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 1; /* keep below the word-label overlay */
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero-text {
      padding: clamp(5rem, 12vw, 7rem) 1.5rem 2rem;
    }
    .hero-heading { font-size: clamp(2rem, 7vw, 3.5rem); }
    .hero-graphic {
      height: 80vw;
    }
  }

  @media (max-width: 760px) {
    .site-nav { padding: 1.1rem 1.5rem; }
    .nav-links { gap: 1.25rem; }
    .nav-descriptor { display: none; }
  }

  /* ── Hamburger toggle button ── */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-right: -0.5rem;
  }

  .nav-toggle-bar {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ink, #2C303C);
    transition: transform 0.2s, opacity 0.2s;
    transform-origin: center;
  }

  .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  @media (max-width: 500px) {
    .site-nav {
      flex-wrap: wrap;
      align-items: center;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      width: 100%;
      flex-direction: column;
      gap: 0;
      border-top: 1px dotted var(--rule, oklch(87% 0.005 260));
      padding: 0.5rem 0 0.75rem;
    }

    .nav-links.is-open {
      display: flex;
    }

    .nav-links a {
      font-size: 0.78rem;
      letter-spacing: 0.06em;
      padding: 0.6rem 0;
      border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
    }

    .nav-links a:last-child {
      border-bottom: none;
    }

    .hero-heading { font-size: clamp(2rem, 9vw, 3rem); }
  }
</style>

<script>
/* Set to true to re-enable the fluid/ASCII animation */
const WEBGL_ENABLED = false;

if (WEBGL_ENABLED) {
const canvas = document.getElementById('fluid-canvas') as HTMLCanvasElement;
const ascii  = document.getElementById('ascii-canvas')  as HTMLCanvasElement;

const gl = canvas.getContext('webgl2', { antialias: false, alpha: false });
if (!gl) { console.warn('no webgl2'); }
else {
gl.getExtension('EXT_color_buffer_float');
gl.getExtension('OES_texture_float_linear');

function compileShader(type: number, src: string) {
  const s = gl.createShader(type)!;
  gl.shaderSource(s, src); gl.compileShader(s);
  if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) console.error(gl.getShaderInfoLog(s));
  return s;
}
function makeProgram(vert: string, frag: string) {
  const p = gl.createProgram()!;
  gl.attachShader(p, compileShader(gl.VERTEX_SHADER, vert));
  gl.attachShader(p, compileShader(gl.FRAGMENT_SHADER, frag));
  gl.linkProgram(p);
  return p;
}
function makeFBO(w: number, h: number) {
  const tex = gl.createTexture()!;
  gl.bindTexture(gl.TEXTURE_2D, tex);
  gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA32F, w, h, 0, gl.RGBA, gl.FLOAT, null);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
  const fb = gl.createFramebuffer()!;
  gl.bindFramebuffer(gl.FRAMEBUFFER, fb);
  gl.framebufferTexture2D(gl.FRAMEBUFFER, gl.COLOR_ATTACHMENT0, gl.TEXTURE_2D, tex, 0);
  gl.bindFramebuffer(gl.FRAMEBUFFER, null);
  return { tex, fb, w, h };
}
function doubleFBO(w: number, h: number) {
  let a = makeFBO(w,h), b = makeFBO(w,h);
  return { read: a, write: b, swap() { [this.read,this.write]=[this.write,this.read]; } };
}

const VERT = `#version 300 es
layout(location=0) in vec2 a_pos;
out vec2 v_uv;
void main(){v_uv=a_pos*.5+.5;gl_Position=vec4(a_pos,0,1);}`;

const ADVECT = `#version 300 es
precision highp float;
in vec2 v_uv;
uniform sampler2D u_vel,u_src;
uniform vec2 u_texel;
uniform float u_dt,u_dissipation;
out vec4 out_color;
void main(){
  vec2 pos=v_uv-u_dt*texture(u_vel,v_uv).xy*u_texel;
  out_color=u_dissipation*texture(u_src,pos);
}`;

const SPLAT = `#version 300 es
precision highp float;
in vec2 v_uv;
uniform sampler2D u_src;
uniform vec2 u_point;
uniform vec3 u_color;
uniform float u_radius;
uniform bool u_isVel;
out vec4 out_color;
void main(){
  float d=length(v_uv-u_point);
  float s=exp(-d*d/u_radius);
  vec4 base=texture(u_src,v_uv);
  if(u_isVel) out_color=base+vec4(u_color.xy*s,0,1);
  else         out_color=base+vec4(u_color*s,1);
}`;

const DIVERGENCE = `#version 300 es
precision highp float;
in vec2 v_uv;
uniform sampler2D u_vel;
uniform vec2 u_texel;
out vec4 out_color;
void main(){
  float L=texture(u_vel,v_uv-vec2(u_texel.x,0)).x;
  float R=texture(u_vel,v_uv+vec2(u_texel.x,0)).x;
  float B=texture(u_vel,v_uv-vec2(0,u_texel.y)).y;
  float T=texture(u_vel,v_uv+vec2(0,u_texel.y)).y;
  out_color=vec4(.5*(R-L+T-B),0,0,1);
}`;

const PRESSURE = `#version 300 es
precision highp float;
in vec2 v_uv;
uniform sampler2D u_pressure,u_div;
uniform vec2 u_texel;
out vec4 out_color;
void main(){
  float L=texture(u_pressure,v_uv-vec2(u_texel.x,0)).x;
  float R=texture(u_pressure,v_uv+vec2(u_texel.x,0)).x;
  float B=texture(u_pressure,v_uv-vec2(0,u_texel.y)).x;
  float T=texture(u_pressure,v_uv+vec2(0,u_texel.y)).x;
  float div=texture(u_div,v_uv).x;
  out_color=vec4((L+R+B+T-div)*.25,0,0,1);
}`;

const GRADIENT = `#version 300 es
precision highp float;
in vec2 v_uv;
uniform sampler2D u_pressure,u_vel;
uniform vec2 u_texel;
out vec4 out_color;
void main(){
  float L=texture(u_pressure,v_uv-vec2(u_texel.x,0)).x;
  float R=texture(u_pressure,v_uv+vec2(u_texel.x,0)).x;
  float B=texture(u_pressure,v_uv-vec2(0,u_texel.y)).x;
  float T=texture(u_pressure,v_uv+vec2(0,u_texel.y)).x;
  vec2 vel=texture(u_vel,v_uv).xy;
  out_color=vec4(vel-vec2(R-L,T-B)*.5,0,1);
}`;

const DISPLAY = `#version 300 es
precision highp float;
in vec2 v_uv;
uniform sampler2D u_dye;
out vec4 out_color;
void main(){
  vec3 dye=clamp(texture(u_dye,v_uv).rgb,0.,1.);
  float lum=dot(dye,vec3(.333));
  /* pure greyscale: white bg → black */
  float g = 1.0 - smoothstep(0.0, 1.0, lum);
  out_color=vec4(vec3(g),1.);
}`;

const SIM=128, DYE=256;
const progs = {
  advect:     makeProgram(VERT,ADVECT),
  splat:      makeProgram(VERT,SPLAT),
  divergence: makeProgram(VERT,DIVERGENCE),
  pressure:   makeProgram(VERT,PRESSURE),
  gradient:   makeProgram(VERT,GRADIENT),
  display:    makeProgram(VERT,DISPLAY),
};

const vao = gl.createVertexArray()!;
gl.bindVertexArray(vao);
const buf = gl.createBuffer();
gl.bindBuffer(gl.ARRAY_BUFFER, buf);
gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1,1,-1,-1,1,1,1]), gl.STATIC_DRAW);
gl.enableVertexAttribArray(0);
gl.vertexAttribPointer(0,2,gl.FLOAT,false,0,0);
gl.bindVertexArray(null);

function bindQuad(prog: WebGLProgram) { gl.useProgram(prog); gl.bindVertexArray(vao); }
function setTex(prog: WebGLProgram, name: string, unit: number, tex: WebGLTexture) {
  gl.activeTexture(gl.TEXTURE0+unit);
  gl.bindTexture(gl.TEXTURE_2D,tex);
  gl.uniform1i(gl.getUniformLocation(prog,name),unit);
}

const vel=doubleFBO(SIM,SIM), dye=doubleFBO(DYE,DYE);
const div=makeFBO(SIM,SIM),   prs=doubleFBO(SIM,SIM);

function runAdvect(src: ReturnType<typeof doubleFBO>, velFBO: ReturnType<typeof doubleFBO>, dt: number, dis: number) {
  const p=progs.advect; bindQuad(p);
  setTex(p,'u_vel',0,velFBO.read.tex);
  setTex(p,'u_src',1,src.read.tex);
  gl.uniform2f(gl.getUniformLocation(p,'u_texel'),1/velFBO.read.w,1/velFBO.read.h);
  gl.uniform1f(gl.getUniformLocation(p,'u_dt'),dt);
  gl.uniform1f(gl.getUniformLocation(p,'u_dissipation'),dis);
  gl.bindFramebuffer(gl.FRAMEBUFFER,src.write.fb);
  gl.viewport(0,0,src.write.w,src.write.h);
  gl.drawArrays(gl.TRIANGLE_STRIP,0,4);
  gl.bindVertexArray(null);
  src.swap();
}

type RGB = [number,number,number];
function splat(x:number,y:number,vx:number,vy:number,color:RGB) {
  const p=progs.splat;
  bindQuad(p); setTex(p,'u_src',0,vel.read.tex);
  gl.uniform2f(gl.getUniformLocation(p,'u_point'),x,y);
  gl.uniform3f(gl.getUniformLocation(p,'u_color'),vx,vy,0);
  gl.uniform1f(gl.getUniformLocation(p,'u_radius'),0.004);
  gl.uniform1i(gl.getUniformLocation(p,'u_isVel'),1);
  gl.bindFramebuffer(gl.FRAMEBUFFER,vel.write.fb);
  gl.viewport(0,0,SIM,SIM); gl.drawArrays(gl.TRIANGLE_STRIP,0,4); gl.bindVertexArray(null); vel.swap();

  bindQuad(p); setTex(p,'u_src',0,dye.read.tex);
  gl.uniform2f(gl.getUniformLocation(p,'u_point'),x,y);
  gl.uniform3f(gl.getUniformLocation(p,'u_color'),...color);
  gl.uniform1f(gl.getUniformLocation(p,'u_radius'),0.012);
  gl.uniform1i(gl.getUniformLocation(p,'u_isVel'),0);
  gl.bindFramebuffer(gl.FRAMEBUFFER,dye.write.fb);
  gl.viewport(0,0,DYE,DYE); gl.drawArrays(gl.TRIANGLE_STRIP,0,4); gl.bindVertexArray(null); dye.swap();
}

const COLORS:RGB[] = [[1,1,1],[.6,.6,.6],[.3,.3,.3]];
const SEED = 24;
for(let i=0;i<SEED;i++){
  const x = (i + 0.5) / SEED;
  const y = 0.15 + Math.random() * 0.7;
  const angle=Math.random()*Math.PI*2, force=150+Math.random()*350;
  splat(x, y, Math.cos(angle)*force, Math.sin(angle)*force, COLORS[i%3]);
}

const ctx2d = ascii.getContext('2d')!;
const CELL  = 11;
const readW = 120, readH = 80;
const off = document.createElement('canvas'); off.width = readW; off.height = readH;
const offCtx = off.getContext('2d')!;
canvas.width = readW; canvas.height = readH;

/* White bg → near-black: pure black-and-white gradient */
const BG_R = 252, BG_G = 252, BG_B = 252;
const HI_R = 12,  HI_G = 12,  HI_B = 12;

/* Binary cell state: each cell persists a 0 or 1 between frames.
   Bits flip randomly at a rate proportional to the local fluid luminance —
   active (bright) regions flicker; calm regions hold steady. */
const MAX_COLS = 240, MAX_ROWS = 140;
const cellBits = new Uint8Array(MAX_COLS * MAX_ROWS);
for (let i = 0; i < cellBits.length; i++) cellBits[i] = Math.random() < 0.5 ? 0 : 1;

/* Luminance threshold below which cells stay blank (clean background). */
const LUM_THRESHOLD = 0.07;
/* Flip probability multiplier: lum * FLIP_RATE = P(bit flips this frame). */
const FLIP_RATE = 0.14;

function drawAscii() {
  const aw = ascii.clientWidth, ah = ascii.clientHeight;
  if (ascii.width !== aw || ascii.height !== ah) { ascii.width = aw; ascii.height = ah; }
  offCtx.drawImage(canvas, 0, 0, readW, readH);
  const px = offCtx.getImageData(0, 0, readW, readH).data;
  const cols = Math.min(Math.floor(aw / CELL), MAX_COLS);
  const rows = Math.min(Math.floor(ah / CELL), MAX_ROWS);
  ctx2d.fillStyle = `rgb(${BG_R},${BG_G},${BG_B})`;
  ctx2d.fillRect(0, 0, aw, ah);
  ctx2d.font = `${CELL}px "Courier New",monospace`;
  ctx2d.textBaseline = 'top';
  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
      const sx = Math.floor((c / cols) * readW);
      const sy = readH - 1 - Math.floor((r / rows) * readH);
      const pi = (sy * readW + sx) * 4;
      const lum = 1 - (0.299 * px[pi] + 0.587 * px[pi + 1] + 0.114 * px[pi + 2]) / 255;
      if (lum < LUM_THRESHOLD) continue;
      /* Stochastically flip the stored bit; rate scales with fluid density */
      const cellIdx = r * MAX_COLS + c;
      if (Math.random() < lum * FLIP_RATE) cellBits[cellIdx] ^= 1;
      const ch = cellBits[cellIdx] ? '1' : '0';
      const ir = Math.round(BG_R + (HI_R - BG_R) * lum);
      const ig = Math.round(BG_G + (HI_G - BG_G) * lum);
      const ib = Math.round(BG_B + (HI_B - BG_B) * lum);
      ctx2d.fillStyle = `rgb(${ir},${ig},${ib})`;
      ctx2d.fillText(ch, c * CELL, r * CELL);
    }
  }
}

let ptr={x:.5,y:.5,dx:0,dy:0,down:false};
const heroEl = ascii.parentElement!;
heroEl.addEventListener('pointermove',e=>{
  const rect=heroEl.getBoundingClientRect();
  const nx=(e.clientX-rect.left)/rect.width;
  const ny=(e.clientY-rect.top)/rect.height;
  ptr.dx=(nx-ptr.x)*5; ptr.dy=(ny-ptr.y)*5;
  ptr.x=nx; ptr.y=ny;
  if(ptr.down) splat(ptr.x,ptr.y,ptr.dx*600,ptr.dy*600,COLORS[Math.floor(Math.random()*3)]);
});
heroEl.addEventListener('pointerdown',e=>{
  ptr.down=true;
  const rect=heroEl.getBoundingClientRect();
  ptr.x=(e.clientX-rect.left)/rect.width;
  ptr.y=(e.clientY-rect.top)/rect.height;
});
heroEl.addEventListener('pointerup',()=>{ptr.down=false;});

const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

if (reducedMotion) {
  /* Static render: one pass, no animation loop */
  { const p=progs.display; bindQuad(p);
    setTex(p,'u_dye',0,dye.read.tex);
    gl.bindFramebuffer(gl.FRAMEBUFFER,null); gl.viewport(0,0,canvas.width,canvas.height);
    gl.drawArrays(gl.TRIANGLE_STRIP,0,4); gl.bindVertexArray(null); }
  drawAscii();
} else {
  let last=0, wanderT=0;
  function frame(t:number){
    requestAnimationFrame(frame);
    const dt=Math.min((t-last)/1000,.033); last=t;
    wanderT+=dt;
    if(wanderT>0.9){
      wanderT=0;
      const angle=Math.random()*Math.PI*2, force=120+Math.random()*280;
      const wx = 0.05 + Math.random()*0.9;
      const wy = 0.1  + Math.random()*0.8;
      splat(wx, wy, Math.cos(angle)*force, Math.sin(angle)*force, COLORS[Math.floor(Math.random()*3)]);
    }
    runAdvect(vel,vel,dt,.98);
    runAdvect(dye,vel,dt,.995);
    { const p=progs.divergence; bindQuad(p); setTex(p,'u_vel',0,vel.read.tex);
      gl.uniform2f(gl.getUniformLocation(p,'u_texel'),1/SIM,1/SIM);
      gl.bindFramebuffer(gl.FRAMEBUFFER,div.fb); gl.viewport(0,0,SIM,SIM);
      gl.drawArrays(gl.TRIANGLE_STRIP,0,4); gl.bindVertexArray(null); }
    for(let i=0;i<20;i++){
      const p=progs.pressure; bindQuad(p);
      setTex(p,'u_pressure',0,prs.read.tex); setTex(p,'u_div',1,div.tex);
      gl.uniform2f(gl.getUniformLocation(p,'u_texel'),1/SIM,1/SIM);
      gl.bindFramebuffer(gl.FRAMEBUFFER,prs.write.fb); gl.viewport(0,0,SIM,SIM);
      gl.drawArrays(gl.TRIANGLE_STRIP,0,4); gl.bindVertexArray(null); prs.swap();
    }
    { const p=progs.gradient; bindQuad(p);
      setTex(p,'u_pressure',0,prs.read.tex); setTex(p,'u_vel',1,vel.read.tex);
      gl.uniform2f(gl.getUniformLocation(p,'u_texel'),1/SIM,1/SIM);
      gl.bindFramebuffer(gl.FRAMEBUFFER,vel.write.fb); gl.viewport(0,0,SIM,SIM);
      gl.drawArrays(gl.TRIANGLE_STRIP,0,4); gl.bindVertexArray(null); vel.swap(); }
    { const p=progs.display; bindQuad(p);
      setTex(p,'u_dye',0,dye.read.tex);
      gl.bindFramebuffer(gl.FRAMEBUFFER,null); gl.viewport(0,0,canvas.width,canvas.height);
      gl.drawArrays(gl.TRIANGLE_STRIP,0,4); gl.bindVertexArray(null); }
    drawAscii();
  }
  requestAnimationFrame(frame);
}
}

} // end WEBGL_ENABLED

/* ── Shared params object — read by shader, written by UI controls ── */
const gridParams = {
  amp:      3.0,  /* pulse amplitude — how much drivers expand  */
  speed:    1.0,  /* playback speed multiplier                  */
  nDrivers: 8,    /* how many of the 8 driver cells are active  */
  gapCSS:   1,    /* gap between cells in CSS pixels            */
  tension:  0.05, /* spring stiffness k — response speed        */
  bounce:   0.40, /* bounciness 0–1: maps to damping 0.97–0.68  */
};

/* ── Grid shader: 16×16 push-layout squares (v3) ── */
(function initGridShader() {
  const canvas = document.getElementById('bauhaus-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const gl = canvas.getContext('webgl2', { antialias: false, alpha: false }) as WebGL2RenderingContext | null;
  if (!gl) { canvas.style.background = '#bbdd00'; return; }

  function mkShader(type: number, src: string): WebGLShader {
    const s = gl!.createShader(type)!;
    gl!.shaderSource(s, src);
    gl!.compileShader(s);
    if (!gl!.getShaderParameter(s, gl!.COMPILE_STATUS))
      console.error('Grid shader:', gl!.getShaderInfoLog(s));
    return s;
  }

  const VERT = `#version 300 es
layout(location=0) in vec2 a_pos;
void main(){gl_Position=vec4(a_pos,0.0,1.0);}`;

  /* ── Fragment shader ────────────────────────────────────────────
     JS computes a proper layout every frame:
       - 16 column widths  (sum = canvas usable width  - 17 px gaps)
       - 16 row heights    (sum = canvas usable height - 17 px gaps)
     Driver cells grow their column AND row; neighbours shrink and
     physically SHIFT so a 1-px gap is always maintained.

     The shader receives cumulative positions + sizes packed into
     two vec4[8] uniforms (32 floats each = 16 vec4 slots total).
     For each fragment it searches column & row linearly (≤ 16 iters
     each) — no overlap is geometrically possible by construction.
     ─────────────────────────────────────────────────────────────── */
  const FRAG = `#version 300 es
precision highp float;
uniform vec2  u_resolution;
uniform float u_unit;     /* base cell size at rest (physical px) */
/* u_cols[0..3] = colX,  u_cols[4..7] = colW   (y-up, grid-local)
   u_rows[0..3] = rowY,  u_rows[4..7] = rowH
   u_colsV[0..3] = colVel[16],  u_rowsV[0..3] = rowVel[16]       */
uniform vec4 u_cols[8];
uniform vec4 u_rows[8];
uniform vec4 u_colsV[4];
uniform vec4 u_rowsV[4];
/* u_drv[i] = (driverCol, driverRow, intensity 0..1, unused) */
uniform vec4 u_drv[8];
uniform int  u_drvN;
out vec4 fragColor;

const vec3 BG = vec3(0.733, 0.867, 0.000); /* lime #bbdd00 */

float cX(int c){ return u_cols[  c >> 2   ][ c & 3 ]; }
float cW(int c){ return u_cols[ (c >> 2)+4 ][ c & 3 ]; }
float rY(int r){ return u_rows[  r >> 2   ][ r & 3 ]; }
float rH(int r){ return u_rows[ (r >> 2)+4 ][ r & 3 ]; }
float cV(int c){ return u_colsV[ c >> 2 ][ c & 3 ]; }
float rV(int r){ return u_rowsV[ r >> 2 ][ r & 3 ]; }

/* 4-stop: near-black → deep forest → mid lime → #bbdd00 → pale */
vec3 cellColor(float t) {
  t = clamp(t, 0.0, 1.0);
  vec3 c0 = vec3(0.173, 0.188, 0.235); /* #2C303C site dark ink   */
  vec3 c1 = vec3(0.150, 0.240, 0.055); /* deep forest green       */
  vec3 c2 = vec3(0.460, 0.650, 0.010); /* mid chartreuse          */
  vec3 c3 = vec3(0.733, 0.867, 0.000); /* #bbdd00 site lime       */
  vec3 c4 = vec3(0.920, 0.960, 0.820); /* pale bloom              */
  if (t < 0.30) return mix(c0, c1, t / 0.30);
  if (t < 0.60) return mix(c1, c2, (t - 0.30) / 0.30);
  if (t < 0.85) return mix(c2, c3, (t - 0.60) / 0.25);
  return         mix(c3, c4, (t - 0.85) / 0.15);
}

void main(){
  vec2 gf = gl_FragCoord.xy;

  int col = -1;
  for(int c = 0; c < 16; c++){
    if(gf.x >= cX(c) && gf.x < cX(c) + cW(c)){ col = c; break; }
  }
  int row = -1;
  for(int r = 0; r < 16; r++){
    if(gf.y >= rY(r) && gf.y < rY(r) + rH(r)){ row = r; break; }
  }

  if(col < 0 || row < 0){ fragColor = vec4(BG, 1.0); return; }

  /* 2D bloom field: colour comes from proximity to the REAL driver cells,
     not from cell size. This avoids the column×row lattice artefact —
     only the actual (random) driver positions light up.                  */
  float fc = float(col);
  float fr = float(row);
  float bloom = 0.0;
  const float sigma = 1.6; /* bloom radius in cells */
  for(int i = 0; i < 8; i++){
    if(i >= u_drvN) break;
    float dc = fc - u_drv[i].x;
    float dr = fr - u_drv[i].y;
    float d2 = dc*dc + dr*dr;
    float b  = u_drv[i].z * exp(-d2 / (2.0 * sigma * sigma));
    bloom = max(bloom, b);
  }

  float t = clamp(0.04 + bloom * 1.05, 0.0, 1.0);
  fragColor = vec4(cellColor(t), 1.0);
}`;

  const prog = gl.createProgram()!;
  gl.attachShader(prog, mkShader(gl.VERTEX_SHADER,   VERT));
  gl.attachShader(prog, mkShader(gl.FRAGMENT_SHADER, FRAG));
  gl.linkProgram(prog);
  if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
    console.error('Grid shader link:', gl.getProgramInfoLog(prog));
    return;
  }

  const vao = gl.createVertexArray()!;
  gl.bindVertexArray(vao);
  const vbuf = gl.createBuffer()!;
  gl.bindBuffer(gl.ARRAY_BUFFER, vbuf);
  gl.bufferData(gl.ARRAY_BUFFER,
    new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
  gl.enableVertexAttribArray(0);
  gl.vertexAttribPointer(0, 2, gl.FLOAT, false, 0, 0);
  gl.bindVertexArray(null);

  const uRes   = gl.getUniformLocation(prog, 'u_resolution');
  const uUnit  = gl.getUniformLocation(prog, 'u_unit');
  const uCols  = gl.getUniformLocation(prog, 'u_cols[0]');
  const uRows  = gl.getUniformLocation(prog, 'u_rows[0]');
  const uColsV = gl.getUniformLocation(prog, 'u_colsV[0]');
  const uRowsV = gl.getUniformLocation(prog, 'u_rowsV[0]');
  const uDrv   = gl.getUniformLocation(prog, 'u_drv[0]');
  const uDrvN  = gl.getUniformLocation(prog, 'u_drvN');

  /* ── Driver config ─────────────────────────────────────────────
     Drivers start spread-out and respawn at a well-spread position
     each time their sine wave starts a fresh positive cycle.
     ─────────────────────────────────────────────────────────────── */
  const ND          = 8;
  const GS          = 16;
  const driverCols: number[] = new Array(ND).fill(0);
  const driverRows: number[] = new Array(ND).fill(0);
  const driverPhase = [0.00, 1.10, 2.30, 4.70, 0.70, 3.10, 5.50, 2.00];
  const driverFreq  = [0.28, 0.41, 0.33, 0.55, 0.22, 0.48, 0.37, 0.63];

  /* Divide the grid into n equal column-zones and n equal row-zones,
     shuffle each list independently, assign one zone per driver.
     Zone width = GS/n so drivers are guaranteed GS/n apart on each axis. */
  function placeDrivers(n: number): void {
    const stride = GS / n;
    const ci = Array.from({ length: n }, (_, i) => i);
    const ri = Array.from({ length: n }, (_, i) => i);
    for (let i = n - 1; i > 0; i--) {
      const jc = Math.floor(Math.random() * (i + 1)); [ci[i], ci[jc]] = [ci[jc], ci[i]];
      const jr = Math.floor(Math.random() * (i + 1)); [ri[i], ri[jr]] = [ri[jr], ri[i]];
    }
    for (let d = 0; d < n; d++) {
      driverCols[d] = Math.floor(ci[d] * stride + Math.random() * stride);
      driverRows[d] = Math.floor(ri[d] * stride + Math.random() * stride);
    }
  }

  /* On respawn: find which column-zone and row-zone are currently free
     (not occupied by any other active driver) and pick within them.     */
  function pickFreeZonePos(self: number, n: number): [number, number] {
    const stride = GS / n;
    const usedC = new Set<number>(), usedR = new Set<number>();
    for (let i = 0; i < n; i++) {
      if (i === self) continue;
      usedC.add(Math.floor(driverCols[i] / stride));
      usedR.add(Math.floor(driverRows[i] / stride));
    }
    const freeC: number[] = [], freeR: number[] = [];
    for (let z = 0; z < n; z++) {
      if (!usedC.has(z)) freeC.push(z);
      if (!usedR.has(z)) freeR.push(z);
    }
    const cz = freeC[Math.floor(Math.random() * freeC.length)] ?? Math.floor(Math.random() * n);
    const rz = freeR[Math.floor(Math.random() * freeR.length)] ?? Math.floor(Math.random() * n);
    return [
      Math.floor(cz * stride + Math.random() * stride),
      Math.floor(rz * stride + Math.random() * stride),
    ];
  }

  placeDrivers(gridParams.nDrivers);

  /* ── Word labels overlaid on the canvas ── */
  /* After Goethe — "The Living Work":
     Who dazzles the crowd with a glittering show / has proved nothing yet of what he can do.
     The work must stand alone when the candles burn low, / when no master's hand remains to see it through.
     Twenty years I have forged and refined, / in tone and light, in the swift rush of code,
     till a new spirit summoned and new work assigned: / the mind of the machine along its weightiest road.
     The agents, those spirits I guide and constrain, / I set their limits, their purpose, their way,
     that their working runs true, not darkened by strain, / and holds what must hold through the long arc of day.
     No counsellor I, who watches from outside. / I write the code. I sit where the work is done.
     I build what will stand when the morning has died, / what runs in the dark long after I am gone. */
  const WORDS = ['Forge', 'Summon', 'Refine', 'Guide', 'Endure', 'Stand', 'Persist', 'Remain'];
  /* Use the sibling #grid-labels div; fall back to canvas parent so we
     always have a real DOM container even if the ID lookup misses.      */
  const labelsEl = document.getElementById('grid-labels') ?? canvas!.parentElement;
  const labelEls: HTMLElement[] = [];
  for (let d = 0; d < ND; d++) {
    const el = document.createElement('span');
    el.className = 'grid-label';
    el.textContent = WORDS[d];
    el.style.opacity = '0';
    labelsEl?.appendChild(el);
    labelEls.push(el);
  }

  const dpulse    = new Float32Array(ND);
  const prevPulse = new Float32Array(ND); /* for zero-crossing detection */
  const colW: number[] = new Array(GS).fill(0);
  const rowH: number[] = new Array(GS).fill(0);
  const colsData = new Float32Array(32); /* 8 vec4s: colX[16] + colW[16] */
  const rowsData = new Float32Array(32); /* 8 vec4s: rowY[16] + rowH[16] */
  const drvData  = new Float32Array(32); /* 8 vec4s: (col, row, intensity, _) */

  /* Spring physics state — per-driver */
  const driverDelta = new Float32Array(ND); /* current spring positions (expansions) */
  const driverDV    = new Float32Array(ND); /* spring velocities                     */

  /* Per-track velocity → colour in GLSL */
  const colV      = new Float32Array(GS);
  const rowV      = new Float32Array(GS);
  const colsVData = new Float32Array(16); /* 4 vec4s: colVel[16] */
  const rowsVData = new Float32Array(16); /* 4 vec4s: rowVel[16] */

  let prevUnit = -1; /* track resize so we can reset springs */
  let rafId = 0;

  /* ── Mouse interaction state ──────────────────────────────────── */
  let dragDriver = -1;               /* driver index being dragged, -1 = none   */
  let didDrag    = false;            /* true once pointer moves after pointerdown */

  interface Ghost { col: number; row: number; born: number; }
  const ghosts: Ghost[] = [];
  const MAX_GHOSTS = 4;
  const GHOST_DUR  = 1.5;           /* seconds a click-push ripple lives         */

  /* Convert pointer event → physical canvas px (y-up, matches shader coords) */
  function canvasPhy(e: PointerEvent): [number, number] {
    const dpr  = Math.min(devicePixelRatio || 1, 2);
    const rect = canvas!.getBoundingClientRect();
    return [
      (e.clientX - rect.left) * dpr,
      canvas!.height - (e.clientY - rect.top) * dpr,
    ];
  }

  /* Map physical px → grid [col, row] using the last-rendered layout arrays */
  function pxToCell(px: number, pyUp: number): [number, number] {
    let col = -1, row = -1;
    for (let c = 0; c < GS; c++)
      if (px  >= colsData[c]      && px  < colsData[c]      + colsData[c      + GS]) { col = c; break; }
    for (let r = 0; r < GS; r++)
      if (pyUp >= rowsData[r]     && pyUp < rowsData[r]     + rowsData[r      + GS]) { row = r; break; }
    return [col, row];
  }

  function resize() {
    const dpr = Math.min(devicePixelRatio || 1, 2);
    const w = Math.round(canvas!.clientWidth  * dpr);
    const h = Math.round(canvas!.clientHeight * dpr);
    if (canvas!.width !== w || canvas!.height !== h) {
      canvas!.width  = w;
      canvas!.height = h;
      gl!.viewport(0, 0, w, h);
    }
  }

  function render(ms: number) {
    resize();
    const time = ms * 0.001;
    const cw   = canvas!.width;
    const ch   = canvas!.height;

    /* Full-rectangle grid — fills the entire canvas */
    const dpr     = Math.min(devicePixelRatio || 1, 2);
    const oxPx    = 0;
    const oyPx    = 0;
    const gap     = Math.max(1, Math.round(gridParams.gapCSS * dpr));
    const availW  = cw - (GS + 1) * gap;
    const availH  = ch - (GS + 1) * gap;
    const avail   = Math.min(availW, availH); /* used for spring target only */
    const unit    = avail / GS;              /* base cell size at rest       */

    /* Reset spring state on canvas resize */
    if (Math.abs(unit - prevUnit) > 0.5) {
      driverDelta.fill(0);
      driverDV.fill(0);
      prevUnit = unit;
    }

    /* 1. Target sine-wave pulses (speed-scaled) */
    const nd = Math.min(ND, gridParams.nDrivers);
    for (let d = 0; d < ND; d++) {
      dpulse[d] = Math.sin(time * driverFreq[d] * gridParams.speed + driverPhase[d]);
    }

    /* Respawn: when a driver's pulse crosses zero going upward (starts a new
       positive cycle) it jumps to a well-spread cell and resets its spring.    */
    for (let d = 0; d < nd; d++) {
      if (d !== dragDriver && prevPulse[d] < 0 && dpulse[d] >= 0) {
        [driverCols[d], driverRows[d]] = pickFreeZonePos(d, nd);
        driverDelta[d] = 0;
        driverDV[d]    = 0;
      }
      prevPulse[d] = dpulse[d];
    }

    /* 2. Spring physics — each driver's expansion springs toward its target.
          k (tension) controls response speed; damp controls overshoot / ring. */
    const springK    = gridParams.tension;
    const springDamp = 0.97 - gridParams.bounce * 0.29; /* bounce 0→1 maps to damp 0.97→0.68 */
    for (let d = 0; d < nd; d++) {
      const target    = dpulse[d] * unit * gridParams.amp;
      driverDV[d]     = (driverDV[d] + (target - driverDelta[d]) * springK) * springDamp;
      driverDelta[d] += driverDV[d];
    }
    /* Inactive drivers spring back to zero */
    for (let d = nd; d < ND; d++) {
      driverDV[d]     = (driverDV[d] - driverDelta[d] * springK) * springDamp;
      driverDelta[d] += driverDV[d];
    }

    /* 3. Layout using spring positions (not raw pulse) */
    for (let i = 0; i < GS; i++) { colW[i] = unit; rowH[i] = unit; }
    for (let d = 0; d < nd; d++) {
      const dc    = driverCols[d];
      const dr    = driverRows[d];
      const delta = driverDelta[d]; /* smoothed by spring */

      colW[dc] += delta;
      const shareW = delta / (GS - 1);
      for (let c = 0; c < GS; c++) if (c !== dc) colW[c] -= shareW;

      rowH[dr] += delta;
      const shareH = delta / (GS - 1);
      for (let r = 0; r < GS; r++) if (r !== dr) rowH[r] -= shareH;
    }

    /* Clamp to 32 CSS-px minimum, then renorm to preserve avail */
    const minCell = Math.round(32 * dpr);
    let tw = 0, th = 0;
    for (let i = 0; i < GS; i++) {
      colW[i] = Math.max(minCell, colW[i]);
      rowH[i] = Math.max(minCell, rowH[i]);
      tw += colW[i]; th += rowH[i];
    }
    for (let i = 0; i < GS; i++) {
      colW[i] = colW[i] * availW / tw;
      rowH[i] = rowH[i] * availH / th;
    }

    /* 4. Per-track velocity (derived from spring velocity, for GLSL colour) */
    colV.fill(0);
    rowV.fill(0);
    for (let d = 0; d < nd; d++) {
      const dc  = driverCols[d];
      const dr  = driverRows[d];
      const vel = driverDV[d];
      colV[dc] += vel;
      const sw = vel / (GS - 1);
      for (let c = 0; c < GS; c++) if (c !== dc) colV[c] -= sw;
      rowV[dr] += vel;
      const sh = vel / (GS - 1);
      for (let r = 0; r < GS; r++) if (r !== dr) rowV[r] -= sh;
    }
    for (let i = 0; i < GS; i++) {
      colsVData[i] = colV[i];
      rowsVData[i] = rowV[i];
    }

    /* 4b. Driver bloom field: position + normalised intensity per driver.
           Intensity is the spring expansion relative to its max, so it
           tracks each driver's pulse independently of the amp setting.   */
    const intScale = unit * gridParams.amp || 1;
    for (let d = 0; d < nd; d++) {
      drvData[d * 4]     = driverCols[d];
      drvData[d * 4 + 1] = driverRows[d];
      drvData[d * 4 + 2] = Math.max(0, Math.min(1, driverDelta[d] / intScale));
      drvData[d * 4 + 3] = 0;
    }

    /* Interaction 2: click-push ghosts — short-lived bloom ripples at clicked cell */
    let totalDrv = nd;
    for (let g = ghosts.length - 1; g >= 0; g--) {
      const ghost = ghosts[g];
      const age   = time - ghost.born;
      if (age > GHOST_DUR) { ghosts.splice(g, 1); continue; }
      if (totalDrv >= 8) break;
      const t         = age / GHOST_DUR;
      const intensity = Math.sin(t * Math.PI);
      drvData[totalDrv * 4]     = ghost.col;
      drvData[totalDrv * 4 + 1] = ghost.row;
      drvData[totalDrv * 4 + 2] = intensity * 0.85;
      drvData[totalDrv * 4 + 3] = 0;
      totalDrv++;
    }

    /* 3. Cumulative positions + pack into uniform float32 buffers.
          colsData layout: [colX × 16, colW × 16] = 32 floats → 8 vec4s
          rowsData layout: [rowY × 16, rowH × 16] (y from grid bottom, y-up)
          All coordinates are grid-local; GLSL subtracts (ox, oy) itself. */
    let cx = gap;    /* first cell starts after the left border gap */
    for (let c = 0; c < GS; c++) {
      colsData[c]      = cx;       /* colX */
      colsData[c + GS] = colW[c];  /* colW */
      cx += colW[c] + gap;
    }

    let ry = gap;    /* first row starts after the bottom border gap */
    for (let r = 0; r < GS; r++) {
      rowsData[r]      = ry;       /* rowY */
      rowsData[r + GS] = rowH[r];  /* rowH */
      ry += rowH[r] + gap;
    }

    /* 5. Upload and draw */
    gl!.useProgram(prog);
    gl!.bindVertexArray(vao);
    gl!.uniform2f(uRes,  cw, ch);
    gl!.uniform1f(uUnit, unit);
    gl!.uniform4fv(uCols,  colsData);
    gl!.uniform4fv(uRows,  rowsData);
    gl!.uniform4fv(uColsV, colsVData);
    gl!.uniform4fv(uRowsV, rowsVData);
    gl!.uniform4fv(uDrv,   drvData);
    gl!.uniform1i(uDrvN,   totalDrv);
    gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
    gl!.bindVertexArray(null);

    /* 6. Update word label positions to follow driver cells.
          The label overlay (#grid-labels, inset:0) fills .hero-graphic,
          which can be taller than the 480px canvas, so the canvas is
          centred inside it. Offset by the canvas's position so labels
          align to the canvas, not the container. */
    const offL = canvas!.offsetLeft;
    const offT = canvas!.offsetTop;
    for (let d = 0; d < ND; d++) {
      const el = labelEls[d];
      if (d >= nd) { el.style.opacity = '0'; continue; }
      const dc = driverCols[d];
      const dr = driverRows[d];
      /* Centre of the driver cell in physical px */
      const cxPhys = oxPx + colsData[dc] + colW[dc] * 0.5;
      const cyPhys = ch - (oyPx + rowsData[dr] + rowH[dr] * 0.5); /* flip y to CSS top-down */
      /* Convert physical→CSS px, then offset to the canvas origin */
      el.style.left     = (offL + cxPhys / dpr) + 'px';
      el.style.top      = (offT + cyPhys / dpr) + 'px';
      /* Font size: scale with cell, but cap so the word never overflows the
         cell width. Assumes each uppercase char is ~0.62× the font size.    */
      const cellCssPx   = Math.min(colW[dc], rowH[dr]) / dpr;
      const cellWidthPx = colW[dc] / dpr;
      const byHeight    = Math.max(8, cellCssPx * 0.22);
      const byWidth     = (cellWidthPx * 0.82) / (WORDS[d].length * 0.62);
      el.style.fontSize = Math.min(byHeight, byWidth) + 'px';
      /* Fade in quickly with spring expansion; clamp 0–1 */
      const maxDelta    = (unit * gridParams.amp) || 1;
      const intensity   = Math.max(0, driverDelta[d]) / maxDelta;
      el.style.opacity  = String(Math.min(1, intensity * 3.0));
    }

    if (!reducedMotion) rafId = requestAnimationFrame(render);
  }

  if (reducedMotion) {
    resize();
    render(0);
  } else {
    rafId = requestAnimationFrame(render);
  }

  /* Pause when off-screen */
  const obs = new IntersectionObserver(entries => {
    const vis = entries[0].isIntersecting;
    if (vis && !reducedMotion) {
      if (!rafId) rafId = requestAnimationFrame(render);
    } else {
      cancelAnimationFrame(rafId);
      rafId = 0;
    }
  }, { threshold: 0 });
  obs.observe(canvas);

  /* ── Pointer event listeners ──────────────────────────────────── */
  canvas!.style.cursor = 'crosshair';

  canvas!.addEventListener('pointermove', (e: PointerEvent) => {
    const [px, py] = canvasPhy(e);
    if (dragDriver >= 0) {
      didDrag = true;
      const [col, row] = pxToCell(px, py);
      if (col >= 0) driverCols[dragDriver] = col;
      if (row >= 0) driverRows[dragDriver] = row;
      canvas!.style.cursor = 'grabbing';
    } else {
      /* Show grab cursor when hovering within 2 cells of any driver */
      const [mc, mr] = pxToCell(px, py);
      const curNd = Math.min(ND, gridParams.nDrivers);
      let near = false;
      if (mc >= 0 && mr >= 0) {
        for (let d = 0; d < curNd; d++) {
          if (Math.abs(driverCols[d] - mc) + Math.abs(driverRows[d] - mr) < 2) { near = true; break; }
        }
      }
      canvas!.style.cursor = near ? 'grab' : 'crosshair';
    }
  });

  canvas!.addEventListener('pointerdown', (e: PointerEvent) => {
    canvas!.setPointerCapture(e.pointerId);
    const [px, py] = canvasPhy(e);
    didDrag = false;
    const curNd = Math.min(ND, gridParams.nDrivers);
    const [col, row] = pxToCell(px, py);
    /* Grab the nearest driver within Manhattan distance 2 */
    let best = -1, bestDist = 3;
    for (let d = 0; d < curNd; d++) {
      const dist = Math.abs(driverCols[d] - col) + Math.abs(driverRows[d] - row);
      if (dist < bestDist) { bestDist = dist; best = d; }
    }
    dragDriver = best;
    if (dragDriver >= 0) canvas!.style.cursor = 'grabbing';
  });

  canvas!.addEventListener('pointerup', (e: PointerEvent) => {
    if (dragDriver < 0 && !didDrag) {
      /* Clean click on empty space → ghost impulse ripple */
      const [px, py] = canvasPhy(e);
      const [col, row] = pxToCell(px, py);
      if (col >= 0 && row >= 0) {
        if (ghosts.length >= MAX_GHOSTS) ghosts.shift();
        ghosts.push({ col, row, born: performance.now() * 0.001 });
      }
    }
    dragDriver = -1;
    didDrag    = false;
    canvas!.style.cursor = 'crosshair';
  });

  canvas!.addEventListener('pointerleave', () => {
    dragDriver = -1;
    canvas!.style.cursor = 'crosshair';
  });
})();


/* ── Mobile nav toggle ── */
const navToggle = document.getElementById('nav-toggle') as HTMLButtonElement;
const navLinks  = document.getElementById('nav-links')  as HTMLElement;

function closeNav() {
  navLinks.classList.remove('is-open');
  navToggle.setAttribute('aria-expanded', 'false');
  navToggle.setAttribute('aria-label', 'Open menu');
}

navToggle.addEventListener('click', () => {
  const isOpen = navLinks.classList.toggle('is-open');
  navToggle.setAttribute('aria-expanded', String(isOpen));
  navToggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
});

navLinks.querySelectorAll('a').forEach(a => a.addEventListener('click', closeNav));

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeNav(); });

/* ── Nav transparency on scroll ── */
const siteNavEl   = document.querySelector('.site-nav') as HTMLElement;

function refreshNav() {
  const heroEl = document.querySelector('.hero') as HTMLElement;
  const thresh = (heroEl?.offsetHeight ?? 600) - 80;
  siteNavEl?.classList.toggle('is-scrolled', window.scrollY > thresh);
}

window.addEventListener('scroll', refreshNav, { passive: true });
/* Defer initial call so layout has fully painted */
requestAnimationFrame(refreshNav);
</script>
