---
const disciplines = [
  'Fractional CTO / CAIO',
  'AI Systems & Machine Learning',
  'Agents, RAG & Automation',
  'AI Reliability & Evaluation',
  'Real-Time Graphics & GPU',
  'Audio Engineering & DSP',
  'Product Architecture',
];

const stack = [
  { cat: 'Languages',       items: 'Python, TypeScript, JavaScript, C, C++, C#, Rust, GLSL' },
  { cat: 'AI / ML',         items: 'PyTorch, LangChain, LlamaIndex, OpenAI & Anthropic APIs, open-weight models (Llama, Mistral, Qwen), vLLM, RAG pipelines, evals & guardrails, Hugging Face' },
  { cat: 'Infrastructure',  items: 'Docker, GitHub Actions, PostgreSQL, Redis, pgvector / Pinecone, Supabase, Hetzner' },
  { cat: 'Scale & Ops',     items: 'Nginx, Kubernetes, Terraform, Ansible, Cloudflare, Kafka, AWS, GCP, Grafana' },
  { cat: 'Web & Real-time', items: 'React, Next.js, Astro, Three.js, WebGL2, WebAssembly, Web Audio API' },
  { cat: 'Creative Tech',   items: 'TouchDesigner, vvvv, Max/MSP, Unity, JUCE, OpenFrameworks' },
];
---

<section id="about" class="about-section">
  <h2 class="visually-hidden">About</h2>
  <div class="about-grid">

    <div class="about-body">
      <p class="about-lead fade-up" data-delay="100">
        I'm an engineer and technical lead based in Berlin. I care most about systems that have to keep working.
        <a href="/about/" class="about-more">About</a>
      </p>

      <p class="about-prose fade-up" data-delay="240">
        I've been building software for about 25 years. I started as a developer, writing apps and the real-time GPU and audio code where a dropped frame is a bug you can hear. A lot of it was for the stage and custom software clients. For years I worked as a creative developer for theater and performance, including with artists like Philip Glass. <br/>In startups, that work grew into more than writing code. I took on architecture, started leading small teams, and over time ran engineering as a CTO, building plenty of infrastructure and custom systems along the way. These days I help companies get AI into production and keep it running. Usually the unglamorous parts: the infra, the plumbing, the custom pieces that don't come in a box. Often agents, often on open models they host themselves.
      </p>

      <div class="about-disciplines fade-up" data-delay="360">
        <ul class="disciplines-list">
          {disciplines.map(d => <li>{d}</li>)}
        </ul>
      </div>

      <div class="about-stack fade-up" data-delay="440">
        <span class="about-stack-label">Stack, among others</span>
        <dl class="stack-list">
          {stack.map(s => (
            <div class="stack-row">
              <dt class="stack-cat">{s.cat}</dt>
              <dd class="stack-items">{s.items}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>

    <div class="about-meta fade-in" data-delay="480">
      <dl class="meta-list">
        <dd class="meta-graphic" aria-hidden="true">
          <img src="/graphics/icon-about.svg" alt="" loading="lazy" decoding="async" />
        </dd>
        <dt class="visually-hidden">Location</dt>
        <dd>Berlin, DE</dd>
        <dd class="meta-coords">52°31′ N · 13°23′ E</dd>
        <dt class="meta-sep">Open to</dt>
        <dd>AI readiness &amp; production audits</dd>
        <dd>AI &amp; agent build sprints</dd>
        <dd>Reliability retainers</dd>
        <dd>Fractional CTO / CAIO</dd>
      </dl>
    </div>

  </div>
</section>

<style>
  .about-section {
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3.5rem);
    background: var(--white, oklch(99% 0 0));
  }

  .about-grid {
    display: grid;
    grid-template-columns: 2.6fr 1fr;
    gap: 0 clamp(3rem, 5vw, 6rem);
    align-items: start;
  }

  .about-lead {
    font-size: clamp(1.15rem, 2.2vw, 1.65rem);
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: -0.02em;
    color: var(--ink, #2C303C);
    margin-bottom: 1.75rem;
    max-width: 44ch;
    text-wrap: balance;
  }

  .about-more {
    display: inline-block;
    margin-left: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0;
    color: var(--cobalt, #bbdd00);
    text-decoration: none;
  }

  .about-more:hover {
    text-decoration: underline;
  }

  .about-prose {
    font-size: var(--text-body-size, 1rem);
    font-weight: 400;
    line-height: var(--text-body-lh, 1.875);
    color: var(--dim, oklch(28% 0.010 258));
    margin-bottom: 2.5rem;
    max-width: 58ch;
  }

  .disciplines-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.55rem 2rem;
  }

  .disciplines-list li {
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--dim, oklch(28% 0.010 258));
    letter-spacing: 0.01em;
  }

  /* ── Stack ── */
  .about-stack {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px dotted var(--rule, oklch(87% 0.005 260));
  }

  .about-stack-label {
    display: block;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ghost, oklch(50% 0.006 260));
    margin-bottom: 1.1rem;
  }

  .stack-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .stack-row {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0 1.5rem;
    align-items: baseline;
  }

  .stack-cat {
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink, #2C303C);
  }

  .stack-items {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 400;
    line-height: 1.65;
    color: var(--dim, oklch(28% 0.010 258));
  }

  @media (max-width: 640px) {
    .stack-row { grid-template-columns: 1fr; gap: 0.2rem; }
  }

  /* ── Meta sidebar ── */
  .about-meta {
    text-align: right;
    padding-top: 0.25rem;
  }

  .meta-list {
    font-size: 0.62rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ghost, oklch(50% 0.006 260));
    line-height: 2.2;
  }
  .meta-list dt,
  .meta-list dd { margin: 0; }

  .meta-coords {
    color: var(--ghost, oklch(50% 0.006 260));
    letter-spacing: 0.08em;
    margin-bottom: 0.25rem;
  }

  .meta-graphic {
    margin-bottom: 1.25rem;
    display: flex;
    justify-content: flex-end;
  }

  .meta-graphic img {
    display: block;
    width: 56px;
    height: 56px;
    object-fit: contain;
  }

  .meta-sep {
    position: static;
    width: auto;
    height: auto;
    overflow: visible;
    clip: auto;
    white-space: normal;
    margin-top: 1.5rem;
    color: var(--cobalt, #bbdd00);
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-meta { text-align: left; }
  }
  @media (max-width: 640px) {
    .disciplines-list { grid-template-columns: 1fr; }
  }
</style>
