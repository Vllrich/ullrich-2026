---
import ContentPage from '../../layouts/ContentPage.astro';
import WorkCatalog from '../../components/WorkCatalog.astro';
import { languageAlternates } from '../../lib/i18n';
import { workEntriesFor } from '../../data/work-patterns';

const description =
  'Real AI work, written plainly: case studies and common engagement shapes, without made-up numbers.';

const alternates = languageAlternates('/work/patterns/', '/de/arbeit/muster/');
const entries = workEntriesFor('en');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://larsullrich.de/work/patterns/#webpage',
  url: 'https://larsullrich.de/work/patterns/',
  name: 'Work patterns & case studies',
  description,
  inLanguage: 'en',
  isPartOf: { '@id': 'https://larsullrich.de/#website' },
  author: { '@id': 'https://larsullrich.de/#person' },
  hasPart: entries.map((p) => ({
    '@type': 'CreativeWork',
    name: p.title,
    description: p.blurb,
    identifier: p.id,
  })),
};
---

<ContentPage
  title="Work patterns & case studies - Lars Ullrich"
  description={description}
  canonical="/work/patterns/"
  noteId="patterns"
  heading="Work patterns & case studies"
  eyebrow="Work"
  lead="Real work first. Then the usual shapes of an engagement. No invented numbers. Names only when clients clear them."
  icon="/graphics/work-cases-mark.svg"
  alternates={alternates}
  jsonLd={jsonLd}
  localeSwitch={{ href: '/de/arbeit/muster/', label: 'Deutsch' }}
  layout="wide"
>
  <WorkCatalog lang="en" />
</ContentPage>
