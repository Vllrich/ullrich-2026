---
import { activeNavKey, primaryNav, type NavKey } from '../lib/nav';
import type { SiteLang } from '../lib/i18n';
import LocaleSwitch from './LocaleSwitch.astro';
import DiagnoseIcon from './DiagnoseIcon.astro';
import { landingCopy, landingHomeHref } from '../data/landing';

interface Props {
  lang?: SiteLang;
  /** Visual surface: home lime bar vs content pages */
  variant?: 'home' | 'content';
  localeSwitch?: {
    href?: string;
    label?: string;
    hrefs?: Partial<Record<SiteLang, string>>;
  };
  /** Force active key; otherwise derived from the current URL */
  active?: NavKey | null;
}

const { lang = 'en', variant = 'content', localeSwitch, active } = Astro.props;
const items = primaryNav(lang);
const current = active !== undefined ? active : activeNavKey(Astro.url.pathname);
const homeHref = landingHomeHref(lang);
const brandLabel =
  lang === 'de' ? 'Zur Startseite' : lang === 'es' ? 'Volver al inicio' : 'Back to home';
const navLabel =
  lang === 'de' ? 'Hauptnavigation' : lang === 'es' ? 'Navegación principal' : 'Main navigation';
const menuOpenLabel =
  lang === 'de' ? 'Menü öffnen' : lang === 'es' ? 'Abrir menú' : 'Open menu';
const descriptor = landingCopy(lang).cover.descriptor;

const switchHrefs: Partial<Record<SiteLang, string>> = {
  ...(localeSwitch?.hrefs ?? {}),
};
if (localeSwitch?.href && !localeSwitch.hrefs) {
  if (lang === 'de') switchHrefs.en = localeSwitch.href;
  else if (lang === 'es') switchHrefs.en = localeSwitch.href;
  else switchHrefs.de = localeSwitch.href;
}
---

{
  variant === 'home' ? (
    <header class="site-nav">
      <a href={homeHref} class="nav-logo">
        <DiagnoseIcon size="sm" class="nav-mark" />
        <span class="nav-logo-text">
          LARS ULLRICH
          <span class="nav-descriptor">{descriptor}</span>
        </span>
      </a>
      <nav class="nav-links" id="nav-links" aria-label={navLabel}>
        {items.map((item) => (
          <a href={item.href} class:list={[current === item.key && 'is-active']}>{item.label}</a>
        ))}
        {localeSwitch && (
          <LocaleSwitch lang={lang} hrefs={switchHrefs} variant="lime" />
        )}
      </nav>
      <button
        class="nav-toggle"
        id="nav-toggle"
        aria-label={menuOpenLabel}
        aria-expanded="false"
        aria-controls="nav-links"
      >
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
      </button>
    </header>
  ) : (
    <header class="cp-bar">
      <a href={homeHref} class="cp-brand" aria-label={brandLabel}>
        <DiagnoseIcon size="sm" class="cp-brand-mark" />
        <span class="cp-brand-text">Lars Ullrich</span>
      </a>
      <nav class="cp-bar-nav" aria-label={navLabel}>
        {items.map((item) => (
          <a href={item.href} class:list={[current === item.key && 'is-active']}>{item.label}</a>
        ))}
        {localeSwitch && (
          <LocaleSwitch lang={lang} hrefs={switchHrefs} variant="content" />
        )}
      </nav>
    </header>
  )
}
