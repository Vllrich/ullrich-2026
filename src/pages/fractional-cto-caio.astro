---
import ContentPage from '../layouts/ContentPage.astro';
import { languageAlternates } from '../lib/i18n';

const description =
  'Part-time senior technical leadership: architecture, delivery, and AI strategy, with hands in the repo. Monthly retainer.';

const alternates = languageAlternates('/fractional-cto-caio/', '/de/fractional-cto-caio/');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://larsullrich.de/fractional-cto-caio/#webpage',
  url: 'https://larsullrich.de/fractional-cto-caio/',
  name: 'Fractional CTO / CAIO',
  description,
  inLanguage: 'en',
  isPartOf: { '@id': 'https://larsullrich.de/#website' },
  about: {
    '@type': 'Occupation',
    name: 'Fractional CTO / CAIO',
    description,
  },
  author: { '@id': 'https://larsullrich.de/#person' },
};
---

<ContentPage
  title="Fractional CTO / CAIO - Lars Ullrich"
  description={description}
  canonical="/fractional-cto-caio/"
  noteId="fractional-cto"
  heading="Fractional CTO / CAIO"
  eyebrow="Leadership"
  lead="Senior judgment and delivery ownership on a part-time seat. Hands in the repo."
  icon="/graphics/icon-command.svg"
  alternates={alternates}
  jsonLd={jsonLd}
  localeSwitch={{ href: '/de/fractional-cto-caio/', label: 'Deutsch' }}
>
  <p>
    I come in part-time or on a project basis. Architecture, roadmap, delivery ownership, team and vendor calls, AI strategy. Day to day that looks like reviews, hard decisions, and debugging production with your team. Same kinds of work as a staff+ hire. Without the full salary load.
  </p>

  <h2>Hands in the repo</h2>
  <p>
    The engagement includes code. I work inside your repository. I stay around to operate what we ship when that's part of the deal. Implementation, architecture reviews, production debugging, ongoing reliability. Pick the mix that fits.
  </p>

  <h2>Where people usually start</h2>
  <p>
    Still fuzzy on AI?
    <a href="/services/readiness-audit/">Do the audit</a>
    first. Already know the build? A Build Sprint takes one system to production. Already live?
    <a href="/agent-reliability/">Reliability</a>
    keeps it honest. Need the seat filled ongoing? That's this retainer.
  </p>
  <p>
    More in
    <a href="/work/patterns/">patterns</a>,
    <a href="/eu-ai-act-readiness/">EU AI Act readiness</a>,
    and
    <a href="/about/">about</a>.
  </p>
</ContentPage>
