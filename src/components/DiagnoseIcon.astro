<style>
  .diagnose-mark {
    width: 100%;
    max-width: 340px;
    height: auto;
    display: block;
  }

  .diagnose-mark--sm {
    width: 2.75rem;
    max-width: none;
    height: 2.75rem;
  }

  .line {
    fill: var(--ink, #2c303c);
  }

  .shade {
    fill: #000;
    fill-opacity: 0.2;
  }

  .tri {
    fill: #caf200;
    transition: fill 0.45s ease;
  }

  .tri.is-off {
    fill: transparent;
  }

  @media (prefers-reduced-motion: reduce) {
    .tri {
      transition: none;
    }
  }
</style>

<script>
  function bootOne(root: Element) {
    if (!(root instanceof SVGElement) || root.dataset.animate === '1') return;

    const tris = Array.from(root.querySelectorAll('.tri'));
    if (tris.length === 0) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (reduce.matches) return;

    root.dataset.animate = '1';
    tris.forEach((t, i) => t.classList.toggle('is-off', i % 2 === 1));

    let timer = 0;

    const tick = () => {
      const idx = Math.floor(Math.random() * tris.length);
      tris[idx].classList.toggle('is-off');
      const lit = tris.filter((t) => !t.classList.contains('is-off'));
      if (lit.length === 0) tris[idx].classList.remove('is-off');
      timer = window.setTimeout(tick, 700 + Math.random() * 900);
    };

    timer = window.setTimeout(tick, 600);

    reduce.addEventListener('change', () => {
      if (!reduce.matches) return;
      window.clearTimeout(timer);
      tris.forEach((t) => t.classList.remove('is-off'));
      delete root.dataset.animate;
    });
  }

  function boot() {
    document.querySelectorAll('[data-diagnose-icon]').forEach(bootOne);
  }

  boot();
  document.addEventListener('astro:page-load', boot);
</script>
