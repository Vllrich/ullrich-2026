---
const items = ['Diagnose', 'Architect', 'Build', 'Harden', 'Ship'];
---

<div class="velocity-strip" aria-hidden="true">
  <div class="velocity-track">
    {[...items, ...items, ...items].map((item) => (
      <span class="velocity-item">
        {item}
        <span class="velocity-sep" aria-hidden="true">—</span>
      </span>
    ))}
  </div>
</div>

<style>
  .velocity-strip {
    overflow: hidden;
    border-bottom: 1px solid var(--color-rule, oklch(84% 0.005 255));
    padding: 1rem 0;
    background: var(--color-bg, oklch(97.5% 0 0));
  }

  .velocity-track {
    display: flex;
    white-space: nowrap;
    animation: scroll-left 24s linear infinite;
    width: max-content;
  }

  .velocity-strip:hover .velocity-track {
    animation-play-state: paused;
  }

  .velocity-item {
    font-size: clamp(0.9rem, 1.4vw, 1.05rem);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink, oklch(11% 0.015 255));
    padding: 0 0.2rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .velocity-sep {
    color: var(--color-rule, oklch(84% 0.005 255));
    font-weight: 400;
    margin-right: 1rem;
  }

  @keyframes scroll-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.333%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .velocity-track { animation: none; }
  }
</style>
