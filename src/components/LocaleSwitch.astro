---
import { LANG_CODE, SITE_LANGS, type SiteLang, landingLocaleHrefs } from '../lib/i18n';

interface Props {
  lang: SiteLang;
  /** Per-locale URLs. Defaults to landing homes. */
  hrefs?: Partial<Record<SiteLang, string>>;
  /** Visual surface for contrast */
  variant?: 'lime' | 'content' | 'footer' | 'dark';
}

const { lang, hrefs: hrefOverrides, variant = 'content' } = Astro.props;
const defaults = landingLocaleHrefs();
const hrefs: Record<SiteLang, string> = {
  en: hrefOverrides?.en ?? defaults.en,
  de: hrefOverrides?.de ?? defaults.de,
  es: hrefOverrides?.es ?? defaults.es,
};

const ariaLabel =
  lang === 'de' ? 'Sprache' : lang === 'es' ? 'Idioma' : 'Language';
const code = LANG_CODE[lang];
---

<details class:list={['locale-switch', `locale-switch--${variant}`]}>
  <summary class="locale-switch__trigger" aria-label={ariaLabel}>
    <span class="locale-switch__globe" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="9"></circle>
        <path d="M3 12h18"></path>
        <path d="M12 3a14 14 0 0 1 0 18"></path>
        <path d="M12 3a14 14 0 0 0 0 18"></path>
      </svg>
    </span>
    <span class="locale-switch__code">{code}</span>
  </summary>
  <ul class="locale-switch__menu" role="listbox" aria-label={ariaLabel}>
    {SITE_LANGS.map((codeLang) => {
      const isCurrent = codeLang === lang;
      const label = LANG_CODE[codeLang];
      return (
        <li role="option" aria-selected={isCurrent}>
          {isCurrent ? (
            <span class="locale-switch__opt is-current" aria-current="true">{label}</span>
          ) : (
            <a
              class="locale-switch__opt"
              href={hrefs[codeLang]}
              hreflang={codeLang}
              lang={codeLang}
            >
              {label}
            </a>
          )}
        </li>
      );
    })}
  </ul>
</details>

<script>
  function closeOtherLocaleSwitches(except: HTMLDetailsElement) {
    document.querySelectorAll<HTMLDetailsElement>('details.locale-switch[open]').forEach((el) => {
      if (el !== except) el.open = false;
    });
  }

  document.querySelectorAll<HTMLDetailsElement>('details.locale-switch').forEach((details) => {
    details.addEventListener('toggle', () => {
      if (details.open) closeOtherLocaleSwitches(details);
    });
  });

  document.addEventListener('click', (event) => {
    const target = event.target as Node | null;
    document.querySelectorAll<HTMLDetailsElement>('details.locale-switch[open]').forEach((el) => {
      if (!el.contains(target)) el.open = false;
    });
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    document.querySelectorAll<HTMLDetailsElement>('details.locale-switch[open]').forEach((el) => {
      el.open = false;
    });
  });
</script>

<style>
  .locale-switch {
    position: relative;
    display: inline-flex;
    flex-shrink: 0;
    vertical-align: middle;
    line-height: 1;
  }

  .locale-switch__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.15rem 0;
    list-style: none;
    cursor: pointer;
    user-select: none;
    color: var(--ghost, oklch(50% 0.006 260));
    font-family: var(--font-sans, "Darker Grotesque", system-ui, sans-serif);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.15s ease;
  }

  .locale-switch__trigger::-webkit-details-marker {
    display: none;
  }

  .locale-switch__trigger::marker {
    content: "";
  }

  .locale-switch__trigger:hover,
  .locale-switch[open] .locale-switch__trigger {
    color: var(--ink, #2c303c);
  }

  .locale-switch__trigger:focus-visible {
    outline: 2px solid var(--cobalt, #bbdd00);
    outline-offset: 3px;
  }

  .locale-switch__globe {
    display: inline-flex;
  }

  .locale-switch__code {
    line-height: 1;
  }

  .locale-switch__menu {
    position: absolute;
    top: calc(100% + 0.35rem);
    right: 0;
    z-index: 40;
    min-width: 3.25rem;
    margin: 0;
    padding: 0.25rem;
    list-style: none;
    background: var(--paper, #f4f5f0);
    border: 1px solid color-mix(in oklch, var(--ink, #2c303c) 16%, transparent);
    box-shadow: 0 6px 18px color-mix(in oklch, var(--ink, #2c303c) 10%, transparent);
  }

  .locale-switch__menu li + li {
    margin-top: 0.1rem;
  }

  .locale-switch__opt {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 1.55rem;
    padding: 0.2rem 0.45rem;
    border-radius: 0;
    font-family: var(--font-sans, "Darker Grotesque", system-ui, sans-serif);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ghost, oklch(50% 0.006 260));
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .locale-switch__opt.is-current {
    background: var(--ink, #2c303c);
    color: var(--paper, #f4f5f0);
  }

  a.locale-switch__opt:hover {
    color: var(--ink, #2c303c);
    background: color-mix(in oklch, var(--ink, #2c303c) 6%, transparent);
  }

  a.locale-switch__opt:focus-visible {
    outline: 2px solid var(--cobalt, #bbdd00);
    outline-offset: 1px;
  }

  .locale-switch--lime .locale-switch__trigger {
    color: var(--dim, oklch(28% 0.010 258));
  }

  .locale-switch--lime .locale-switch__trigger:hover,
  .locale-switch--lime[open] .locale-switch__trigger {
    color: var(--ink, #2c303c);
  }

  .locale-switch--lime .locale-switch__opt.is-current {
    background: var(--ink, #2c303c);
    color: var(--lime, #bbdd00);
  }

  .locale-switch--footer .locale-switch__trigger {
    font-size: 0.64rem;
  }

  .locale-switch--footer .locale-switch__opt {
    font-size: 0.64rem;
    min-height: 1.4rem;
  }

  .locale-switch--dark .locale-switch__trigger {
    color: rgba(255, 255, 255, 0.7);
  }

  .locale-switch--dark .locale-switch__trigger:hover,
  .locale-switch--dark[open] .locale-switch__trigger {
    color: #ffffff;
  }

  .locale-switch--dark .locale-switch__menu {
    background: #2c303c;
    border-color: rgba(255, 255, 255, 0.18);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.35);
  }

  .locale-switch--dark .locale-switch__opt {
    color: rgba(255, 255, 255, 0.55);
  }

  .locale-switch--dark .locale-switch__opt.is-current {
    background: #bbdd00;
    color: #2c303c;
  }

  .locale-switch--dark a.locale-switch__opt:hover {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.08);
  }

  @media (prefers-reduced-motion: reduce) {
    .locale-switch__trigger,
    .locale-switch__opt {
      transition: none;
    }
  }
</style>
