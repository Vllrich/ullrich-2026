---
---

<div class="site-wrap">

  <header class="site-nav">
    <a href="/" class="nav-logo">
      LARS ULLRICH
      <span class="nav-descriptor">Agent reliability &middot; Full-Stack Engineer &amp; Fractional CTO</span>
    </a>
    <nav class="nav-links" id="nav-links" aria-label="Main navigation">
      <a href="/work/patterns/">Work</a>
      <a href="/notes/">Notes</a>
      <a href="#services">Services</a>
      <a href="/about/">About</a>
      <a href="#contact">Contact</a>
      <a href="/de/" hreflang="de" class="nav-locale">Deutsch</a>
    </nav>
    <button
      class="nav-toggle"
      id="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-links"
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </header>

  <section class="hero" aria-label="Hero">
    <!-- WebGL canvases — hidden, preserved for re-enable -->
    <canvas id="fluid-canvas" aria-hidden="true"></canvas>
    <canvas id="ascii-canvas" aria-hidden="true"></canvas>

    <!-- Left: text content -->
    <div class="hero-text">
      <h1 class="hero-heading">
        Engineering leadership<br/>
        <span class="hero-heading-alt">for software that has to work</span>
      </h1>

      <p class="hero-body">
        I help growing companies ship software that holds up in production, and keep it running<br/>
        AI included, when it earns its place
      </p>
      <div class="hero-ctas">
        <a href="#contact" class="hero-cta-primary">Request a scope call</a>
        <a href="#method" class="hero-cta-secondary">See how I work</a>
      </div>
    </div>

    <!-- Full-bleed skyline along the hero floor -->
    <div class="hero-graphic" aria-hidden="true">
      <canvas id="bauhaus-canvas"></canvas>
      <!-- Icons over open driver cells — positioned by JS each frame -->
      <div id="grid-labels" class="grid-labels"></div>
    </div>
  </section>

</div>

<style>
  .site-wrap { background: #ffffff; }

  /* ── Navigation ── */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 3.5rem;
    background: #bbdd00;
    border-bottom: 1px solid transparent;
    transition: background 0.28s ease, border-color 0.28s ease;
  }

  .site-nav.is-scrolled {
    background: oklch(99% 0 0 / 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--rule, oklch(87% 0.005 260));
  }

  .nav-logo {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink, #2C303C);
    font-family: var(--font-sans, "Darker Grotesque", system-ui, sans-serif);
    line-height: 1.1;
  }

  .nav-descriptor {
    font-weight: 400;
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: oklch(30% 0.008 258);
    font-family: var(--font-sans, "Darker Grotesque", system-ui, sans-serif);
    display: block;
    line-height: 1;
  }

  .nav-links {
    display: flex;
    gap: clamp(1rem, 2vw, 1.75rem);
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-sans, "Darker Grotesque", system-ui, sans-serif);
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dim, oklch(28% 0.010 258));
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--ink, #2C303C); }

  .nav-links a.nav-locale {
    color: var(--ink, #2C303C);
    font-weight: 700;
  }

  /* ── Hero: text left, skyline graphic full-bleed at bottom ── */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr;
    height: 720px;
    background: #bbdd00;
    overflow: hidden;
    position: relative;
    margin-top: -2rem; /* nav bar is same lime color — shift up so content sits at optical midpoint of nav+hero combined */
  }

  #fluid-canvas,
  #ascii-canvas { display: none; }

  /* Left: text column — vertically centered, above the skyline */
  .hero-text {
    grid-column: 1;
    grid-row: 1;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(2.5rem, 5vw, 4.5rem);
    position: relative;
  }

  .hero-heading {
    font-family: var(--font-display, "Darker Grotesque", system-ui, sans-serif);
    font-size: clamp(2rem, 3.5vw, 3.85rem);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--ink, #2C303C);
    text-transform: uppercase;
    text-wrap: balance;
  }

  .hero-badge {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-sans, "Darker Grotesque", system-ui, sans-serif);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink, #2C303C);
    background: transparent;
    border: 1px dotted var(--ink, #2C303C);
    border-radius: 999px;
    padding: 0.4em 0.9em;
  }

  .hero-body {
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--dim, oklch(28% 0.010 258));
    max-width: 42ch;
  }

  .hero-heading-alt {
    color: var(--white, #fafafa);
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero-cta-primary {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--white, #fafafa);
    background: var(--ink, #2C303C);
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .hero-cta-primary:hover { background: oklch(22% 0.01 258); }

  .hero-cta-secondary {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink, #2C303C);
    background: #bbdd00;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--ink, #2C303C);
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .hero-cta-secondary:hover { opacity: 0.55; }

  /* Services list below CTA */
  .hero-services {
    list-style: none;
    padding: 0;
    margin-top: 0.25rem;
  }

  .hero-services li {
    font-family: var(--font-sans, "Darker Grotesque", system-ui, sans-serif);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ghost, oklch(50% 0.006 260));
    padding: 0.55rem 0;
    border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
    line-height: 1;
  }
  .hero-services li:first-child { border-top: 1px dotted var(--rule, oklch(87% 0.005 260)); }

  /* Full-bleed skyline — sits on the hero floor, under the text */
  .hero-graphic {
    grid-column: 1 / -1;
    grid-row: 1;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: stretch;
    overflow: hidden;
    padding: 0;
    background: transparent;
    position: relative;
    pointer-events: none;
  }

  /* ── Icon overlay on open driver cells ──────────────────────── */
  .grid-labels {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 5; /* above the canvas (z-index:1), below the param panel (20) */
  }
  /* :global — these imgs are created in JS via createElement, so they
     don't carry Astro's scoped data-attribute. Without :global the scoped
     selector wouldn't match them and position:absolute would be dropped. */
  :global(.grid-icon) {
    position: absolute;
    width: 32px;
    height: 32px;
    object-fit: contain;
    background: transparent;
    transform: translate(-50%, -50%);
    user-select: none;
    pointer-events: none;
  }

  #bauhaus-canvas {
    display: block;
    width: 100%;
    height: 92%;
    max-width: none;
    position: relative;
    z-index: 1; /* keep below the icon overlay */
    pointer-events: auto;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      height: auto;
      min-height: auto;
    }
    .hero-text {
      grid-column: 1;
      grid-row: 1;
      padding: clamp(3rem, 8vw, 4rem) 1.5rem 1.5rem;
    }
    .hero-heading { font-size: clamp(1.4rem, 5vw, 2.45rem); }
    .hero-graphic {
      grid-column: 1;
      grid-row: 2;
      position: relative;
      height: 52vw;
      min-height: 220px;
      pointer-events: auto;
    }
    #bauhaus-canvas {
      height: 100%;
    }
  }

  @media (max-width: 760px) {
    .site-nav { padding: 1.1rem 1.5rem; }
    .nav-links { gap: 1.25rem; }
    .nav-descriptor { display: none; }
  }

  /* ── Hamburger toggle button ── */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-right: -0.5rem;
  }

  .nav-toggle-bar {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ink, #2C303C);
    transition: transform 0.2s, opacity 0.2s;
    transform-origin: center;
  }

  .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  @media (max-width: 500px) {
    .site-nav {
      flex-wrap: wrap;
      align-items: center;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      width: 100%;
      flex-direction: column;
      gap: 0;
      border-top: 1px dotted var(--rule, oklch(87% 0.005 260));
      padding: 0.5rem 0 0.75rem;
    }

    .nav-links.is-open {
      display: flex;
    }

    .nav-links a {
      font-size: 0.78rem;
      letter-spacing: 0.06em;
      padding: 0.6rem 0;
      border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
    }

    .nav-links a:last-child {
      border-bottom: none;
    }

    .hero-heading { font-size: clamp(1.4rem, 6.3vw, 2.1rem); }
  }
</style>

<script>
/* ── Shared params object — read by shader, written by UI controls ── */
const gridParams = {
  amp:      2.4,  /* pulse amplitude — how much drivers expand  */
  speed:    1.0,  /* playback speed multiplier                  */
  nDrivers: 8,    /* how many of the 8 driver cells are active  */
  gapCSS:   2,    /* gap between cells in CSS pixels            */
  ease:     0.12, /* exponential follow toward pulse target     */
};

/* ── Grid shader: 16×16 push-layout squares (v3) ── */
(function initGridShader() {
  const canvas = document.getElementById('bauhaus-canvas') as HTMLCanvasElement | null;
  if (!canvas) return;

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const gl = canvas.getContext('webgl2', { antialias: false, alpha: false }) as WebGL2RenderingContext | null;
  if (!gl) { canvas.style.background = '#bbdd00'; return; }

  function mkShader(type: number, src: string): WebGLShader {
    const s = gl!.createShader(type)!;
    gl!.shaderSource(s, src);
    gl!.compileShader(s);
    if (!gl!.getShaderParameter(s, gl!.COMPILE_STATUS))
      console.error('Grid shader:', gl!.getShaderInfoLog(s));
    return s;
  }

  const VERT = `#version 300 es
layout(location=0) in vec2 a_pos;
void main(){gl_Position=vec4(a_pos,0.0,1.0);}`;

  /* ── Fragment shader ────────────────────────────────────────────
     JS computes a proper layout every frame:
       - 16 column widths  (sum = canvas usable width  - 17 px gaps)
       - 16 row heights    (sum = canvas usable height - 17 px gaps)
     Driver cells grow their column AND row; neighbours shrink and
     physically SHIFT so a 1-px gap is always maintained.

     The shader receives cumulative positions + sizes packed into
     two vec4[8] uniforms (32 floats each = 16 vec4 slots total).
     For each fragment it searches column & row linearly (≤ 16 iters
     each) — no overlap is geometrically possible by construction.
     ─────────────────────────────────────────────────────────────── */
  const FRAG = `#version 300 es
precision highp float;
uniform vec2  u_resolution;
uniform float u_unit;     /* base cell size at rest (physical px) */
/* u_cols[0..3] = colX,  u_cols[4..7] = colW   (y-up, grid-local)
   u_rows[0..3] = rowY,  u_rows[4..7] = rowH
   u_colsV[0..3] = colVel[16],  u_rowsV[0..3] = rowVel[16]       */
uniform vec4 u_cols[8];
uniform vec4 u_rows[8];
uniform vec4 u_colsV[4];
uniform vec4 u_rowsV[4];
/* u_drv[i] = (driverCol, driverRow, intensity 0..1, unused) */
uniform vec4 u_drv[8];
uniform int  u_drvN;
uniform float u_limeSeed; /* fixed at init — which cells are solid lime */
uniform vec4 u_sky[4];    /* 16 floats: floors visible per column (from bottom) */
out vec4 fragColor;

const vec3 BG = vec3(0.733, 0.867, 0.000); /* lime #bbdd00 */
const vec3 LIME = vec3(0.733, 0.867, 0.000); /* solid site lime */

float cX(int c){ return u_cols[  c >> 2   ][ c & 3 ]; }
float cW(int c){ return u_cols[ (c >> 2)+4 ][ c & 3 ]; }
float rY(int r){ return u_rows[  r >> 2   ][ r & 3 ]; }
float rH(int r){ return u_rows[ (r >> 2)+4 ][ r & 3 ]; }
float cV(int c){ return u_colsV[ c >> 2 ][ c & 3 ]; }
float rV(int r){ return u_rowsV[ r >> 2 ][ r & 3 ]; }
float skyH(int c){ return u_sky[ c >> 2 ][ c & 3 ]; }

/* 4-stop: deep lime → mid → #bbdd00 → soft pale lime (never full white) */
vec3 cellColor(float t) {
  t = clamp(t, 0.0, 1.0);
  vec3 c0 = vec3(0.55, 0.68, 0.000);   /* deep lime resting cells */
  vec3 c1 = vec3(0.62, 0.76, 0.000);   /* mid lime                */
  vec3 c2 = vec3(0.68, 0.82, 0.000);   /* bright lime             */
  vec3 c3 = vec3(0.733, 0.867, 0.000); /* #bbdd00 site lime       */
  vec3 c4 = vec3(0.90, 0.95, 0.62);    /* whitish lime, not full white */
  if (t < 0.30) return mix(c0, c1, t / 0.30);
  if (t < 0.60) return mix(c1, c2, (t - 0.30) / 0.30);
  if (t < 0.85) return mix(c2, c3, (t - 0.60) / 0.25);
  return         mix(c3, c4, (t - 0.85) / 0.15);
}

/* Signed distance to a rounded box; p relative to centre, b = half-size. */
float sdRoundBox(vec2 p, vec2 b, float r) {
  vec2 q = abs(p) - b + r;
  return min(max(q.x, q.y), 0.0) + length(max(q, 0.0)) - r;
}

float hash21(vec2 p) {
  return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123);
}

void main(){
  vec2 gf = gl_FragCoord.xy;

  int col = -1;
  for(int c = 0; c < 16; c++){
    if(gf.x >= cX(c) && gf.x < cX(c) + cW(c)){ col = c; break; }
  }
  int row = -1;
  for(int r = 0; r < 16; r++){
    if(gf.y >= rY(r) && gf.y < rY(r) + rH(r)){ row = r; break; }
  }

  /* Skyline mask: only floors below each column's building height. */
  if(col < 0 || row < 0 || float(row) >= skyH(col)){
    fragColor = vec4(BG, 1.0);
    return;
  }

  /* Round each cell; soft edge so spring motion doesn't shimmer. */
  float cw = cW(col);
  float ch = rH(row);
  float rr = min(min(cw, ch) * 0.22, u_unit * 0.22);
  vec2 halfSz = vec2(cw, ch) * 0.5;
  vec2 center = vec2(cX(col), rY(row)) + halfSz;
  float sd = sdRoundBox(gf - center, halfSz, rr);
  if (sd > 1.25) {
    fragColor = vec4(BG, 1.0);
    return;
  }
  float edge = 1.0 - smoothstep(-0.5, 1.25, sd);

  float fc = float(col);
  float fr = float(row);

  /* 2D bloom field: colour comes from proximity to the REAL driver cells,
     not from cell size. This avoids the column×row lattice artefact —
     only the actual (random) driver positions light up.                  */
  float bloom = 0.0;
  const float sigma = 1.6; /* bloom radius in cells */
  for(int i = 0; i < 8; i++){
    if(i >= u_drvN) break;
    float dc = fc - u_drv[i].x;
    float dr = fr - u_drv[i].y;
    float d2 = dc*dc + dr*dr;
    float b  = u_drv[i].z * exp(-d2 / (2.0 * sigma * sigma));
    bloom = max(bloom, b);
  }

  /* Cap bloom so open cells go whitish behind icons, but never full white. */
  float t = clamp(0.04 + bloom * 0.95, 0.0, 0.88);
  /* Narrow alpha range — wide 0.25–1.0 contrast flickered at moving edges. */
  float cellA = 0.55 + hash21(vec2(fc + 5.2, fr + 9.1) + u_limeSeed * 3.7) * 0.35;
  vec3 lit = cellColor(t);
  vec3 rgb = mix(BG, lit, cellA);
  /* Soft lime accent (no hard binary branch — that flickered at cell edges). */
  float limeAmt = smoothstep(0.82, 0.92, hash21(vec2(fc, fr) + u_limeSeed * 17.3));
  rgb = mix(rgb, LIME, limeAmt * (1.0 - smoothstep(0.15, 0.55, t)));
  /* Bloom smoothly lifts toward the lit colour. */
  rgb = mix(rgb, lit, smoothstep(0.12, 0.60, t));

  fragColor = vec4(mix(BG, rgb, edge), 1.0);
}`;

  const prog = gl.createProgram()!;
  gl.attachShader(prog, mkShader(gl.VERTEX_SHADER,   VERT));
  gl.attachShader(prog, mkShader(gl.FRAGMENT_SHADER, FRAG));
  gl.linkProgram(prog);
  if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
    console.error('Grid shader link:', gl.getProgramInfoLog(prog));
    return;
  }

  const vao = gl.createVertexArray()!;
  gl.bindVertexArray(vao);
  const vbuf = gl.createBuffer()!;
  gl.bindBuffer(gl.ARRAY_BUFFER, vbuf);
  gl.bufferData(gl.ARRAY_BUFFER,
    new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
  gl.enableVertexAttribArray(0);
  gl.vertexAttribPointer(0, 2, gl.FLOAT, false, 0, 0);
  gl.bindVertexArray(null);

  const uRes      = gl.getUniformLocation(prog, 'u_resolution');
  const uUnit     = gl.getUniformLocation(prog, 'u_unit');
  const uCols     = gl.getUniformLocation(prog, 'u_cols[0]');
  const uRows     = gl.getUniformLocation(prog, 'u_rows[0]');
  const uColsV    = gl.getUniformLocation(prog, 'u_colsV[0]');
  const uRowsV    = gl.getUniformLocation(prog, 'u_rowsV[0]');
  const uDrv      = gl.getUniformLocation(prog, 'u_drv[0]');
  const uDrvN     = gl.getUniformLocation(prog, 'u_drvN');
  const uLimeSeed = gl.getUniformLocation(prog, 'u_limeSeed');
  const uSky      = gl.getUniformLocation(prog, 'u_sky[0]');
  let limeSeed = Math.random() * 1000;

  /* ── Driver config ─────────────────────────────────────────────
     Drivers are placed once at init and stay put. Icons may swap while
     a cell is closed. Moving drivers mid-run caused layout jumps.
     ─────────────────────────────────────────────────────────────── */
  const ND          = 8;
  const GS          = 16;
  const driverCols: number[] = new Array(ND).fill(0);
  const driverRows: number[] = new Array(ND).fill(0);
  const driverPhase = [0.00, 1.10, 2.30, 4.70, 0.70, 3.10, 5.50, 2.00];
  const driverFreq  = [0.28, 0.41, 0.33, 0.55, 0.22, 0.48, 0.37, 0.63];
  /* Icon swap once per closed half — positions stay fixed (no layout teleport). */
  const iconArmed = new Uint8Array(ND);

  /* Skyline profile — fixed at init. Left half stays low; right half climbs hard.
     Adjacent columns sometimes share a height so blocks read as buildings.
     Left floors are also capped to LEFT_MAX_CSS px after layout each frame. */
  const LEFT_MAX_CSS = 154;
  const buildingH = new Float32Array(GS);
  const skyEff = new Float32Array(GS); /* effective floors after pixel cap */
  let leftFloorsCap = 3;               /* frozen from rest layout; avoids pop flicker */
  let skySizeKey = '';
  {
    let c = 0;
    while (c < GS) {
      const t = c / (GS - 1);
      /* Left half: 2–3 floors (pixel-capped later). Right half: up to full height. */
      const base = t < 0.5
        ? 2 + t * 2
        : 4 + Math.pow((t - 0.5) * 2, 0.85) * 12;
      const wobble = t < 0.5 ? (Math.random() - 0.5) * 0.8 : (Math.random() - 0.15) * 2.8;
      const h = t < 0.5
        ? Math.max(2, Math.min(3, Math.round(base + wobble)))
        : Math.max(2, Math.min(GS, Math.round(base + wobble)));
      const span = Math.random() < 0.4 ? 1 : Math.random() < 0.65 ? 2 : 3;
      for (let k = 0; k < span && c < GS; k++, c++) {
        buildingH[c] = h;
      }
    }
    skyEff.set(buildingH);
  }

  /* Recompute left floor budget only when canvas size changes (rest row height). */
  function refreshLeftFloorsCap(gapPx: number, unitRest: number, dpr: number): void {
    const maxLeftPhy = LEFT_MAX_CSS * dpr;
    let top = gapPx;
    let floors = 0;
    for (let r = 0; r < GS; r++) {
      top += unitRest;
      if (top <= maxLeftPhy + 0.5) floors = r + 1;
      else break;
      top += gapPx;
    }
    leftFloorsCap = Math.max(1, floors);
  }

  function clampToSkyline(col: number, row: number): [number, number] {
    const h = skyEff[col] > 0 ? skyEff[col] : buildingH[col];
    const maxR = Math.max(0, Math.floor(h) - 1);
    return [col, Math.min(row, maxR)];
  }

  /* Divide the grid into n equal column-zones, shuffle, assign one zone
     per driver. Row is picked inside that column's visible skyline floors. */
  function placeDrivers(n: number): void {
    const stride = GS / n;
    const ci = Array.from({ length: n }, (_, i) => i);
    for (let i = n - 1; i > 0; i--) {
      const jc = Math.floor(Math.random() * (i + 1)); [ci[i], ci[jc]] = [ci[jc], ci[i]];
    }
    for (let d = 0; d < n; d++) {
      const col = Math.floor(ci[d] * stride + Math.random() * stride);
      const floors = Math.max(1, Math.floor(buildingH[col]));
      const row = Math.floor(Math.random() * floors);
      [driverCols[d], driverRows[d]] = clampToSkyline(col, row);
    }
  }

  placeDrivers(gridParams.nDrivers);

  /* ── Icons overlaid on open driver cells ── */
  const ICONS = [
    '/graphics/icon-about.svg',
    '/graphics/icon-ai-readiness-audit.svg',
    '/graphics/icon-build-and-operate.svg',
    '/graphics/icon-build-sprint.svg',
    '/graphics/icon-build-system.svg',
    '/graphics/icon-command.svg',
    '/graphics/icon-compliance-frame.svg',
    '/graphics/icon-core-diamond.svg',
    '/graphics/icon-corporate-llm.svg',
    '/graphics/icon-diagnose.svg',
    '/graphics/icon-find-use-case.svg',
    '/graphics/icon-focus-monitor.svg',
    '/graphics/icon-fractional-cto.svg',
    '/graphics/icon-layer-stack.svg',
    '/graphics/icon-model-orbits.svg',
    '/graphics/icon-pattern-steps.svg',
    '/graphics/icon-priority-stack.svg',
    '/graphics/icon-reliability-retainer.svg',
    '/graphics/icon-signal-nodes.svg',
    '/graphics/icon-structure-frame.svg',
    '/graphics/icon-system-grid.svg',
    '/graphics/work-cases-mark.svg',
    '/graphics/case-knowledge-agent.svg',
    '/graphics/case-eu-ai-platform.svg',
    '/graphics/case-robot-vision-tooling.svg',
    '/graphics/pattern-agent-ops.svg',
    '/graphics/pattern-open-models.svg',
    '/graphics/pattern-corporate-llm.svg',
    '/graphics/pattern-readiness.svg',
    '/graphics/pattern-retainer.svg',
  ];

  /* Pick a random icon, preferring ones not currently shown by other drivers. */
  function pickIcon(self = -1): string {
    const used = new Set<string>();
    for (let i = 0; i < iconEls.length; i++) {
      if (i === self) continue;
      const src = iconEls[i]?.getAttribute('src');
      if (src) used.add(src);
    }
    const free = ICONS.filter((src) => !used.has(src));
    const pool = free.length > 0 ? free : ICONS;
    return pool[Math.floor(Math.random() * pool.length)];
  }

  /* Use the sibling #grid-labels div; fall back to canvas parent so we
     always have a real DOM container even if the ID lookup misses.      */
  const labelsEl = document.getElementById('grid-labels') ?? canvas!.parentElement;
  const iconEls: HTMLImageElement[] = [];
  for (let d = 0; d < ND; d++) {
    const el = document.createElement('img');
    el.className = 'grid-icon';
    el.alt = '';
    el.draggable = false;
    el.style.opacity = '0';
    labelsEl?.appendChild(el);
    iconEls.push(el);
  }
  /* Warm the image cache so icon swaps don't flash empty frames. */
  for (const src of ICONS) {
    const warm = new Image();
    warm.src = src;
  }
  for (let d = 0; d < ND; d++) iconEls[d].src = pickIcon(d);

  const dpulse = new Float32Array(ND);
  const colW: number[] = new Array(GS).fill(0);
  const rowH: number[] = new Array(GS).fill(0);
  const colsData = new Float32Array(32); /* 8 vec4s: colX[16] + colW[16] */
  const rowsData = new Float32Array(32); /* 8 vec4s: rowY[16] + rowH[16] */
  const drvData  = new Float32Array(32); /* 8 vec4s: (col, row, intensity, _) */

  /* Spring physics state — per-driver */
  const driverDelta = new Float32Array(ND); /* current spring positions (expansions) */
  const driverDV    = new Float32Array(ND); /* spring velocities                     */

  /* Per-track velocity → colour in GLSL */
  const colV      = new Float32Array(GS);
  const rowV      = new Float32Array(GS);
  const colsVData = new Float32Array(16); /* 4 vec4s: colVel[16] */
  const rowsVData = new Float32Array(16); /* 4 vec4s: rowVel[16] */

  let prevUnit = -1; /* track resize so we can reset springs */
  let rafId = 0;

  /* ── Mouse interaction state ──────────────────────────────────── */
  let dragDriver = -1;               /* driver index being dragged, -1 = none   */
  let didDrag    = false;            /* true once pointer moves after pointerdown */

  interface Ghost { col: number; row: number; born: number; }
  const ghosts: Ghost[] = [];
  const MAX_GHOSTS = 4;
  const GHOST_DUR  = 1.5;           /* seconds a click-push ripple lives         */

  /* Convert pointer event → physical canvas px (y-up, matches shader coords) */
  function canvasPhy(e: PointerEvent): [number, number] {
    const dpr  = Math.min(devicePixelRatio || 1, 2);
    const rect = canvas!.getBoundingClientRect();
    return [
      (e.clientX - rect.left) * dpr,
      canvas!.height - (e.clientY - rect.top) * dpr,
    ];
  }

  /* Map physical px → grid [col, row] using the last-rendered layout arrays */
  function pxToCell(px: number, pyUp: number): [number, number] {
    let col = -1, row = -1;
    for (let c = 0; c < GS; c++)
      if (px  >= colsData[c]      && px  < colsData[c]      + colsData[c      + GS]) { col = c; break; }
    for (let r = 0; r < GS; r++)
      if (pyUp >= rowsData[r]     && pyUp < rowsData[r]     + rowsData[r      + GS]) { row = r; break; }
    return [col, row];
  }

  function resize() {
    const dpr = Math.min(devicePixelRatio || 1, 2);
    const w = Math.round(canvas!.clientWidth  * dpr);
    const h = Math.round(canvas!.clientHeight * dpr);
    if (canvas!.width !== w || canvas!.height !== h) {
      canvas!.width  = w;
      canvas!.height = h;
      gl!.viewport(0, 0, w, h);
    }
  }

  function render(ms: number) {
    resize();
    const time = ms * 0.001;
    const cw   = canvas!.width;
    const ch   = canvas!.height;

    /* Full-rectangle grid — fills the entire canvas */
    const dpr     = Math.min(devicePixelRatio || 1, 2);
    const oxPx    = 0;
    const oyPx    = 0;
    const gap     = Math.max(1, Math.round(gridParams.gapCSS * dpr));
    const availW  = cw - (GS + 1) * gap;
    const availH  = ch - (GS + 1) * gap;
    const avail   = Math.min(availW, availH); /* used for spring target only */
    const unit    = avail / GS;              /* base cell size at rest       */

    /* Reset spring state on canvas resize */
    if (Math.abs(unit - prevUnit) > 0.5) {
      driverDelta.fill(0);
      driverDV.fill(0);
      prevUnit = unit;
    }

    /* 1. Target sine-wave pulses (speed-scaled) */
    const nd = Math.min(ND, gridParams.nDrivers);
    for (let d = 0; d < ND; d++) {
      dpulse[d] = Math.sin(time * driverFreq[d] * gridParams.speed + driverPhase[d]);
    }

    /* Icon-only cycle while closed. Driver cells stay put — relocating
       columns was the main source of layout jumps and late flicker. */
    for (let d = 0; d < nd; d++) {
      if (dpulse[d] >= 0) {
        iconArmed[d] = 1;
      } else if (
        d !== dragDriver &&
        iconArmed[d] &&
        dpulse[d] < -0.45 &&
        Math.abs(driverDelta[d]) < 0.5
      ) {
        iconEls[d].src = pickIcon(d);
        iconArmed[d] = 0;
      }
    }

    /* 2. Smooth follow toward pulse target — no spring overshoot/ring. */
    const ease = gridParams.ease;
    for (let d = 0; d < nd; d++) {
      const target = Math.max(0, dpulse[d]) * unit * gridParams.amp;
      driverDelta[d] += (target - driverDelta[d]) * ease;
      driverDV[d] = target - driverDelta[d]; /* retained for colour velocity only */
    }
    for (let d = nd; d < ND; d++) {
      driverDelta[d] += (0 - driverDelta[d]) * ease;
      driverDV[d] = -driverDelta[d];
    }

    /* 3. Layout using smoothed expansions.
          Columns always expand. Rows expand only for right-half drivers
          on floors above the left skyline, so left buildings stay under
          the pixel height cap. */
    const LEFT_MAX_FLOORS = 3;
    for (let i = 0; i < GS; i++) { colW[i] = unit; rowH[i] = unit; }
    for (let d = 0; d < nd; d++) {
      const dc    = driverCols[d];
      const dr    = driverRows[d];
      const delta = driverDelta[d];

      colW[dc] += delta;
      const shareW = delta / (GS - 1);
      for (let c = 0; c < GS; c++) if (c !== dc) colW[c] -= shareW;

      if (dc >= GS / 2 && dr >= LEFT_MAX_FLOORS) {
        rowH[dr] += delta;
        const shareH = delta / (GS - 1);
        for (let r = 0; r < GS; r++) if (r !== dr) rowH[r] -= shareH;
      }
    }

    /* Clamp to 32 CSS-px minimum, then renorm to preserve avail */
    const minCell = Math.round(32 * dpr);
    let tw = 0, th = 0;
    for (let i = 0; i < GS; i++) {
      colW[i] = Math.max(minCell, colW[i]);
      rowH[i] = Math.max(minCell, rowH[i]);
      tw += colW[i]; th += rowH[i];
    }
    for (let i = 0; i < GS; i++) {
      colW[i] = colW[i] * availW / tw;
      rowH[i] = rowH[i] * availH / th;
    }

    /* 4. Per-track velocity (derived from spring velocity, for GLSL colour) */
    colV.fill(0);
    rowV.fill(0);
    for (let d = 0; d < nd; d++) {
      const dc  = driverCols[d];
      const dr  = driverRows[d];
      const vel = driverDV[d];
      colV[dc] += vel;
      const sw = vel / (GS - 1);
      for (let c = 0; c < GS; c++) if (c !== dc) colV[c] -= sw;
      if (dc >= GS / 2 && dr >= LEFT_MAX_FLOORS) {
        rowV[dr] += vel;
        const sh = vel / (GS - 1);
        for (let r = 0; r < GS; r++) if (r !== dr) rowV[r] -= sh;
      }
    }
    for (let i = 0; i < GS; i++) {
      colsVData[i] = colV[i];
      rowsVData[i] = rowV[i];
    }

    /* 4b. Driver bloom field: position + intensity from the sine pulse
           (not spring delta) so colour doesn't ring/flicker with overshoot. */
    for (let d = 0; d < nd; d++) {
      drvData[d * 4]     = driverCols[d];
      drvData[d * 4 + 1] = driverRows[d];
      drvData[d * 4 + 2] = Math.max(0, Math.min(1, dpulse[d]));
      drvData[d * 4 + 3] = 0;
    }

    /* Interaction 2: click-push ghosts — short-lived bloom ripples at clicked cell */
    let totalDrv = nd;
    for (let g = ghosts.length - 1; g >= 0; g--) {
      const ghost = ghosts[g];
      const age   = time - ghost.born;
      if (age > GHOST_DUR) { ghosts.splice(g, 1); continue; }
      if (totalDrv >= 8) break;
      const t         = age / GHOST_DUR;
      const intensity = Math.sin(t * Math.PI);
      drvData[totalDrv * 4]     = ghost.col;
      drvData[totalDrv * 4 + 1] = ghost.row;
      drvData[totalDrv * 4 + 2] = intensity * 0.85;
      drvData[totalDrv * 4 + 3] = 0;
      totalDrv++;
    }

    /* 3. Cumulative positions + pack into uniform float32 buffers.
          colsData layout: [colX × 16, colW × 16] = 32 floats → 8 vec4s
          rowsData layout: [rowY × 16, rowH × 16] (y from grid bottom, y-up)
          All coordinates are grid-local; GLSL subtracts (ox, oy) itself. */
    let cx = gap;    /* first cell starts after the left border gap */
    for (let c = 0; c < GS; c++) {
      colsData[c]      = cx;       /* colX */
      colsData[c + GS] = colW[c];  /* colW */
      cx += colW[c] + gap;
    }

    let ry = gap;    /* first row starts after the bottom border gap */
    for (let r = 0; r < GS; r++) {
      rowsData[r]      = ry;       /* rowY */
      rowsData[r + GS] = rowH[r];  /* rowH */
      ry += rowH[r] + gap;
    }

    /* Cap left-half buildings using a frozen rest-layout floor budget
       (recomputed only on resize) so spring motion can't pop floors on/off. */
    const unitRest = availH / GS;
    const sizeKey = `${cw}x${ch}x${dpr}`;
    if (sizeKey !== skySizeKey) {
      skySizeKey = sizeKey;
      refreshLeftFloorsCap(gap, unitRest, dpr);
    }
    for (let c = 0; c < GS; c++) {
      skyEff[c] = c < GS / 2
        ? Math.min(buildingH[c], leftFloorsCap)
        : buildingH[c];
    }
    /* Keep drivers inside the effective skyline after the left cap. */
    for (let d = 0; d < nd; d++) {
      [driverCols[d], driverRows[d]] = clampToSkyline(driverCols[d], driverRows[d]);
      drvData[d * 4]     = driverCols[d];
      drvData[d * 4 + 1] = driverRows[d];
      drvData[d * 4 + 2] = Math.max(0, Math.min(1, dpulse[d]));
      drvData[d * 4 + 3] = 0;
    }

    /* 5. Upload and draw */
    gl!.useProgram(prog);
    gl!.bindVertexArray(vao);
    gl!.uniform2f(uRes,  cw, ch);
    gl!.uniform1f(uUnit, unit);
    gl!.uniform4fv(uCols,  colsData);
    gl!.uniform4fv(uRows,  rowsData);
    gl!.uniform4fv(uColsV, colsVData);
    gl!.uniform4fv(uRowsV, rowsVData);
    gl!.uniform4fv(uDrv,      drvData);
    gl!.uniform1i(uDrvN,      totalDrv);
    gl!.uniform1f(uLimeSeed,  limeSeed);
    gl!.uniform4fv(uSky,      skyEff);
    gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
    gl!.bindVertexArray(null);

    /* 6. Update icon positions to follow driver cells.
          The overlay (#grid-labels, inset:0) fills .hero-graphic,
          which can be taller than the canvas, so the canvas is
          centred inside it. Offset by the canvas's position so icons
          align to the canvas, not the container. */
    const offL = canvas!.offsetLeft;
    const offT = canvas!.offsetTop;
    for (let d = 0; d < ND; d++) {
      const el = iconEls[d];
      if (d >= nd) { el.style.opacity = '0'; continue; }
      const dc = driverCols[d];
      const dr = driverRows[d];
      /* Hide if the driver sits above this column's skyline. */
      if (dr >= skyEff[dc]) { el.style.opacity = '0'; continue; }
      /* Centre of the driver cell in physical px */
      const cxPhys = oxPx + colsData[dc] + colW[dc] * 0.5;
      const cyPhys = ch - (oyPx + rowsData[dr] + rowH[dr] * 0.5); /* flip y to CSS top-down */
      /* Convert physical→CSS px, then offset to the canvas origin */
      el.style.left = (offL + cxPhys / dpr) + 'px';
      el.style.top  = (offT + cyPhys / dpr) + 'px';
      /* Size: ~55% of the smaller cell edge, capped so it stays inside */
      const cellCssPx = Math.min(colW[dc], rowH[dr]) / dpr;
      const size      = Math.max(14, Math.min(cellCssPx * 0.55, cellCssPx - 6));
      el.style.width  = size + 'px';
      el.style.height = size + 'px';
      /* Fade with sine pulse (same as bloom) so opacity doesn't ring with the spring. */
      el.style.opacity = String(Math.min(1, Math.max(0, dpulse[d]) * 2.2));
    }

    if (!reducedMotion) rafId = requestAnimationFrame(render);
  }

  if (reducedMotion) {
    resize();
    render(0);
  } else {
    rafId = requestAnimationFrame(render);
  }

  /* Pause when off-screen */
  const obs = new IntersectionObserver(entries => {
    const vis = entries[0].isIntersecting;
    if (vis && !reducedMotion) {
      if (!rafId) rafId = requestAnimationFrame(render);
    } else {
      cancelAnimationFrame(rafId);
      rafId = 0;
    }
  }, { threshold: 0 });
  obs.observe(canvas);

  /* Pause when tab is hidden */
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      cancelAnimationFrame(rafId);
      rafId = 0;
    } else if (!reducedMotion) {
      if (!rafId) rafId = requestAnimationFrame(render);
    }
  });

  /* ── Pointer event listeners ──────────────────────────────────── */
  canvas!.style.cursor = 'crosshair';

  canvas!.addEventListener('pointermove', (e: PointerEvent) => {
    const [px, py] = canvasPhy(e);
    if (dragDriver >= 0) {
      didDrag = true;
      const [col, row] = pxToCell(px, py);
      if (col >= 0 && row >= 0) {
        [driverCols[dragDriver], driverRows[dragDriver]] = clampToSkyline(col, row);
      } else if (col >= 0) {
        driverCols[dragDriver] = col;
        driverRows[dragDriver] = Math.min(driverRows[dragDriver], Math.max(0, Math.floor(buildingH[col]) - 1));
      }
      canvas!.style.cursor = 'grabbing';
    } else {
      /* Show grab cursor when hovering within 2 cells of any driver */
      const [mc, mr] = pxToCell(px, py);
      const curNd = Math.min(ND, gridParams.nDrivers);
      let near = false;
      if (mc >= 0 && mr >= 0) {
        for (let d = 0; d < curNd; d++) {
          if (Math.abs(driverCols[d] - mc) + Math.abs(driverRows[d] - mr) < 2) { near = true; break; }
        }
      }
      canvas!.style.cursor = near ? 'grab' : 'crosshair';
    }
  });

  canvas!.addEventListener('pointerdown', (e: PointerEvent) => {
    canvas!.setPointerCapture(e.pointerId);
    const [px, py] = canvasPhy(e);
    didDrag = false;
    const curNd = Math.min(ND, gridParams.nDrivers);
    const [col, row] = pxToCell(px, py);
    /* Grab the nearest driver within Manhattan distance 2 */
    let best = -1, bestDist = 3;
    for (let d = 0; d < curNd; d++) {
      const dist = Math.abs(driverCols[d] - col) + Math.abs(driverRows[d] - row);
      if (dist < bestDist) { bestDist = dist; best = d; }
    }
    dragDriver = best;
    if (dragDriver >= 0) canvas!.style.cursor = 'grabbing';
  });

  canvas!.addEventListener('pointerup', (e: PointerEvent) => {
    if (dragDriver < 0 && !didDrag) {
      /* Clean click on empty space → ghost impulse ripple */
      const [px, py] = canvasPhy(e);
      const [col, row] = pxToCell(px, py);
      if (col >= 0 && row >= 0 && row < skyEff[col]) {
        if (ghosts.length >= MAX_GHOSTS) ghosts.shift();
        ghosts.push({ col, row, born: performance.now() * 0.001 });
      }
    }
    dragDriver = -1;
    didDrag    = false;
    canvas!.style.cursor = 'crosshair';
  });

  canvas!.addEventListener('pointerleave', () => {
    dragDriver = -1;
    canvas!.style.cursor = 'crosshair';
  });
})();


/* ── Mobile nav toggle ── */
const navToggle = document.getElementById('nav-toggle') as HTMLButtonElement;
const navLinks  = document.getElementById('nav-links')  as HTMLElement;

function closeNav() {
  navLinks.classList.remove('is-open');
  navToggle.setAttribute('aria-expanded', 'false');
  navToggle.setAttribute('aria-label', 'Open menu');
}

navToggle.addEventListener('click', () => {
  const isOpen = navLinks.classList.toggle('is-open');
  navToggle.setAttribute('aria-expanded', String(isOpen));
  navToggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
});

navLinks.querySelectorAll('a').forEach(a => a.addEventListener('click', closeNav));

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeNav(); });

/* ── Nav transparency on scroll ── */
const siteNavEl   = document.querySelector('.site-nav') as HTMLElement;

function refreshNav() {
  const heroEl = document.querySelector('.hero') as HTMLElement;
  const thresh = (heroEl?.offsetHeight ?? 600) - 80;
  siteNavEl?.classList.toggle('is-scrolled', window.scrollY > thresh);
}

window.addEventListener('scroll', refreshNav, { passive: true });
/* Defer initial call so layout has fully painted */
requestAnimationFrame(refreshNav);
</script>
