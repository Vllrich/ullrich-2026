---
import DiagnoseIcon from './DiagnoseIcon.astro';
import LocaleSwitch from './LocaleSwitch.astro';
import {
  landingAuditHref,
  landingCopy,
  landingImpressumHref,
  landingLocaleSwitchHref,
  landingNotesHref,
  landingWorkIndexHref,
  type LandingLang,
} from '../data/landing';

interface Props {
  lang?: LandingLang;
}

const { lang = 'en' } = Astro.props;
const t = landingCopy(lang);
const f = t.contact.form;
const year = new Date().getFullYear();

const EMAILJS_PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;
const EMAILJS_SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
const EMAILJS_TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;

const socials = [
  { label: 'GitHub',    href: 'https://github.com/Vllrich' },
  { label: 'Instagram', href: 'https://www.instagram.com/vllrich/' },
  { label: 'LinkedIn',  href: 'https://www.linkedin.com/in/lars-ullrich-47338a27/' },
];
---

<section id={t.ids.contact} class="contact-section">

  <div class="contact-inner">
    <div class="contact-left">
      <h2 class="contact-display fade-up" data-delay="0">
        {t.contact.displayLine1}<br/>{t.contact.displayLine2}
      </h2>

      <p class="contact-intro fade-up" data-delay="120">
        {t.contact.intro}
      </p>

      <p class="contact-note fade-in" data-delay="240">
        {t.contact.noteStart}
        <a href={landingAuditHref(lang)}>{t.contact.noteAudit}</a>
        {t.contact.noteAuditSuffix}
      </p>

      <p class="contact-note fade-in" data-delay="320">
        {t.contact.availability}
      </p>
    </div>

    <div class="contact-right fade-up" data-delay="200">
      <div class="cf-slot" id="cf-slot">
        <form id="contact-form" class="contact-form" novalidate
          data-ejs-key={EMAILJS_PUBLIC_KEY ?? ''}
          data-ejs-service={EMAILJS_SERVICE_ID ?? ''}
          data-ejs-template={EMAILJS_TEMPLATE_ID ?? ''}
          data-label-submit={f.submit}
          data-label-sending={f.sending}
          data-label-try-again={f.tryAgain}
          data-label-closes-in={f.closesIn}
          data-err-name={f.errName}
          data-err-email={f.errEmail}
          data-err-email-invalid={f.errEmailInvalid}
          data-err-subject={f.errSubject}
          data-err-message={f.errMessage}
          data-err-message-short={f.errMessageShort}
        >
          <input type="text" name="_hp" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden" />
          <div class="form-row">
            <div class="form-group">
              <label for="cf-name">{f.name}</label>
              <input type="text" id="cf-name" name="name" placeholder={f.namePh} required autocomplete="name" />
              <span class="form-error" id="err-name"></span>
            </div>
            <div class="form-group">
              <label for="cf-email">{f.email}</label>
              <input type="email" id="cf-email" name="email" placeholder={f.emailPh} required autocomplete="email" />
              <span class="form-error" id="err-email"></span>
            </div>
          </div>
          <div class="form-group">
            <label for="cf-subject">{f.subject}</label>
            <input type="text" id="cf-subject" name="subject" placeholder={f.subjectPh} required />
            <span class="form-error" id="err-subject"></span>
          </div>
          <div class="form-group">
            <label for="cf-message">{f.message}</label>
            <textarea id="cf-message" name="message" rows="5" placeholder={f.messagePh} required></textarea>
            <span class="form-error" id="err-message"></span>
          </div>
          <button type="submit" id="cf-submit" class="cf-btn">
            <span class="btn-label">{f.submit}</span>
            <svg class="btn-spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" opacity="0.25"/>
              <path fill="currentColor" opacity="0.75" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
            </svg>
          </button>
          <p class="cf-feedback" id="cf-error" role="alert" aria-live="assertive" style="display:none">
            {f.error}
          </p>
        </form>

        <div
          id="cf-success"
          class="cf-success"
          role="status"
          aria-live="polite"
          aria-labelledby="cf-success-title"
          hidden
        >
          <p class="cf-success-mark" aria-hidden="true">✓</p>
          <h3 id="cf-success-title" class="cf-success-title">{f.successTitle}</h3>
          <p class="cf-success-body">
            {f.successBody}
          </p>
          <button type="button" class="cf-btn cf-success-close" id="cf-success-close">
            {f.close}
          </button>
          <p class="cf-success-timer" id="cf-success-timer" aria-hidden="true">{f.closesIn} 15s</p>
        </div>
      </div>
    </div>
  </div>

  <footer class="site-footer">
    <div class="footer-brand">
      <span class="footer-logo">LARS ULLRICH</span>
      <DiagnoseIcon size="sm" class="footer-mark" />
      <p class="footer-desc">{t.contact.footer.tagline}</p>
    </div>

    <nav class="footer-links" aria-label={t.contact.footer.navLabel}>
      {socials.map(s => (
        <a href={s.href} target="_blank" rel="noopener noreferrer">{s.label}</a>
      ))}
      <LocaleSwitch lang={lang} href={landingLocaleSwitchHref(lang)} variant="lime" />
      <a href={landingWorkIndexHref(lang)}>{t.contact.footer.work}</a>
      <a href={landingNotesHref(lang)}>{t.contact.footer.notes}</a>
      <a href="/about/">{t.contact.footer.about}</a>
      <a href={landingImpressumHref(lang)}>Impressum</a>
    </nav>

    <span class="footer-copy">&copy; {year} Lars Ullrich. {t.contact.footer.copyright}</span>
  </footer>

</section>

<style>
  .contact-section {
    background: #2C303C;
    position: relative;
    overflow: hidden;
  }

  /* Diagonal soft-light gradient overlay */
  .contact-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(35, 31, 32, 0.35) 0%,
      rgba(255, 255, 255, 0.10) 100%
    );
    mix-blend-mode: soft-light;
    pointer-events: none;
    z-index: 0;
  }

  .contact-section > * { position: relative; z-index: 1; }

  /* ── Main layout ── */
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3.5rem);
    border-bottom: 1px dotted rgba(255,255,255,0.15);
    align-items: start;
  }

  /* ── Left column ── */
  .contact-display {
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.0;
    color: #ffffff;
    text-transform: uppercase;
    margin-bottom: 1.75rem;
    text-wrap: balance;
  }

  .contact-intro {
    font-size: var(--text-body-size, 1rem);
    font-weight: 400;
    line-height: var(--text-body-lh, 1.875);
    color: rgba(255,255,255,0.7);
    max-width: 44ch;
    margin-bottom: 2rem;
  }

  .contact-note {
    font-size: var(--text-note-size, 0.875rem);
    font-weight: 400;
    line-height: var(--text-note-lh, 1.8);
    color: rgba(255,255,255,0.5);
    max-width: 42ch;
  }

  .contact-note a {
    color: var(--cobalt, #bbdd00);
    text-decoration: none;
  }

  .contact-note a:hover {
    text-decoration: underline;
  }

  /* ── Form slot (same footprint for form + success) ── */
  .cf-slot {
    display: grid;
    align-items: stretch;
  }

  .cf-slot > .contact-form,
  .cf-slot > .cf-success {
    grid-area: 1 / 1;
    width: 100%;
  }

  .contact-form[hidden],
  .cf-success[hidden] {
    display: none;
  }

  /* ── Form ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .form-group label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
  }

  .form-group input,
  .form-group textarea {
    font-size: 0.9rem;
    font-weight: 400;
    color: #ffffff;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.18);
    padding: 0.7rem 0.9rem;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    resize: none;
    font-family: inherit;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: rgba(255,255,255,0.3);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: #bbdd00;
    background: rgba(255,255,255,0.12);
  }

  .form-group input.is-invalid,
  .form-group textarea.is-invalid { border-color: oklch(55% 0.2 25); }

  .form-error {
    font-size: 0.62rem;
    color: oklch(50% 0.2 25);
    min-height: 1em;
  }

  /* ── Submit button ── */
  .cf-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: inherit;
    font-weight: 700;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink, #2C303C);
    background: var(--cobalt, #bbdd00);
    border: 1px solid var(--cobalt, #bbdd00);
    padding: 0.9rem 2rem;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    align-self: flex-start;
  }
  .cf-btn:hover:not(:disabled) {
    background: var(--cobalt-dim, #8aaa00);
    border-color: var(--cobalt-dim, #8aaa00);
  }
  .cf-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .cf-btn.is-success { background: oklch(55% 0.15 145); border-color: oklch(55% 0.15 145); }
  .cf-btn.is-error   { background: oklch(55% 0.2 25); border-color: oklch(55% 0.2 25); }

  .btn-spinner {
    display: none;
    width: 1rem;
    height: 1rem;
    animation: spin 0.8s linear infinite;
  }
  .cf-btn.is-loading .btn-spinner { display: block; }
  .cf-btn.is-loading .btn-label { opacity: 0.6; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .cf-feedback {
    font-size: 0.75rem;
    color: oklch(50% 0.2 25);
  }
  .cf-feedback a { color: inherit; }

  /* ── In-place success (same slot as form) ── */
  .cf-success {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.85rem;
    box-sizing: border-box;
    padding: 0.25rem 0;
  }

  .cf-success-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    margin: 0;
    background: var(--cobalt, #bbdd00);
    color: var(--ink, #2C303C);
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1;
  }

  .cf-success-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #ffffff;
    margin: 0;
  }

  .cf-success-body {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.72);
    margin: 0;
    max-width: 36ch;
  }

  .cf-success-close {
    align-self: flex-start;
    margin-top: 0.35rem;
  }

  .cf-success-timer {
    margin: 0;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.4);
  }

  @media (prefers-reduced-motion: no-preference) {
    .cf-success:not([hidden]) {
      animation: cf-success-in 0.22s ease;
    }
  }

  @keyframes cf-success-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ── Footer — green ── */
  .site-footer {
    padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 4vw, 3.5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    background: #bbdd00;
    border-top: none;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.45rem;
  }

  .footer-logo {
    font-weight: 800;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    color: var(--ink, #2C303C);
  }

  .footer-mark {
    width: 3.25rem !important;
    height: 3.25rem !important;
    max-width: none !important;
  }

  /* Lime faces vanish on the lime footer bar; use ink for lit faces. */
  .footer-mark :global(.tri:not(.is-off)) {
    fill: var(--ink, #2c303c);
  }

  .footer-desc {
    font-size: 0.68rem;
    font-weight: 400;
    color: oklch(28% 0.010 258);
    line-height: 1.6;
  }

  .footer-links {
    display: flex;
    gap: 1.75rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer-links > a {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: oklch(22% 0.01 258);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links > a:hover { color: var(--ink, #2C303C); }

  .footer-copy {
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: oklch(30% 0.008 258);
    white-space: nowrap;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .contact-inner { grid-template-columns: 1fr; }
    .site-footer { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
  }
  @media (max-width: 640px) {
    .form-row { grid-template-columns: 1fr; }
    .cf-btn { align-self: stretch; }
    .footer-links { gap: 1.25rem; }
  }
</style>

<script>
  import emailjs from '@emailjs/browser';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const ds = form.dataset;
  const { ejsKey, ejsService, ejsTemplate } = ds as any;
  emailjs.init(ejsKey);

  const labelSubmit = ds.labelSubmit || 'Request a scope call';
  const labelSending = ds.labelSending || 'Sending...';
  const labelTryAgain = ds.labelTryAgain || 'Try Again';
  const labelClosesIn = ds.labelClosesIn || 'Closes in';

  const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement;
  const btnLabel = submitBtn.querySelector('.btn-label') as HTMLElement;
  const errorBox = document.getElementById('cf-error') as HTMLElement;
  const slot = document.getElementById('cf-slot') as HTMLElement;
  const successPanel = document.getElementById('cf-success') as HTMLElement;
  const successClose = document.getElementById('cf-success-close') as HTMLButtonElement;
  const successTimer = document.getElementById('cf-success-timer') as HTMLElement;
  const SUCCESS_MS = 15000;
  let successTimeout: ReturnType<typeof setTimeout> | null = null;
  let successInterval: ReturnType<typeof setInterval> | null = null;

  function clearSuccessTimers() {
    if (successTimeout) clearTimeout(successTimeout);
    if (successInterval) clearInterval(successInterval);
    successTimeout = null;
    successInterval = null;
  }

  function showSuccess() {
    const height = form.offsetHeight;
    slot.style.minHeight = `${height}px`;
    form.hidden = true;
    form.setAttribute('aria-hidden', 'true');
    successPanel.hidden = false;
    successClose.focus();

    let remaining = Math.round(SUCCESS_MS / 1000);
    successTimer.textContent = `${labelClosesIn} ${remaining}s`;
    clearSuccessTimers();
    successInterval = setInterval(() => {
      remaining -= 1;
      if (remaining <= 0) {
        successTimer.textContent = '...';
        return;
      }
      successTimer.textContent = `${labelClosesIn} ${remaining}s`;
    }, 1000);
    successTimeout = setTimeout(() => hideSuccess(), SUCCESS_MS);
  }

  function hideSuccess() {
    if (successPanel.hidden) return;
    clearSuccessTimers();
    successPanel.hidden = true;
    form.hidden = false;
    form.removeAttribute('aria-hidden');
    slot.style.minHeight = '';
    submitBtn.classList.remove('is-success', 'is-loading');
    btnLabel.textContent = labelSubmit;
    submitBtn.disabled = false;
    submitBtn.focus();
  }

  successClose.addEventListener('click', () => hideSuccess());

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !successPanel.hidden) {
      e.preventDefault();
      hideSuccess();
    }
  });

  function setError(fieldId: string, errId: string, msg: string) {
    const el  = document.getElementById(fieldId) as HTMLElement;
    const err = document.getElementById(errId)   as HTMLElement;
    if (msg) { el.classList.add('is-invalid'); err.textContent = msg; }
    else      { el.classList.remove('is-invalid'); err.textContent = ''; }
  }

  function validate(data: Record<string,string>) {
    let ok = true;
    if (!data.name.trim())    { setError('cf-name','err-name', ds.errName || 'Name is required'); ok=false; }
    else setError('cf-name','err-name','');
    if (!data.email.trim())   { setError('cf-email','err-email', ds.errEmail || 'Email is required'); ok=false; }
    else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) { setError('cf-email','err-email', ds.errEmailInvalid || 'Please enter a valid email'); ok=false; }
    else setError('cf-email','err-email','');
    if (!data.subject.trim()) { setError('cf-subject','err-subject', ds.errSubject || 'Subject is required'); ok=false; }
    else setError('cf-subject','err-subject','');
    if (!data.message.trim()) { setError('cf-message','err-message', ds.errMessage || 'Message is required'); ok=false; }
    else if (data.message.length < 10) { setError('cf-message','err-message', ds.errMessageShort || 'At least 10 characters'); ok=false; }
    else setError('cf-message','err-message','');
    return ok;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    // Honeypot check — bots fill hidden fields, humans don't
    const hp = (form.querySelector('[name="_hp"]') as HTMLInputElement)?.value;
    if (hp) return;
    const data = {
      name:    (document.getElementById('cf-name')    as HTMLInputElement).value,
      email:   (document.getElementById('cf-email')   as HTMLInputElement).value,
      subject: (document.getElementById('cf-subject') as HTMLInputElement).value,
      message: (document.getElementById('cf-message') as HTMLTextAreaElement).value,
    };
    if (!validate(data)) return;

    submitBtn.disabled = true;
    submitBtn.classList.add('is-loading');
    btnLabel.textContent = labelSending;
    errorBox.style.display = 'none';

    try {
      const res = await emailjs.send(ejsService, ejsTemplate, {
        to_name:    'Lars Ullrich',
        from_name:  data.name,
        from_email: data.email,
        message:    `Subject: ${data.subject}\n\n${data.message}`,
        to_email:   'contact@larsullrich.de',
      });
      if (res.status === 200) {
        submitBtn.classList.remove('is-loading');
        form.reset();
        showSuccess();
      } else { throw new Error(); }
    } catch {
      submitBtn.classList.remove('is-loading');
      submitBtn.classList.add('is-error');
      btnLabel.textContent = labelTryAgain;
      errorBox.style.display = 'block';
      submitBtn.disabled = false;
      setTimeout(() => {
        submitBtn.classList.remove('is-error');
        btnLabel.textContent = labelSubmit;
      }, 5000);
    }
  });
</script>
