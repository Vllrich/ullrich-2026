---
import ContentPage from '../../../layouts/ContentPage.astro';
import WorkEntryDetail from '../../../components/WorkEntryDetail.astro';
import { languageAlternates } from '../../../lib/i18n';
import { allWorkEntries, localizeWorkEntry, workHref } from '../../../data/work-patterns';

export function getStaticPaths() {
  return allWorkEntries().map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const item = localizeWorkEntry(entry, 'de');
const canonical = workHref(entry.id, 'de');
const enHref = workHref(entry.id, 'en');
const alternates = languageAlternates(enHref, canonical);
const kind = item.caseStudyReady ? 'Case Study' : 'Einsatzmuster';
const description = `${kind}: ${item.title}. ${item.blurb.slice(0, 140)}…`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  '@id': `https://larsullrich.de${canonical}#work`,
  url: `https://larsullrich.de${canonical}`,
  name: item.title,
  description: item.blurb,
  inLanguage: 'de',
  author: { '@id': 'https://larsullrich.de/#person' },
  isPartOf: { '@id': 'https://larsullrich.de/de/arbeit/muster/#webpage' },
  about: item.sector,
};
---

<ContentPage
  title={`${item.title} - Lars Ullrich`}
  description={description}
  canonical={canonical}
  noteId="patterns-de"
  lang="de"
  heading={item.title}
  eyebrow={kind}
  lead={item.clientLabel ?? item.sector}
  icon={item.image}
  alternates={alternates}
  jsonLd={jsonLd}
  localeSwitch={{ href: enHref, label: 'English' }}
  layout="wide"
>
  <WorkEntryDetail entry={entry} lang="de" />
</ContentPage>
