---
import ContentPage from '../layouts/ContentPage.astro';
import { languageAlternates } from '../lib/i18n';

const description = 'Legal notice (Impressum) for larsullrich.de. Lars Ullrich, Berlin.';
const alternates = languageAlternates('/impressum/', '/de/impressum/');
---

<ContentPage
