# EmailJS configuration
# Get these from https://dashboard.emailjs.com/
# These are PUBLIC keys — safe to commit example values
PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx

# Feature flags
# Set to "true" to show the maintenance page instead of the main site
PUBLIC_MAINTENANCE_MODE=false
