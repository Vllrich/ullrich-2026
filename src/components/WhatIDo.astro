---
const beats = [
  {
    title: 'Find the right use case',
    body: 'Not every problem needs AI, and not every AI needs a custom model. I help you pick the few use cases that pay for themselves.',
  },
  {
    title: 'Build the system',
    body: 'RAG, agents, automation, and clean integrations — architected for reliability, observability, and cost control from day one.',
  },
  {
    title: 'Own the outcome',
    body: 'As an embedded technical lead I carry the result, not just the deliverable — architecture, team, delivery, and what happens after launch.',
  },
];
---

<section id="what-i-do" class="wid-section">

  <div class="wid-intro fade-up" data-delay="80">
    <p class="wid-statement">
      I work as a fractional CTO/CAIO and hands-on builder for teams adopting AI. From the first use case to a production system, I own the technical decisions that make AI dependable, cost-aware, and genuinely useful.
    </p>
    <p class="wid-sub">
      Twenty years building software where failure was never an option — real-time audio, live performance, GPU pipelines, industrial robotics — taught me one rule: it has to work the first time, every time. <strong>I was training models and shipping generative systems before the current wave</strong> — which means I understand the technology from the inside, not from a pitch deck.
    </p>
  </div>

  <div class="wid-beats">
    {beats.map((b, i) => (
      <div class="beat fade-up" data-delay={String(160 + i * 80)}>
        <h3 class="beat-title">{b.title}</h3>
        <p class="beat-body">{b.body}</p>
      </div>
    ))}
  </div>

</section>

<style>
  .wid-section {
    background: var(--white, oklch(99% 0 0));
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3.5rem);
    border-bottom: 1px solid var(--rule, oklch(87% 0.005 260));
  }

  /* ── Full-width intro ── */
  .wid-intro {
    border-top: 2px solid var(--ink, oklch(10% 0.012 258));
    padding-top: clamp(2.5rem, 4vw, 3.5rem);
    margin-bottom: clamp(3rem, 5vw, 5rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  .wid-statement {
    font-size: clamp(1.1rem, 1.7vw, 1.25rem);
    font-weight: 500;
    line-height: 1.7;
    color: var(--ink, oklch(10% 0.012 258));
    max-width: 52ch;
  }

  .wid-sub {
    font-size: clamp(1rem, 1.4vw, 1.1rem);
    font-weight: 400;
    line-height: 1.85;
    color: var(--dim, oklch(28% 0.010 258));
    max-width: 52ch;
  }

  .wid-sub strong {
    font-weight: 700;
    color: var(--ink, oklch(10% 0.012 258));
  }

  /* ── Three beats — horizontal row ── */
  .wid-beats {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    border-top: 1px solid var(--rule, oklch(87% 0.005 260));
  }

  .beat {
    padding: clamp(2rem, 3.5vw, 3rem) clamp(1.5rem, 2.5vw, 2.5rem);
    border-right: 1px solid var(--rule, oklch(87% 0.005 260));
  }
  .beat:first-child { padding-left: 0; }
  .beat:last-child  { border-right: none; padding-right: 0; }

  .beat-title {
    font-size: clamp(1.15rem, 2vw, 1.6rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink, oklch(10% 0.012 258));
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .beat-body {
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.8;
    color: var(--dim, oklch(28% 0.010 258));
    max-width: 36ch;
  }

  @media (max-width: 1000px) {
    .wid-intro { grid-template-columns: 1fr; }
  }

  @media (max-width: 760px) {
    .wid-beats {
      grid-template-columns: 1fr;
    }
    .beat {
      border-right: none;
      border-bottom: 1px solid var(--rule, oklch(87% 0.005 260));
      padding: 2rem 0;
    }
    .beat:last-child { border-bottom: none; }
  }
</style>
