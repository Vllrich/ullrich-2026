---
const beats = [
  {
    title: 'Find the right use case',
    body: 'Not every problem needs AI, and not every AI needs a custom model. I help you pick the few use cases that pay for themselves.',
  },
  {
    title: 'Build the system',
    body: 'RAG, agents, automation - and the applications and integrations around them, architected for reliability, observability, and cost control.',
  },
  {
    title: 'Implementation, not just advice',
    body: 'The engagement includes code, architecture reviews, and production debugging. I work in the repository with the team, not from the outside.',
  },
];
---

<section id="what-i-do" class="wid-section">
  <h2 class="visually-hidden">What I do</h2>

  <div class="wid-intro fade-up" data-delay="80">
    <p class="wid-statement">
      For teams adopting AI, I own the technical decisions from the first use case to a production system: what to build, what to buy, what it costs to run, and who maintains it after launch. Strategy when you need it - and the engineering when you need that too.
    </p>
    <p class="wid-sub">
      Real-time audio, live performance, GPU pipelines, industrial robotics - systems where there's no second take. That's the standard I bring to AI in production.
    </p>
  </div>

  <div class="wid-beats">
    {beats.map((b, i) => (
      <div class="beat fade-up" data-delay={String(160 + i * 80)}>
        <h3 class="beat-title">{b.title}</h3>
        <p class="beat-body">{b.body}</p>
      </div>
    ))}
  </div>

</section>

<style>
  .wid-section {
    background: var(--white, oklch(99% 0 0));
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3.5rem);
    border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
  }

  /* ── Full-width intro ── */
  .wid-intro {

    padding-top: clamp(2.5rem, 4vw, 3.5rem);
    margin-bottom: clamp(3rem, 5vw, 5rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  .wid-statement {
    font-size: var(--text-lead-size, clamp(1rem, 1.5vw, 1.125rem));
    font-weight: 500;
    line-height: var(--text-lead-lh, 1.7);
    color: var(--ink, oklch(10% 0.012 258));
    max-width: 52ch;
  }

  .wid-sub {
    font-size: var(--text-body-size, 1rem);
    font-weight: 400;
    line-height: var(--text-body-lh, 1.875);
    color: var(--dim, oklch(28% 0.010 258));
    max-width: 52ch;
  }

  .wid-sub strong {
    font-weight: 700;
    color: var(--ink, oklch(10% 0.012 258));
  }

  /* ── Three beats - horizontal row ── */
  .wid-beats {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    border-top: 1px dotted var(--rule, oklch(87% 0.005 260));
  }

  .beat {
    padding: clamp(2rem, 3.5vw, 3rem) clamp(1.5rem, 2.5vw, 2.5rem);
    border-right: 1px dotted var(--rule, oklch(87% 0.005 260));
  }
  .beat:first-child { padding-left: 0; }
  .beat:last-child  { border-right: none; padding-right: 0; }

  .beat-title {
    font-size: clamp(1.15rem, 2vw, 1.6rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink, oklch(10% 0.012 258));
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .beat-body {
    font-size: var(--text-body-size, 1rem);
    font-weight: 400;
    line-height: var(--text-body-lh, 1.875);
    color: var(--dim, oklch(28% 0.010 258));
    max-width: 36ch;
  }

  @media (max-width: 1000px) {
    .wid-intro { grid-template-columns: 1fr; }
  }

  @media (max-width: 760px) {
    .wid-beats {
      grid-template-columns: 1fr;
    }
    .beat {
      border-right: none;
      border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
      padding: 2rem 0;
    }
    .beat:last-child { border-bottom: none; }
  }
</style>
