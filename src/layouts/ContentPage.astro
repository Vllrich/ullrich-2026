---
import Layout from './Layout.astro';
import type { AlternateLink } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  canonical: string;
  lang?: 'en' | 'de';
  alternates?: AlternateLink[];
  jsonLd?: Record<string, unknown>;
  homeHref?: string;
  backLabel?: string;
  contactHref?: string;
  ctaLabel?: string;
  localeSwitch?: { href: string; label: string };
}

const {
  title,
  description,
  canonical,
  lang = 'en',
  alternates = [],
  jsonLd,
  homeHref = '/',
  backLabel = '← Back to home',
  contactHref = '/#contact',
  ctaLabel = 'Start with a Readiness Audit',
  localeSwitch,
} = Astro.props;
---

<Layout title={title} description={description} canonical={canonical} lang={lang} alternates={alternates}>
  <main class="content-page">
    <div class="container">
      <div class="top-row">
        <a href={homeHref} class="back-link">{backLabel}</a>
        {localeSwitch && (
          <a href={localeSwitch.href} class="locale-switch" hreflang={lang === 'en' ? 'de' : 'en'}>
            {localeSwitch.label}
          </a>
        )}
      </div>
      <slot />
      <p class="cta">
        <a href={contactHref}>{ctaLabel}</a>
      </p>
    </div>
  </main>
  {jsonLd && (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  )}
</Layout>

<style>
  .content-page {
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3.5rem);
  }

  .container {
    max-width: 70ch;
    margin: 0 auto;
  }

  .top-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .back-link,
  .locale-switch {
    color: var(--cobalt, #bbdd00);
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.01em;
    transition: opacity 0.15s ease;
  }

  .back-link:hover,
  .locale-switch:hover {
    text-decoration: underline;
    opacity: 0.8;
  }

  .locale-switch {
    font-weight: 600;
  }

  .content-page :global(h1) {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--ink, #2C303C);
    line-height: 1.1;
    margin: 0 0 1.5rem;
  }

  .content-page :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    font-weight: 700;
    color: var(--ink, #2C303C);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 2.5rem 0 0.875rem;
  }

  .content-page :global(h3) {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--ink, #2C303C);
    margin: 1.75rem 0 0.5rem;
  }

  .content-page :global(p),
  .content-page :global(li) {
    color: var(--dim, oklch(28% 0.01 258));
    font-size: 1rem;
    line-height: 1.875;
    margin: 0 0 1rem;
  }

  .content-page :global(ul) {
    margin: 0 0 1rem;
    padding-left: 1.25rem;
  }

  .content-page :global(a) {
    color: var(--cobalt, #bbdd00);
    text-decoration: none;
  }

  .content-page :global(a:hover) {
    text-decoration: underline;
  }

  .cta {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px dotted var(--rule, oklch(87% 0.005 260));
  }

  .cta a {
    font-weight: 600;
  }
</style>
