---
const items = [
  {
    code: 'WHERE / IT STARTS',
    body: "I've always worked in the space between disciplines — too technical for the art world, too expressive for the engineering world. Sound, real-time graphics, interactive systems, and software architecture aren't separate practices for me. They're different faces of the same material.",
  },
  {
    code: 'ON / STAGE',
    body: 'For ten years I made work that lived and died in front of audiences — video direction for operas, live visuals at electronic music venues, generative installations at media art festivals across Europe and North America. You learn a different kind of rigour when there\'s no rollback and a thousand people are watching.',
  },
  {
    code: 'AI / BEFORE AI',
    body: "I led the development of an adaptive music platform — machine learning models that shaped sound in real time based on how people actually listened. I took a neural-network-driven robotics vision system from prototype to production, processing millions of nodes in real time. This was 2020–2023. The models were smaller, the hype was quieter, and the engineering problems were the same ones everyone is now discovering for the first time.",
  },
  {
    code: 'INTO / THE ENGINE ROOM',
    body: "The transition from stages to startups felt natural. A company in its first two years has the same energy as a live performance — you're building the thing while it's already running. I brought an unusual toolkit: real-time systems thinking, a habit of shipping with very little, and the ability to see a product from the audience's seat, not just the architecture diagram.",
  },
];
---

<section id="perspective" class="persp-section">

  <div class="persp-header">
    <span class="persp-label">— Perspective</span>
    <p class="persp-lead fade-up" data-delay="100">
      For twenty years I've been building at the place where sound, image, and code converge — turning digital systems into experiences people actually feel.
    </p>
  </div>

  <div class="persp-grid">
    {items.map((item, i) => (
      <div class="persp-item fade-up" data-delay={String(i * 80)}>
        <h3 class="persp-code">{item.code}</h3>
        <p class="persp-body">{item.body}</p>
      </div>
    ))}
  </div>

  <!-- Large statement line -->
  <div class="persp-statement fade-up" data-delay="350">
    <p>The stages got smaller.<br/>
    <strong>The systems got larger. The instinct stayed the same.</strong></p>
  </div>

</section>

<style>
  /* Dark inverted section — the visual contrast moment */
  .persp-section {
    background: #0E0D0B;
    color: #F0EDE6;
    padding: 6rem 3.5rem;
  }

  .persp-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 5rem;
    gap: 4rem;
  }

  .persp-label {
    font-family: 'Open Sans', sans-serif;
    font-weight: 400;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #5A5650;
    flex-shrink: 0;
    padding-top: 0.2rem;
  }

  .persp-lead {
    font-family: 'Open Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(1.6rem, 4vw, 3.5rem);
    letter-spacing: -0.035em;
    line-height: 1.1;
    color: #F0EDE6;
    text-transform: uppercase;
    text-align: right;
  }

  /* ── 2×2 grid of perspective items ── */
  .persp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid #2A2820;
    border-left: 1px solid #2A2820;
    margin-bottom: 5rem;
  }

  .persp-item {
    padding: 2.5rem;
    border-bottom: 1px solid #2A2820;
    border-right: 1px solid #2A2820;
  }

  .persp-code {
    font-family: 'Open Sans', sans-serif;
    font-weight: 800;
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    letter-spacing: -0.02em;
    line-height: 1.0;
    color: #F0EDE6;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .persp-body {
    font-family: 'Open Sans', sans-serif;
    font-weight: 300;
    font-size: 0.82rem;
    line-height: 1.8;
    color: #5A5650;
    letter-spacing: 0.01em;
  }

  /* ── Bottom statement — large type ── */
  .persp-statement {
    border-top: 1px solid #2A2820;
    padding-top: 3rem;
  }

  .persp-statement p {
    font-family: 'Open Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 3.5vw, 3rem);
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: #5A5650;
    text-transform: uppercase;
  }

  .persp-statement strong {
    color: #F0EDE6;
    font-weight: 800;
  }

  @media (max-width: 760px) {
    .persp-section { padding: 4rem 1.75rem; }
    .persp-header { flex-direction: column; gap: 1.5rem; }
    .persp-lead { text-align: left; }
    .persp-grid { grid-template-columns: 1fr; }
    .persp-item { padding: 2rem 0; }
  }
</style>
