---
const scorecard = [
  { dim: 'Problem framing',      weight: '35%', score: 7 },
  { dim: 'Stack & architecture', weight: '30%', score: 6 },
  { dim: 'Production readiness', weight: '25%', score: 4 },
  { dim: 'Governance',           weight: '10%', score: 3 },
];

const items = [
  {
    code: 'Tune in',
    body: 'Understand the real problem, the data, and the constraints before writing code or reaching for a model. Most failures are framing failures, not technical ones.',
  },
  {
    code: 'Compose the architecture',
    body: 'Choose the right stack and shape the system: services, data, and where AI actually earns its place. Design for reliability, cost, and the team that inherits it.',
  },
  {
    code: 'Ship and harden',
    body: 'Get it live, then make it dependable: tests, monitoring, guardrails, evals where AI is involved, and clear ownership.',
  },
  {
    code: 'Adopt responsibly',
    body: 'Governance sized to your company: security, data protection, EU AI Act readiness where it applies, decisions you can explain.',
  },
];
---

<section id="method" class="method-section">

  <div class="method-header fade-up" data-delay="0">
    <h2 class="method-lead">
      From signal<br/>
      to system.
    </h2>
    <div class="method-meta">
      <img src="/graphics/lars-ullrich-perspective.svg" alt="" class="method-perspective-img" aria-hidden="true" loading="lazy" decoding="async" />
      <p class="method-sub">From a demo that works to a system you can leave running.</p>
    </div>
  </div>

  <ol class="method-list">
    {items.map((item, i) => (
      <li class="method-item fade-up" data-delay={String(80 + i * 60)}>
        <span class="method-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
        <div class="method-content">
          <h3 class="method-code">{item.code}</h3>
          <p class="method-body">{item.body}</p>
        </div>
      </li>
    ))}
  </ol>

  <div class="sc-wrap fade-up" data-delay="300">
    <h3 class="sc-title">Readiness scorecard</h3>
    <p class="sc-context">A typical first engagement, scored across the four dimensions where production systems usually break. Most teams arrive strong on framing and weak on production readiness.</p>
    <div class="sc-row">
      {scorecard.map((s) => (
        <div class="sc-col" style={`flex: ${parseInt(s.weight)}`}>
          <span class="sc-dim">{s.dim}</span>
          <span class="sc-weight">{s.weight}</span>
          <div class="sc-bar-wrap">
            <div class="sc-bar-fill" style={`--fill: ${(s.score / 10 * 100).toFixed(1)}%`}></div>
          </div>
          <span class="sc-score">{s.score}<span class="sc-denom"> / 10</span></span>
        </div>
      ))}
    </div>
  </div>

  <div class="method-statement fade-up" data-delay="440">
    <p><span class="stmt-mid">The environments change</span><br/>
    <strong>The standard for shipping doesn't</strong></p>
  </div>

</section>

<style>
  .method-section {
    background: #2C303C;
    color: #ffffff;
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3.5rem);
    border-bottom: 1px dotted rgba(255,255,255,0.15);
    position: relative;
    overflow: hidden;
  }

  /* Diagonal soft-light gradient overlay — mirrors light.svg */
  .method-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(35, 31, 32, 0.35) 0%,
      rgba(255, 255, 255, 0.10) 100%
    );
    mix-blend-mode: soft-light;
    pointer-events: none;
    z-index: 0;
  }

  .method-section > * { position: relative; z-index: 1; }

  /* ── Header ── */
  .method-header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem 4rem;
    align-items: end;
    margin-bottom: clamp(3rem, 6vw, 5rem);
    border-bottom: 1px dotted rgba(255,255,255,0.15);
    padding-bottom: clamp(2.5rem, 4vw, 3.5rem);
  }

  .method-lead {
    font-size: clamp(2.4rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: #ffffff;
    text-transform: uppercase;
    text-wrap: balance;
    margin: 0;
  }

  .method-meta {
    text-align: right;
    max-width: 28ch;
    align-self: flex-end;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1rem;
  }

  .method-perspective-img {
    width: 100%;
    max-width: 280px;
    height: auto;
    display: block;
    opacity: 0.9;
  }

  .method-sub {
    font-size: var(--text-note-size, 0.875rem);
    font-weight: 400;
    line-height: var(--text-note-lh, 1.8);
    color: #ffffff;
  }

  /* ── Numbered list ── */
  .method-list {
    list-style: none;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .method-item {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 0 2rem;
    padding: clamp(1.75rem, 3vw, 2.5rem) 0;
    border-bottom: 1px dotted rgba(255,255,255,0.15);
    align-items: baseline;
  }

  .method-item:last-child {
    border-bottom: none;
  }

  .method-num {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: #bbdd00;
    font-variant-numeric: tabular-nums;
    padding-top: 0.3rem;
  }

  .method-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 3rem;
    align-items: baseline;
  }

  .method-code {
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: #ffffff;
  }

  .method-body {
    font-size: var(--text-body-size, 1rem);
    font-weight: 400;
    line-height: var(--text-body-lh, 1.875);
    color: #ffffff;
  }

  /* ── Closing statement ── */
  .method-statement {
    border-top: 1px dotted rgba(255,255,255,0.15);
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .method-statement p {
    font-size: clamp(1.4rem, 3.5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    color: #ffffff;
    text-transform: uppercase;
  }

  .stmt-small {
    font-size: clamp(0.85rem, 1.8vw, 1.5rem);
    font-weight: 500;
    color: rgba(255,255,255,0.45);
    letter-spacing: -0.01em;
  }

  .stmt-mid {
    font-size: clamp(1.4rem, 3.5vw, 3rem);
    font-weight: 700;
    color: rgba(255,255,255,0.65);
    letter-spacing: -0.03em;
  }

  .method-statement strong {
    font-size: clamp(1.7rem, 4.5vw, 3.8rem);
    color: #ffffff;
    font-weight: 800;
    display: inline;
  }

  /* ── Scorecard ── */
  .sc-wrap {
    padding-top: clamp(2rem, 4vw, 3rem);
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .sc-title {
    font-size: 0.58rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin-bottom: 0.75rem;
  }

  .sc-context {
    font-size: 0.78rem;
    font-weight: 400;
    line-height: 1.6;
    color: rgba(255,255,255,0.55);
    max-width: 62ch;
    margin-bottom: 1.75rem;
  }

  /* ── Scorecard columns — proportional flex widths ── */
  .sc-row {
    display: flex;
    width: 100%;
    overflow: hidden;
  }

  .sc-col {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.9rem 0 0.75rem 0;
    border-left: 1px dotted rgba(255,255,255,0.18);
    border-right: 1px dotted rgba(255,255,255,0.18);
    min-width: 0;
    flex-shrink: 1;
    overflow: hidden;
  }
  .sc-col:not(:first-child) { border-left: none; }

  .sc-dim,
  .sc-weight,
  .sc-score { padding-left: 1rem; padding-right: 1rem; }
  .sc-col:first-child .sc-dim,
  .sc-col:first-child .sc-weight,
  .sc-col:first-child .sc-score { padding-left: 0.75rem; }
  .sc-col:last-child .sc-dim,
  .sc-col:last-child .sc-weight,
  .sc-col:last-child .sc-score  { padding-right: 0.75rem; }

  .sc-dim {
    font-size: 0.72rem;
    font-weight: 400;
    color: rgba(255,255,255,0.6);
    line-height: 1.3;
  }

  .sc-weight {
    font-size: 0.72rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 0.15rem;
  }

  /* Animated bar */
  .sc-bar-wrap {
    height: 44px;
    background: rgba(255,255,255,0.06);
    overflow: hidden;
  }

  .sc-bar-fill {
    height: 100%;
    width: var(--fill, 50%);
    background: #bbdd00;
    transition: width 1.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  html.js-ready .sc-bar-fill { width: 0; }
  html.js-ready .sc-wrap.in .sc-bar-fill { width: var(--fill); }

  .sc-col:nth-child(1) .sc-bar-fill { transition-delay:   0ms; }
  .sc-col:nth-child(2) .sc-bar-fill { transition-delay: 110ms; }
  .sc-col:nth-child(3) .sc-bar-fill { transition-delay: 220ms; }
  .sc-col:nth-child(4) .sc-bar-fill { transition-delay: 330ms; }

  @media (prefers-reduced-motion: reduce) {
    .sc-bar-fill { transition: none; }
    html.js-ready .sc-bar-fill { width: var(--fill); }
  }

  .sc-score {
    font-size: clamp(0.9rem, 1.6vw, 1.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #ffffff;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    font-family: var(--font-display);
  }

  .sc-denom {
    font-size: 0.8em;
    font-weight: 400;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0;
  }

  @media (max-width: 900px) {
    .method-content { grid-template-columns: 1fr; gap: 0.75rem; }
    .sc-row { flex-wrap: wrap; }
    .sc-col { flex: 1 1 40% !important; }
    .sc-col:nth-child(2) { border-right: none; }
    .sc-col:nth-child(3) { padding-left: 0; }
  }

  @media (max-width: 760px) {
    .method-header { grid-template-columns: 1fr; }
    .method-meta { text-align: left; }
    .method-item { grid-template-columns: 2.5rem 1fr; gap: 0 1rem; }
  }

  @media (max-width: 480px) {
    .sc-row { flex-direction: column; }
    .sc-col { border-right: none; border-bottom: 1px dotted rgba(255,255,255,0.18); padding: 0.75rem 0; }
    .sc-col:last-child { border-bottom: none; }
    .sc-col:not(:first-child) { padding-left: 0; }
  }
</style>
