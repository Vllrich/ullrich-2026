---
const disciplines = [
  'Creative Direction',
  'WebGL / Three.js',
  'Generative Systems',
  'Full-Stack Architecture',
  'Interactive Design',
  'CTO Leadership',
];
---

<section id="about" class="about-section">
  <div class="about-grid">

    <div class="about-label">
      <span class="cat fade-in" style="color: #9A9288;">About</span>
    </div>

    <div class="about-body">
      <p class="about-lead fade-up" data-delay="100">
        Twelve years at the intersection of engineering,
        design, and digital art. Former CTO of two
        venture-backed companies.
      </p>

      <p class="about-prose fade-up" data-delay="240">
        I build things at the limit of what browsers can render —
        generative systems, immersive WebGL experiences, design tools,
        and technical foundations that allow creative ambition to scale.
        The work lives where code becomes material.
      </p>

      <div class="about-disciplines fade-up" data-delay="380">
        <span class="cat" style="color: #C4BFB6; display: block; margin-bottom: 1rem;">Disciplines</span>
        <ul class="disciplines-list">
          {disciplines.map(d => <li class="cat" style="color: #9A9288;">{d}</li>)}
        </ul>
      </div>
    </div>

    <div class="about-meta fade-in" data-delay="500">
      <dl class="meta-list">
        <dd>Berlin, DE</dd>
        <dd>52°31′ N · 13°23′ E</dd>
        <dd class="meta-sep">Open to</dd>
        <dd>Collaboration</dd>
        <dd>Advisory</dd>
        <dd>Senior roles</dd>
      </dl>
    </div>

  </div>
</section>

<style>
  .about-section {
    padding: 6rem 3.5rem;
    border-top: 1px solid #D4CFC6;
    background: #F0EDE6;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 2.2fr 1fr;
    gap: 0 4rem;
  }

  .about-label { padding-top: 0.1rem; }

  .about-lead {
    font-family: 'Open Sans', sans-serif;
    font-weight: 500;
    font-size: clamp(1.2rem, 2.4vw, 1.75rem);
    line-height: 1.45;
    letter-spacing: -0.02em;
    color: #0E0D0B;
    margin-bottom: 1.75rem;
  }

  .about-prose {
    font-family: 'Open Sans', sans-serif;
    font-weight: 300;
    font-size: 0.83rem;
    line-height: 1.9;
    letter-spacing: 0.01em;
    color: #9A9288;
    margin-bottom: 2.5rem;
    max-width: 44ch;
  }

  .disciplines-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.65rem 2.5rem;
  }

  .about-meta { text-align: right; }

  .meta-list {
    list-style: none;
    font-family: 'Open Sans', sans-serif;
    font-weight: 300;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9A9288;
    line-height: 2.2;
  }
  .meta-list dd { margin: 0; }
  .meta-sep { margin-top: 1.5rem !important; color: #C4BFB6; }

  @media (max-width: 900px) {
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-meta { text-align: left; }
  }

  @media (max-width: 640px) {
    .about-section { padding: 4rem 1.75rem; }
    .disciplines-list { grid-template-columns: 1fr; }
  }
</style>
