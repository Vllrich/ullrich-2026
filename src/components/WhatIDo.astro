---
import { landingCopy, type LandingLang } from '../data/landing';

interface Props {
  lang?: LandingLang;
}

const { lang = 'en' } = Astro.props;
const t = landingCopy(lang);
const beatIcons = [
  '/graphics/icon-find-use-case.svg',
  '/graphics/icon-build-system.svg',
  '/graphics/icon-build-and-operate.svg',
];
---

<section id={t.ids.whatIDo} class="wid-section">
  <h2 class="visually-hidden">{t.whatIDo.heading}</h2>

  <div class="wid-intro fade-up" data-delay="80">
    <p class="wid-statement">
      <img src="/graphics/intro-line.svg" alt="" class="wid-rule" aria-hidden="true" loading="lazy" decoding="async" />{t.whatIDo.statement}
    </p>
    <div class="wid-aside">
      <ul class="wid-services">
        {t.whatIDo.services.map((s) => (
          <li>{s}</li>
        ))}
      </ul>
    </div>
  </div>

  <div class="wid-beats">
    {t.whatIDo.beats.map((beat, i) => (
      <div class="beat fade-up" data-delay={String(160 + i * 80)}>
        <img src={beatIcons[i]} alt="" class="beat-icon" aria-hidden="true" loading="lazy" decoding="async" />
        <h3 class="beat-title">{beat.title}</h3>
        <p class="beat-body">{beat.body}</p>
      </div>
    ))}
  </div>

</section>

<style>
  .wid-section {
    background: var(--white, oklch(99% 0 0));
    border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Upper intro band — white ── */
  .wid-intro {
    background: #ffffff;
    padding: clamp(4rem, 8vw, 7rem) clamp(1.5rem, 4vw, 3.5rem) clamp(3rem, 5vw, 5rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  .wid-statement {
    font-size: var(--text-lead-size, clamp(1rem, 1.5vw, 1.125rem));
    font-weight: 500;
    line-height: var(--text-lead-lh, 1.7);
    color: var(--ink, #2C303C);
    max-width: 52ch;
  }

  .wid-rule {
    display: inline-block;
    width: 72px;
    height: auto;
    vertical-align: middle;
    margin-right: 0.6em;
    flex-shrink: 0;
  }

  .wid-aside {
    display: flex;
    flex-direction: column;
    align-self: center;
  }

  .wid-services {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .wid-services li {
    font-family: var(--font-sans, "Darker Grotesque", system-ui, sans-serif);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: oklch(18% 0.008 258);
    padding: 0.65rem 0;
    border-bottom: 1px solid oklch(14% 0.01 250 / 0.22);
    line-height: 1;
  }
  .wid-services li:first-child { border-top: 1px solid oklch(14% 0.01 250 / 0.22); }

  /* ── Three beats - horizontal row — white bg ── */
  .wid-beats {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    border-top: 1px dotted var(--rule, oklch(87% 0.005 260));
    padding: 0 clamp(1.5rem, 4vw, 3.5rem);
  }

  .beat {
    padding: clamp(2rem, 3.5vw, 3rem) clamp(1.5rem, 2.5vw, 2.5rem);
    border-right: 1px dotted var(--rule, oklch(87% 0.005 260));
  }
  .beat:first-child { padding-left: 0; }
  .beat:last-child  { border-right: none; padding-right: 0; }

  .beat-icon {
    display: block;
    width: 56px;
    height: 56px;
    margin-bottom: 1.75rem;
    flex-shrink: 0;
    object-fit: contain;
  }

  .beat-title {
    font-size: clamp(1.15rem, 2vw, 1.6rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink, #2C303C);
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .beat-body {
    font-size: var(--text-body-size, 1rem);
    font-weight: 400;
    line-height: var(--text-body-lh, 1.875);
    color: var(--dim, oklch(28% 0.010 258));
    max-width: 36ch;
  }

  @media (max-width: 1000px) {
    .wid-intro { grid-template-columns: 1fr; }
  }

  @media (max-width: 760px) {
    .wid-beats {
      grid-template-columns: 1fr;
    }
    .beat {
      border-right: none;
      border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
      padding: 2rem 0;
    }
    .beat:last-child { border-bottom: none; }
  }
</style>
