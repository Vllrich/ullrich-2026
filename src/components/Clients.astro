---
import { landingCopy, type LandingLang } from '../data/landing';

interface Props {
  lang?: LandingLang;
}

const { lang = 'en' } = Astro.props;
const t = landingCopy(lang);
const brands = ['SONY', 'PORSCHE', 'BMW', 'ARRI MEDIA', 'KORG', 'MICROPSI INDUSTRIES', 'CORPUS.MUSIC', 'THEATER DORTMUND', 'OPER DORTMUND', 'ECM RECORDS', 'AMP SOUND BRANDING', 'BERLINER FESTSPIELE', 'SILEX INVESTMENT'];
---

<div class="clients-wrap">
  <h2 class="clients-label">{t.clients.label}</h2>
  <div class="clients-strip" aria-hidden="true">
    <div class="clients-track">
      {[...brands, ...brands, ...brands].map((b) => (
        <span class="brand-item">
          {b}
          <span class="brand-sep" aria-hidden="true">·</span>
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  .clients-wrap {
    background: var(--white, oklch(99% 0 0));
    padding: 1.75rem clamp(1.5rem, 4vw, 3.5rem);
    overflow: hidden;
    position: relative;
  }

  .clients-wrap::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: clamp(1.5rem, 4vw, 3.5rem);
    right: clamp(1.5rem, 4vw, 3.5rem);
    border-bottom: 1px dotted var(--rule, oklch(87% 0.005 260));
  }

  .clients-label {
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--ghost, oklch(50% 0.006 260));
    padding: 0 0 0.5rem;
    margin: 0;
  }

  .clients-context {
    font-size: 0.78rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--ghost, oklch(50% 0.006 260));
    padding: 0 clamp(1.5rem, 4vw, 3.5rem) 0.9rem;
    margin: 0;
    max-width: 72ch;
  }

  .clients-strip {
    overflow: hidden;
    width: 100%;
  }

  .clients-track {
    display: flex;
    white-space: nowrap;
    animation: clients-scroll 32s linear infinite;
    width: max-content;
  }

  .clients-strip:hover .clients-track {
    animation-play-state: paused;
  }

  .brand-item {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--dim, oklch(28% 0.010 258));
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0 0.1rem;
  }

  .brand-sep {
    color: var(--rule, oklch(87% 0.005 260));
    font-weight: 400;
    margin-right: 1rem;
  }

  @keyframes clients-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.333%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .clients-track { animation: none; }
  }
</style>
