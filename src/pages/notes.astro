---
import Layout from '../layouts/Layout.astro';
import ContentFooter from '../components/ContentFooter.astro';
import SiteNav from '../components/SiteNav.astro';
import { notesEn } from '../data/notes';
import { languageAlternates } from '../lib/i18n';
import '../styles/content-page.css';

const description =
  'Short notes on production AI, agent reliability, corporate LLM, and fractional CTO work.';

const alternates = languageAlternates('/notes/', '/de/notizen/');
---

<Layout
  title="Notes - Lars Ullrich"
  description={description}
  canonical="/notes/"
  alternates={alternates}
>
  <div class="cp-shell">
    <SiteNav lang="en" variant="content" localeSwitch={{ href: '/de/notizen/', label: 'Deutsch' }} />

    <header class="cp-index-head">
      <h1>Notes</h1>
      <p>
        Short reads on the work. Audits, agents, corporate LLM, reliability, leadership.
        For anonymized cases, see
        <a href="/work/patterns/">Work</a>.
      </p>
    </header>

    <ol class="notes-index">
      {notesEn.map((n) => (
        <li class="notes-index-item">
          <a href={n.href} class="notes-index-link">
            <span class="notes-index-eyebrow">{n.eyebrow}</span>
            <span class="notes-index-title">{n.title}</span>
            <span class="notes-index-summary">{n.summary}</span>
          </a>
        </li>
      ))}
    </ol>
  </div>

  <ContentFooter lang="en" />
</Layout>
