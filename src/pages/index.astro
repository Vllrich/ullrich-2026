---
import Layout      from '../layouts/Layout.astro';
import Maintenance from '../components/Maintenance.astro';
import Cover       from '../components/Cover.astro';
import WhatIDo     from '../components/WhatIDo.astro';
import Perspective from '../components/Perspective.astro';
import Services    from '../components/Services.astro';
import Clients     from '../components/Clients.astro';
import About       from '../components/About.astro';
import Contact     from '../components/Contact.astro';

const maintenance = import.meta.env.PUBLIC_MAINTENANCE_MODE === 'true';
---

<Layout title="Lars Ullrich - Production-grade AI, Full-Stack Engineer & Fractional CTO">
  {maintenance ? (
    <Maintenance />
  ) : (
    <>
      <Cover />
      <WhatIDo />
      <Perspective />
      <Services />
      <Clients />
      <About />
      <Contact />
    </>
  )}
</Layout>
