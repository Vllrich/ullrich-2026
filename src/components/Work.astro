---
import '../styles/work.css';
import Clients from './Clients.astro';
import { workCases, localizeWorkEntry, workHref, type WorkLang } from '../data/work-patterns';
import { landingCopy, type LandingLang } from '../data/landing';

interface Props {
  lang?: LandingLang;
}

const { lang = 'en' } = Astro.props;
const t = landingCopy(lang);
const workLang: WorkLang = lang === 'de' ? 'de' : 'en';
const cases = workCases.map((entry) => localizeWorkEntry(entry, workLang));
---

<section id={t.ids.work} class="work-section" aria-labelledby="work-heading">
  <div class="work-header fade-up" data-delay="0">
    <h2 class="work-display" id="work-heading">{t.work.heading}</h2>
    <p class="work-sub">{t.work.sub}</p>
  </div>

  <Clients lang={lang} embedded />

  <ol class="work-previews">
    {cases.map((item, i) => (
      <li class="work-preview fade-up" data-delay={String(80 + i * 90)}>
        <a class="work-preview-link" href={workHref(item.id, workLang)}>
          <figure class="work-preview-media" aria-hidden="true">
            <img
              src={item.image}
              alt=""
              width="240"
              height="240"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <p class="work-preview-sector">{item.sector}</p>
          <h3 class="work-preview-title">{item.title}</h3>
          <p class="work-preview-desc">{item.blurb}</p>
          <span class="work-preview-more">{t.work.readCase}</span>
        </a>
      </li>
    ))}
  </ol>
</section>
