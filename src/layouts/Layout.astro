---
import '../styles/global.css';
import type { AlternateLink } from '../lib/i18n';
import { absoluteUrl } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  lang?: 'en' | 'de';
  alternates?: AlternateLink[];
}

const DEFAULT_DESCRIPTION =
  'I help growing companies get AI into production, and keep it running. Often agents, often on open models you host yourself. Full-stack engineer and fractional CTO/CAIO, with two decades of engineering behind the work.';

const {
  title = 'Lars Ullrich - Production AI, Agent Reliability & Fractional CTO',
  description = DEFAULT_DESCRIPTION,
  canonical,
  lang = 'en',
  alternates = [],
} = Astro.props;

const canonicalURL = canonical
  ? new URL(canonical, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);

const ogImageURL = new URL('/graphics/logo-lars-ullrich-og.png', Astro.site);
const ogLocale = lang === 'de' ? 'de_DE' : 'en_US';

const resolvedAlternates = alternates.map((a) => ({
  hreflang: a.hreflang,
  href: absoluteUrl(a.href),
}));

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': 'https://larsullrich.de/#person',
      name: 'Lars Ullrich',
      jobTitle: 'Fractional CTO / CAIO & Full-Stack AI Engineer',
      url: 'https://larsullrich.de',
      email: 'contact@larsullrich.de',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Berlin',
        addressCountry: 'DE',
      },
      sameAs: [
        'https://github.com/Vllrich',
        'https://www.linkedin.com/in/lars-ullrich-47338a27/',
        'https://www.instagram.com/vllrich/',
      ],
      knowsAbout: [
        'Production AI',
        'Corporate LLM',
        'Agent reliability',
        'AI systems & ML',
        'Agents / RAG / automation',
        'AI reliability & evaluation',
        'Open-weight & self-hosted models',
        'Fractional CTO / CAIO',
        'EU AI Act readiness',
        'Real-time graphics & GPU',
        'Audio engineering & DSP',
        'Product architecture',
      ],
      description: DEFAULT_DESCRIPTION,
    },
    {
      '@type': 'WebSite',
      '@id': 'https://larsullrich.de/#website',
      url: 'https://larsullrich.de',
      name: 'Lars Ullrich',
      inLanguage: ['en', 'de'],
    },
    {
      '@type': 'ProfessionalService',
      '@id': 'https://larsullrich.de/#service',
      name: 'Lars Ullrich - Production AI, Agent Reliability & Fractional CTO',
      url: 'https://larsullrich.de',
      areaServed: ['DE', 'EU', 'Worldwide'],
      provider: { '@id': 'https://larsullrich.de/#person' },
      description: DEFAULT_DESCRIPTION,
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'Services',
        itemListElement: [
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Readiness & Production Audit',
              url: 'https://larsullrich.de/services/readiness-audit/',
              description:
                'Strategy and fixed-scope audit to assess AI and engineering readiness for production. Delivered as a structured engagement with clear deliverables.',
            },
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Build Sprint',
              description:
                'Full-stack AI build engagement on a per-project basis, from prototype to production-ready system.',
            },
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Corporate LLM',
              url: 'https://larsullrich.de/corporate-llm/',
              description:
                'Company LLM stack under your control: private or open models, RAG over company data, access control, cost limits, and production ops.',
            },
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Reliability Retainer',
              description:
                'Ongoing AI reliability and operations on a monthly retainer: evaluations, monitoring, guardrails, drift checks, incident response, and EU AI Act re-assessment for production AI systems.',
            },
          },
          {
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: 'Fractional CTO / CAIO',
              url: 'https://larsullrich.de/fractional-cto-caio/',
              description:
                'Ongoing technical leadership on a monthly retainer: AI strategy, architecture decisions, and engineering team guidance.',
            },
          },
        ],
      },
    },
  ],
};
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {resolvedAlternates.map((a) => (
    <link rel="alternate" hreflang={a.hreflang} href={a.href} />
  ))}
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="author" content="Lars Ullrich" />
  <meta name="geo.region" content="DE-BE" />
  <meta name="geo.placename" content="Berlin" />
  <meta name="theme-color" content="#fafafa" />
  <link rel="icon" type="image/png" href="/graphics/logo-lars-ullrich.png" />
  <link rel="apple-touch-icon" href="/graphics/logo-lars-ullrich-512.png" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Lars Ullrich" />
  <meta property="og:locale" content={ogLocale} />
  {lang === 'en' && <meta property="og:locale:alternate" content="de_DE" />}
  {lang === 'de' && <meta property="og:locale:alternate" content="en_US" />}
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
  {import.meta.env.PROD && (
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "f4e21edead614058a4b53d2be7a1bf76"}'></script>
  )}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
</head>
<body>
  <div class="page">
    <slot />
  </div>

  <script>
    document.documentElement.classList.add('js-ready');

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            const el = e.target as HTMLElement;
            const delay = el.dataset.delay ? parseInt(el.dataset.delay) : 0;
            setTimeout(() => el.classList.add('in'), delay);
            io.unobserve(el);
          }
        }
      },
      { threshold: 0.06, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.fade-up, .fade-in').forEach(el => io.observe(el));
  </script>
</body>
</html>
