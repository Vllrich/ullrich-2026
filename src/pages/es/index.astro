---
import Layout from '../../layouts/Layout.astro';
import Maintenance from '../../components/Maintenance.astro';
import Cover from '../../components/Cover.astro';
import WhatIDo from '../../components/WhatIDo.astro';
import Perspective from '../../components/Perspective.astro';
import Services from '../../components/Services.astro';
import Work from '../../components/Work.astro';
import Consult from '../../components/Consult.astro';
import FAQ from '../../components/FAQ.astro';
import Contact from '../../components/Contact.astro';
import { languageAlternates } from '../../lib/i18n';
import { landingCopy } from '../../data/landing';

const maintenance = import.meta.env.PUBLIC_MAINTENANCE_MODE === 'true';
const t = landingCopy('es');
const alternates = languageAlternates('/', '/de/', '/es/');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': 'https://larsullrich.de/es/#webpage',
  url: 'https://larsullrich.de/es/',
  name: t.meta.title,
  description: t.meta.description,
  inLanguage: 'es',
  isPartOf: { '@id': 'https://larsullrich.de/#website' },
  about: { '@id': 'https://larsullrich.de/#person' },
};
---

<Layout
  title={t.meta.title}
  description={t.meta.description}
  canonical="/es/"
  lang="es"
  alternates={alternates}
>
  {maintenance ? (
    <Maintenance />
  ) : (
    <>
      <Cover lang="es" />
      <WhatIDo lang="es" />
      <Perspective lang="es" />
      <Services lang="es" />
      <Work lang="es" />
      <Consult lang="es" />
      <FAQ lang="es" />
      <Contact lang="es" />
    </>
  )}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</Layout>
